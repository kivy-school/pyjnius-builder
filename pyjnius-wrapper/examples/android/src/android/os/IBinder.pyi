from typing import Any, ClassVar, overload
from android.os.IInterface import IInterface
from android.os.Parcel import Parcel
from java.io.FileDescriptor import FileDescriptor

class IBinder:
    DUMP_TRANSACTION: ClassVar[int]
    FIRST_CALL_TRANSACTION: ClassVar[int]
    FLAG_ONEWAY: ClassVar[int]
    INTERFACE_TRANSACTION: ClassVar[int]
    LAST_CALL_TRANSACTION: ClassVar[int]
    LIKE_TRANSACTION: ClassVar[int]
    PING_TRANSACTION: ClassVar[int]
    TWEET_TRANSACTION: ClassVar[int]
    @staticmethod
    def getSuggestedMaxIpcSizeBytes() -> int: ...
    def getInterfaceDescriptor(self) -> str: ...
    def pingBinder(self) -> bool: ...
    def isBinderAlive(self) -> bool: ...
    def queryLocalInterface(self, arg0: str) -> IInterface: ...
    def dump(self, arg0: FileDescriptor, arg1: list[str]) -> None: ...
    def dumpAsync(self, arg0: FileDescriptor, arg1: list[str]) -> None: ...
    def transact(self, arg0: int, arg1: Parcel, arg2: Parcel, arg3: int) -> bool: ...
    def linkToDeath(self, arg0: "DeathRecipient", arg1: int) -> None: ...
    def unlinkToDeath(self, arg0: "DeathRecipient", arg1: int) -> bool: ...

    class DeathRecipient:
        @overload
        def binderDied(self) -> None: ...
        @overload
        def binderDied(self, arg0: "IBinder") -> None: ...
