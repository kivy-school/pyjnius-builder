from typing import Any, ClassVar, overload
from java.time.Clock import Clock

class SystemClock:
    @staticmethod
    def sleep(arg0: int) -> None: ...
    @staticmethod
    def setCurrentTimeMillis(arg0: int) -> bool: ...
    @staticmethod
    def uptimeMillis() -> int: ...
    @staticmethod
    def uptimeNanos() -> int: ...
    @staticmethod
    def elapsedRealtime() -> int: ...
    @staticmethod
    def elapsedRealtimeNanos() -> int: ...
    @staticmethod
    def currentThreadTimeMillis() -> int: ...
    @staticmethod
    def currentNetworkTimeClock() -> Clock: ...
    @staticmethod
    def currentGnssTimeClock() -> Clock: ...
