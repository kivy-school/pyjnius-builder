from typing import Any, ClassVar, overload
from android.os.WorkDuration import WorkDuration

class PerformanceHintManager:
    def getPreferredUpdateRateNanos(self) -> int: ...
    def createHintSession(self, arg0: list[int], arg1: int) -> "Session": ...

    class Session:
        def finalize(self) -> None: ...
        def updateTargetWorkDuration(self, arg0: int) -> None: ...
        @overload
        def reportActualWorkDuration(self, arg0: int) -> None: ...
        @overload
        def reportActualWorkDuration(self, arg0: WorkDuration) -> None: ...
        def close(self) -> None: ...
        def setPreferPowerEfficiency(self, arg0: bool) -> None: ...
        def setThreads(self, arg0: list[int]) -> None: ...
