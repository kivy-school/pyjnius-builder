from typing import Any, ClassVar, overload
from android.media.AudioAttributes import AudioAttributes
from android.os.VibrationAttributes import VibrationAttributes
from android.os.VibrationEffect import VibrationEffect

class Vibrator:
    VIBRATION_EFFECT_SUPPORT_NO: ClassVar[int]
    VIBRATION_EFFECT_SUPPORT_UNKNOWN: ClassVar[int]
    VIBRATION_EFFECT_SUPPORT_YES: ClassVar[int]
    def getId(self) -> int: ...
    def hasVibrator(self) -> bool: ...
    def hasAmplitudeControl(self) -> bool: ...
    def getResonantFrequency(self) -> float: ...
    def getQFactor(self) -> float: ...
    @overload
    def vibrate(self, arg0: int) -> None: ...
    @overload
    def vibrate(self, arg0: int, arg1: AudioAttributes) -> None: ...
    @overload
    def vibrate(self, arg0: list[int], arg1: int) -> None: ...
    @overload
    def vibrate(self, arg0: list[int], arg1: int, arg2: AudioAttributes) -> None: ...
    @overload
    def vibrate(self, arg0: VibrationEffect) -> None: ...
    @overload
    def vibrate(self, arg0: VibrationEffect, arg1: AudioAttributes) -> None: ...
    @overload
    def vibrate(self, arg0: VibrationEffect, arg1: VibrationAttributes) -> None: ...
    def areEffectsSupported(self, *arg0: int) -> list[int]: ...
    def areAllEffectsSupported(self, *arg0: int) -> int: ...
    def arePrimitivesSupported(self, *arg0: int) -> list[bool]: ...
    def areAllPrimitivesSupported(self, *arg0: int) -> bool: ...
    def getPrimitiveDurations(self, *arg0: int) -> list[int]: ...
    def cancel(self) -> None: ...
