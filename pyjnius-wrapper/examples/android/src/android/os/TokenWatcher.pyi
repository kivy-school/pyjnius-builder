from typing import Any, ClassVar, overload
from android.os.Handler import Handler
from android.os.IBinder import IBinder
from java.io.PrintWriter import PrintWriter

class TokenWatcher:
    def __init__(self, arg0: Handler, arg1: str) -> None: ...
    def acquired(self) -> None: ...
    def released(self) -> None: ...
    def acquire(self, arg0: IBinder, arg1: str) -> None: ...
    def cleanup(self, arg0: IBinder, arg1: bool) -> None: ...
    def release(self, arg0: IBinder) -> None: ...
    def isAcquired(self) -> bool: ...
    @overload
    def dump(self) -> None: ...
    @overload
    def dump(self, arg0: PrintWriter) -> None: ...
