from typing import Any, ClassVar, overload
from android.os.Parcel import Parcel
from android.os.ParcelFileDescriptor import ParcelFileDescriptor
from java.io.File import File
from java.io.InputStream import InputStream

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class DropBoxManager:
    ACTION_DROPBOX_ENTRY_ADDED: ClassVar[str]
    EXTRA_DROPPED_COUNT: ClassVar[str]
    EXTRA_TAG: ClassVar[str]
    EXTRA_TIME: ClassVar[str]
    IS_EMPTY: ClassVar[int]
    IS_GZIPPED: ClassVar[int]
    IS_TEXT: ClassVar[int]
    def __init__(self) -> None: ...
    def addText(self, arg0: str, arg1: str) -> None: ...
    def addData(self, arg0: str, arg1: list[int], arg2: int) -> None: ...
    def addFile(self, arg0: str, arg1: File, arg2: int) -> None: ...
    def isTagEnabled(self, arg0: str) -> bool: ...
    def getNextEntry(self, arg0: str, arg1: int) -> "Entry": ...

    class Entry:
        CREATOR: ClassVar[Creator]
        @overload
        def __init__(self, arg0: str, arg1: int) -> None: ...
        @overload
        def __init__(self, arg0: str, arg1: int, arg2: str) -> None: ...
        @overload
        def __init__(self, arg0: str, arg1: int, arg2: list[int], arg3: int) -> None: ...
        @overload
        def __init__(self, arg0: str, arg1: int, arg2: ParcelFileDescriptor, arg3: int) -> None: ...
        @overload
        def __init__(self, arg0: str, arg1: int, arg2: File, arg3: int) -> None: ...
        def close(self) -> None: ...
        def getTag(self) -> str: ...
        def getTimeMillis(self) -> int: ...
        def getFlags(self) -> int: ...
        def getText(self, arg0: int) -> str: ...
        def getInputStream(self) -> InputStream: ...
        def describeContents(self) -> int: ...
        def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
