from typing import Any, ClassVar, overload
from android.os.ParcelFileDescriptor import ParcelFileDescriptor
from java.util.concurrent.Executor import Executor

class BugreportManager:
    def startConnectivityBugreport(self, arg0: ParcelFileDescriptor, arg1: Executor, arg2: "BugreportCallback") -> None: ...
    def cancelBugreport(self) -> None: ...

    class BugreportCallback:
        BUGREPORT_ERROR_ANOTHER_REPORT_IN_PROGRESS: ClassVar[int]
        BUGREPORT_ERROR_INVALID_INPUT: ClassVar[int]
        BUGREPORT_ERROR_NO_BUGREPORT_TO_RETRIEVE: ClassVar[int]
        BUGREPORT_ERROR_RUNTIME: ClassVar[int]
        BUGREPORT_ERROR_USER_CONSENT_TIMED_OUT: ClassVar[int]
        BUGREPORT_ERROR_USER_DENIED_CONSENT: ClassVar[int]
        def __init__(self) -> None: ...
        def onProgress(self, arg0: float) -> None: ...
        def onError(self, arg0: int) -> None: ...
        def onFinished(self) -> None: ...
        def onEarlyReportFinished(self) -> None: ...
