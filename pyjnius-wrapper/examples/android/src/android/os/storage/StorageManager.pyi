    def getManageSpaceActivityIntent(self, arg0: str, arg1: int) -> PendingIntent: ...
    def unmountObb(self, arg0: str, arg1: bool, arg2: OnObbStateChangeListener) -> bool: ...
    def isObbMounted(self, arg0: str) -> bool: ...
    def getMountedObbPath(self, arg0: str) -> str: ...
    def getUuidForPath(self, arg0: File) -> UUID: ...
    def isAllocationSupported(self, arg0: FileDescriptor) -> bool: ...
