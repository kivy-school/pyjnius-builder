    def getStorageVolume(self, arg0: File) -> StorageVolume: ...
    @overload
    def getStorageVolume(self, arg0: Uri) -> StorageVolume: ...
    def getStorageVolumes(self) -> list: ...
    def getStorageVolumesIncludingSharedProfiles(self) -> list: ...
    def getRecentStorageVolumes(self) -> list: ...
    def getPrimaryStorageVolume(self) -> StorageVolume: ...
    def isEncrypted(self, arg0: File) -> bool: ...
