    def getCacheSizeBytes(self, arg0: UUID) -> int: ...
    def getAllocatableBytes(self, arg0: UUID) -> int: ...
    @overload
    def allocateBytes(self, arg0: UUID, arg1: int) -> None: ...
    @overload
    def allocateBytes(self, arg0: FileDescriptor, arg1: int) -> None: ...
    def setCacheBehaviorGroup(self, arg0: File, arg1: bool) -> None: ...
    def isCacheBehaviorGroup(self, arg0: File) -> bool: ...
    def setCacheBehaviorTombstone(self, arg0: File, arg1: bool) -> None: ...
    def isCacheBehaviorTombstone(self, arg0: File) -> bool: ...
    def isCheckpointSupported(self) -> bool: ...

    class StorageVolumeCallback:
        def __init__(self) -> None: ...
        def onStateChanged(self, arg0: StorageVolume) -> None: ...
