from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.se.omapi.Reader import Reader
from java.util.concurrent.Executor import Executor

class SEService:
    ACTION_SECURE_ELEMENT_STATE_CHANGED: ClassVar[str]
    EXTRA_READER_NAME: ClassVar[str]
    EXTRA_READER_STATE: ClassVar[str]
    def __init__(self, arg0: Context, arg1: Executor, arg2: "OnConnectedListener") -> None: ...
    def isConnected(self) -> bool: ...
    def getReaders(self) -> list[Reader]: ...
    def getUiccReader(self, arg0: int) -> Reader: ...
    def shutdown(self) -> None: ...
    def getVersion(self) -> str: ...

    class OnConnectedListener:
        def onConnected(self) -> None: ...
