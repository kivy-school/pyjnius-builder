from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.util.AttributeSet import AttributeSet
from android.view.View import View
from android.view.animation.Animation import Animation
from android.view.animation.Interpolator import Interpolator
from java.util.Random import Random

class LayoutAnimationController:
    ORDER_NORMAL: ClassVar[int]
    ORDER_RANDOM: ClassVar[int]
    ORDER_REVERSE: ClassVar[int]
    mAnimation: Animation
    mInterpolator: Interpolator
    mRandomizer: Random
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    @overload
    def __init__(self, arg0: Animation) -> None: ...
    @overload
    def __init__(self, arg0: Animation, arg1: float) -> None: ...
    def getOrder(self) -> int: ...
    def setOrder(self, arg0: int) -> None: ...
    @overload
    def setAnimation(self, arg0: Context, arg1: int) -> None: ...
    @overload
    def setAnimation(self, arg0: Animation) -> None: ...
    def getAnimation(self) -> Animation: ...
    @overload
    def setInterpolator(self, arg0: Context, arg1: int) -> None: ...
    @overload
    def setInterpolator(self, arg0: Interpolator) -> None: ...
    def getInterpolator(self) -> Interpolator: ...
    def getDelay(self) -> float: ...
    def setDelay(self, arg0: float) -> None: ...
    def willOverlap(self) -> bool: ...
    def start(self) -> None: ...
    def getAnimationForView(self, arg0: View) -> Animation: ...
    def isDone(self) -> bool: ...
    def getDelayForView(self, arg0: View) -> int: ...
    def getTransformedIndex(self, arg0: "AnimationParameters") -> int: ...

    class AnimationParameters:
        count: int
        index: int
        def __init__(self) -> None: ...
