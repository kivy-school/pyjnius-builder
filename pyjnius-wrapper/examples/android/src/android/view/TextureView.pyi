from android.graphics.Rect import Rect
from android.graphics.SurfaceTexture import SurfaceTexture
from android.graphics.drawable.Drawable import Drawable
from android.util.AttributeSet import AttributeSet
from android.view.View import View

class TextureView:
    @overload
    def __init__(self, arg0: Context) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int, arg3: int) -> None: ...
    def isOpaque(self) -> bool: ...
    def setOpaque(self, arg0: bool) -> None: ...
    def onAttachedToWindow(self) -> None: ...
    def setLayerType(self, arg0: int, arg1: Paint) -> None: ...
    def setLayerPaint(self, arg0: Paint) -> None: ...
    def getLayerType(self) -> int: ...
    def buildLayer(self) -> None: ...
    def setForeground(self, arg0: Drawable) -> None: ...
    def setBackgroundDrawable(self, arg0: Drawable) -> None: ...
    def draw(self, arg0: Canvas) -> None: ...
    def onDraw(self, arg0: Canvas) -> None: ...
    def onSizeChanged(self, arg0: int, arg1: int, arg2: int, arg3: int) -> None: ...
    def onVisibilityChanged(self, arg0: View, arg1: int) -> None: ...
    def setTransform(self, arg0: Matrix) -> None: ...
    def getTransform(self, arg0: Matrix) -> Matrix: ...
    @overload
    def getBitmap(self) -> Bitmap: ...
    @overload
    def getBitmap(self, arg0: int, arg1: int) -> Bitmap: ...
    @overload
    def getBitmap(self, arg0: Bitmap) -> Bitmap: ...
    def isAvailable(self) -> bool: ...
