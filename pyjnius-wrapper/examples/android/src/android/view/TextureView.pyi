    def lockCanvas(self) -> Canvas: ...
    @overload
    def lockCanvas(self, arg0: Rect) -> Canvas: ...
    def unlockCanvasAndPost(self, arg0: Canvas) -> None: ...
    def getSurfaceTexture(self) -> SurfaceTexture: ...
    def setSurfaceTexture(self, arg0: SurfaceTexture) -> None: ...
    def getSurfaceTextureListener(self) -> "SurfaceTextureListener": ...
    def setSurfaceTextureListener(self, arg0: "SurfaceTextureListener") -> None: ...

    class SurfaceTextureListener:
        def onSurfaceTextureAvailable(self, arg0: SurfaceTexture, arg1: int, arg2: int) -> None: ...
        def onSurfaceTextureSizeChanged(self, arg0: SurfaceTexture, arg1: int, arg2: int) -> None: ...
        def onSurfaceTextureDestroyed(self, arg0: SurfaceTexture) -> bool: ...
        def onSurfaceTextureUpdated(self, arg0: SurfaceTexture) -> None: ...
