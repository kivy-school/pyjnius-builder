from typing import Any, ClassVar, overload
from android.graphics.Canvas import Canvas
from android.graphics.Rect import Rect
from android.graphics.SurfaceTexture import SurfaceTexture
from android.os.Parcel import Parcel
from android.view.SurfaceControl import SurfaceControl

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class Surface:
    CHANGE_FRAME_RATE_ALWAYS: ClassVar[int]
    CHANGE_FRAME_RATE_ONLY_IF_SEAMLESS: ClassVar[int]
    CREATOR: ClassVar[Creator]
    FRAME_RATE_COMPATIBILITY_DEFAULT: ClassVar[int]
    FRAME_RATE_COMPATIBILITY_FIXED_SOURCE: ClassVar[int]
    ROTATION_0: ClassVar[int]
    ROTATION_180: ClassVar[int]
    ROTATION_270: ClassVar[int]
    ROTATION_90: ClassVar[int]
    @overload
    def __init__(self, arg0: SurfaceControl) -> None: ...
    @overload
    def __init__(self, arg0: SurfaceTexture) -> None: ...
    def finalize(self) -> None: ...
    def release(self) -> None: ...
    def isValid(self) -> bool: ...
    def lockCanvas(self, arg0: Rect) -> Canvas: ...
    def unlockCanvasAndPost(self, arg0: Canvas) -> None: ...
    def lockHardwareCanvas(self) -> Canvas: ...
    def unlockCanvas(self, arg0: Canvas) -> None: ...
    def describeContents(self) -> int: ...
    def readFromParcel(self, arg0: Parcel) -> None: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def toString(self) -> str: ...
    @overload
    def setFrameRate(self, arg0: float, arg1: int, arg2: int) -> None: ...
    @overload
    def setFrameRate(self, arg0: float, arg1: int) -> None: ...
    def clearFrameRate(self) -> None: ...

    class OutOfResourcesException:
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, arg0: str) -> None: ...
