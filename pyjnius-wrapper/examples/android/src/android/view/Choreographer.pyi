from typing import Any, ClassVar, overload

class Choreographer:
    @staticmethod
    def getInstance() -> "Choreographer": ...
    def postVsyncCallback(self, arg0: "VsyncCallback") -> None: ...
    def postFrameCallback(self, arg0: "FrameCallback") -> None: ...
    def postFrameCallbackDelayed(self, arg0: "FrameCallback", arg1: int) -> None: ...
    def removeFrameCallback(self, arg0: "FrameCallback") -> None: ...
    def removeVsyncCallback(self, arg0: "VsyncCallback") -> None: ...

    class FrameCallback:
        def doFrame(self, arg0: int) -> None: ...

    class FrameData:
        def getFrameTimeNanos(self) -> int: ...
        def getFrameTimelines(self) -> list["FrameTimeline"]: ...
        def getPreferredFrameTimeline(self) -> "FrameTimeline": ...

    class FrameTimeline:
        def getVsyncId(self) -> int: ...
        def getExpectedPresentationTimeNanos(self) -> int: ...
        def getDeadlineNanos(self) -> int: ...

    class VsyncCallback:
        def onVsync(self, arg0: "FrameData") -> None: ...
