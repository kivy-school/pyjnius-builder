from typing import Any, ClassVar, overload
from android.graphics.drawable.Drawable import Drawable
from android.view.View import View

class ContextMenu:
    @overload
    def setHeaderTitle(self, arg0: int) -> "ContextMenu": ...
    @overload
    def setHeaderTitle(self, arg0: str) -> "ContextMenu": ...
    @overload
    def setHeaderIcon(self, arg0: int) -> "ContextMenu": ...
    @overload
    def setHeaderIcon(self, arg0: Drawable) -> "ContextMenu": ...
    def setHeaderView(self, arg0: View) -> "ContextMenu": ...
    def clearHeader(self) -> None: ...

    class ContextMenuInfo:
        ...
