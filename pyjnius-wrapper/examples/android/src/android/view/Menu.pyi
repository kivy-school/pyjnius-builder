    def setGroupVisible(self, arg0: int, arg1: bool) -> None: ...
    def setGroupEnabled(self, arg0: int, arg1: bool) -> None: ...
    def hasVisibleItems(self) -> bool: ...
    def findItem(self, arg0: int) -> MenuItem: ...
    def size(self) -> int: ...
    def getItem(self, arg0: int) -> MenuItem: ...
    def close(self) -> None: ...
    def performShortcut(self, arg0: int, arg1: KeyEvent, arg2: int) -> bool: ...
    def isShortcutKey(self, arg0: int, arg1: KeyEvent) -> bool: ...
    def performIdentifierAction(self, arg0: int, arg1: int) -> bool: ...
    def setQwertyMode(self, arg0: bool) -> None: ...
    def setGroupDividerEnabled(self, arg0: bool) -> None: ...
