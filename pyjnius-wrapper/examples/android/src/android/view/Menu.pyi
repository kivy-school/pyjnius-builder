    @overload
    def add(self, arg0: str) -> MenuItem: ...
    @overload
    def add(self, arg0: int) -> MenuItem: ...
    @overload
    def add(self, arg0: int, arg1: int, arg2: int, arg3: str) -> MenuItem: ...
    @overload
    def add(self, arg0: int, arg1: int, arg2: int, arg3: int) -> MenuItem: ...
