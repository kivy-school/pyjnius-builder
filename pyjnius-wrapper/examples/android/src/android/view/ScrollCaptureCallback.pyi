from typing import Any, ClassVar, overload
from android.graphics.Rect import Rect
from android.os.CancellationSignal import CancellationSignal
from android.view.ScrollCaptureSession import ScrollCaptureSession
from java.lang.Runnable import Runnable
from java.util.function.Consumer import Consumer

class ScrollCaptureCallback:
    def onScrollCaptureSearch(self, arg0: CancellationSignal, arg1: Consumer) -> None: ...
    def onScrollCaptureStart(self, arg0: ScrollCaptureSession, arg1: CancellationSignal, arg2: Runnable) -> None: ...
    def onScrollCaptureImageRequest(self, arg0: ScrollCaptureSession, arg1: CancellationSignal, arg2: Rect, arg3: Consumer) -> None: ...
    def onScrollCaptureEnd(self, arg0: Runnable) -> None: ...
