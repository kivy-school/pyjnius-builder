from typing import Any, ClassVar, overload
from android.content.Context import Context

class OrientationEventListener:
    ORIENTATION_UNKNOWN: ClassVar[int]
    @overload
    def __init__(self, arg0: Context) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: int) -> None: ...
    def enable(self) -> None: ...
    def disable(self) -> None: ...
    def canDetectOrientation(self) -> bool: ...
    def onOrientationChanged(self, arg0: int) -> None: ...
