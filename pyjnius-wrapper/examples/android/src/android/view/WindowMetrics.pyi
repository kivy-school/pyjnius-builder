from typing import Any, ClassVar, overload
from android.graphics.Rect import Rect
from android.view.WindowInsets import WindowInsets

class WindowMetrics:
    @overload
    def __init__(self, arg0: Rect, arg1: WindowInsets) -> None: ...
    @overload
    def __init__(self, arg0: Rect, arg1: WindowInsets, arg2: float) -> None: ...
    def getBounds(self) -> Rect: ...
    def getWindowInsets(self) -> WindowInsets: ...
    def getDensity(self) -> float: ...
    def toString(self) -> str: ...
