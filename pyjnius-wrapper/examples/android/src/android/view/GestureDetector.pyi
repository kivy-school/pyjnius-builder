from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.os.Handler import Handler
from android.view.MotionEvent import MotionEvent

class GestureDetector:
    @overload
    def __init__(self, arg0: "OnGestureListener", arg1: Handler) -> None: ...
    @overload
    def __init__(self, arg0: "OnGestureListener") -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: "OnGestureListener") -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: "OnGestureListener", arg2: Handler) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: "OnGestureListener", arg2: Handler, arg3: bool) -> None: ...
    def setOnDoubleTapListener(self, arg0: "OnDoubleTapListener") -> None: ...
    def setContextClickListener(self, arg0: "OnContextClickListener") -> None: ...
    def setIsLongpressEnabled(self, arg0: bool) -> None: ...
    def isLongpressEnabled(self) -> bool: ...
    def onTouchEvent(self, arg0: MotionEvent) -> bool: ...
    def onGenericMotionEvent(self, arg0: MotionEvent) -> bool: ...

    class OnContextClickListener:
        def onContextClick(self, arg0: MotionEvent) -> bool: ...

    class OnDoubleTapListener:
        def onSingleTapConfirmed(self, arg0: MotionEvent) -> bool: ...
        def onDoubleTap(self, arg0: MotionEvent) -> bool: ...
        def onDoubleTapEvent(self, arg0: MotionEvent) -> bool: ...

    class OnGestureListener:
        def onDown(self, arg0: MotionEvent) -> bool: ...
        def onShowPress(self, arg0: MotionEvent) -> None: ...
        def onSingleTapUp(self, arg0: MotionEvent) -> bool: ...
        def onScroll(self, arg0: MotionEvent, arg1: MotionEvent, arg2: float, arg3: float) -> bool: ...
        def onLongPress(self, arg0: MotionEvent) -> None: ...
        def onFling(self, arg0: MotionEvent, arg1: MotionEvent, arg2: float, arg3: float) -> bool: ...

    class SimpleOnGestureListener:
        def __init__(self) -> None: ...
        def onSingleTapUp(self, arg0: MotionEvent) -> bool: ...
        def onLongPress(self, arg0: MotionEvent) -> None: ...
        def onScroll(self, arg0: MotionEvent, arg1: MotionEvent, arg2: float, arg3: float) -> bool: ...
        def onFling(self, arg0: MotionEvent, arg1: MotionEvent, arg2: float, arg3: float) -> bool: ...
        def onShowPress(self, arg0: MotionEvent) -> None: ...
        def onDown(self, arg0: MotionEvent) -> bool: ...
        def onDoubleTap(self, arg0: MotionEvent) -> bool: ...
        def onDoubleTapEvent(self, arg0: MotionEvent) -> bool: ...
        def onSingleTapConfirmed(self, arg0: MotionEvent) -> bool: ...
        def onContextClick(self, arg0: MotionEvent) -> bool: ...
