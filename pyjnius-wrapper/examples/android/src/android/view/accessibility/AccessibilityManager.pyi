from typing import Any, ClassVar, overload
from android.os.Handler import Handler
from android.view.accessibility.AccessibilityEvent import AccessibilityEvent
from android.view.accessibility.AccessibilityRequestPreparer import AccessibilityRequestPreparer
from java.util.concurrent.Executor import Executor

class AccessibilityManager:
    FLAG_CONTENT_CONTROLS: ClassVar[int]
    FLAG_CONTENT_ICONS: ClassVar[int]
    FLAG_CONTENT_TEXT: ClassVar[int]
    def isEnabled(self) -> bool: ...
    def isTouchExplorationEnabled(self) -> bool: ...
    def sendAccessibilityEvent(self, arg0: AccessibilityEvent) -> None: ...
    def interrupt(self) -> None: ...
    def getAccessibilityServiceList(self) -> list: ...
    def getInstalledAccessibilityServiceList(self) -> list: ...
    def getEnabledAccessibilityServiceList(self, arg0: int) -> list: ...
    @overload
    def addAccessibilityStateChangeListener(self, arg0: "AccessibilityStateChangeListener") -> bool: ...
    @overload
    def addAccessibilityStateChangeListener(self, arg0: "AccessibilityStateChangeListener", arg1: Handler) -> None: ...
    def removeAccessibilityStateChangeListener(self, arg0: "AccessibilityStateChangeListener") -> bool: ...
    @overload
    def addTouchExplorationStateChangeListener(self, arg0: "TouchExplorationStateChangeListener") -> bool: ...
    @overload
    def addTouchExplorationStateChangeListener(self, arg0: "TouchExplorationStateChangeListener", arg1: Handler) -> None: ...
    def removeTouchExplorationStateChangeListener(self, arg0: "TouchExplorationStateChangeListener") -> bool: ...
    @overload
    def addAccessibilityServicesStateChangeListener(self, arg0: Executor, arg1: "AccessibilityServicesStateChangeListener") -> None: ...
    @overload
    def addAccessibilityServicesStateChangeListener(self, arg0: "AccessibilityServicesStateChangeListener") -> None: ...
    def removeAccessibilityServicesStateChangeListener(self, arg0: "AccessibilityServicesStateChangeListener") -> bool: ...
    def isRequestFromAccessibilityTool(self) -> bool: ...
    def addAccessibilityRequestPreparer(self, arg0: AccessibilityRequestPreparer) -> None: ...
    def removeAccessibilityRequestPreparer(self, arg0: AccessibilityRequestPreparer) -> None: ...
    def getRecommendedTimeoutMillis(self, arg0: int, arg1: int) -> int: ...
    def getAccessibilityFocusStrokeWidth(self) -> int: ...
    def getAccessibilityFocusColor(self) -> int: ...
    def addAudioDescriptionRequestedChangeListener(self, arg0: Executor, arg1: "AudioDescriptionRequestedChangeListener") -> None: ...
    def removeAudioDescriptionRequestedChangeListener(self, arg0: "AudioDescriptionRequestedChangeListener") -> bool: ...
    def isAudioDescriptionRequested(self) -> bool: ...
    @staticmethod
    def isAccessibilityButtonSupported() -> bool: ...

    class AccessibilityServicesStateChangeListener:
        def onAccessibilityServicesStateChanged(self, arg0: "AccessibilityManager") -> None: ...

    class AccessibilityStateChangeListener:
        def onAccessibilityStateChanged(self, arg0: bool) -> None: ...

    class AudioDescriptionRequestedChangeListener:
        def onAudioDescriptionRequestedChanged(self, arg0: bool) -> None: ...

    class TouchExplorationStateChangeListener:
        def onTouchExplorationStateChanged(self, arg0: bool) -> None: ...
