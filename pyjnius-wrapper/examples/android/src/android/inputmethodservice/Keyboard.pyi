from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.content.res.Resources import Resources
from android.content.res.XmlResourceParser import XmlResourceParser
from android.graphics.drawable.Drawable import Drawable

class Keyboard:
    EDGE_BOTTOM: ClassVar[int]
    EDGE_LEFT: ClassVar[int]
    EDGE_RIGHT: ClassVar[int]
    EDGE_TOP: ClassVar[int]
    KEYCODE_ALT: ClassVar[int]
    KEYCODE_CANCEL: ClassVar[int]
    KEYCODE_DELETE: ClassVar[int]
    KEYCODE_DONE: ClassVar[int]
    KEYCODE_MODE_CHANGE: ClassVar[int]
    KEYCODE_SHIFT: ClassVar[int]
    @overload
    def __init__(self, arg0: Context, arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: int, arg2: int, arg3: int, arg4: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: int, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: int, arg2: str, arg3: int, arg4: int) -> None: ...
    def getKeys(self) -> list: ...
    def getModifierKeys(self) -> list: ...
    def getHorizontalGap(self) -> int: ...
    def setHorizontalGap(self, arg0: int) -> None: ...
    def getVerticalGap(self) -> int: ...
    def setVerticalGap(self, arg0: int) -> None: ...
    def getKeyHeight(self) -> int: ...
    def setKeyHeight(self, arg0: int) -> None: ...
    def getKeyWidth(self) -> int: ...
    def setKeyWidth(self, arg0: int) -> None: ...
    def getHeight(self) -> int: ...
    def getMinWidth(self) -> int: ...
    def setShifted(self, arg0: bool) -> bool: ...
    def isShifted(self) -> bool: ...
    def getShiftKeyIndex(self) -> int: ...
    def getNearestKeys(self, arg0: int, arg1: int) -> list[int]: ...
    def createRowFromXml(self, arg0: Resources, arg1: XmlResourceParser) -> "Row": ...
    def createKeyFromXml(self, arg0: Resources, arg1: "Row", arg2: int, arg3: int, arg4: XmlResourceParser) -> "Key": ...

    class Key:
        codes: list[int]
        edgeFlags: int
        gap: int
        height: int
        icon: Drawable
        iconPreview: Drawable
        label: str
        modifier: bool
        on: bool
        popupCharacters: str
        popupResId: int
        pressed: bool
        repeatable: bool
        sticky: bool
        text: str
        width: int
        x: int
        y: int
        @overload
        def __init__(self, arg0: "Row") -> None: ...
        @overload
        def __init__(self, arg0: Resources, arg1: "Row", arg2: int, arg3: int, arg4: XmlResourceParser) -> None: ...
        def onPressed(self) -> None: ...
        def onReleased(self, arg0: bool) -> None: ...
        def isInside(self, arg0: int, arg1: int) -> bool: ...
        def squaredDistanceFrom(self, arg0: int, arg1: int) -> int: ...
        def getCurrentDrawableState(self) -> list[int]: ...

    class Row:
        defaultHeight: int
        defaultHorizontalGap: int
        defaultWidth: int
        mode: int
        rowEdgeFlags: int
        verticalGap: int
        @overload
        def __init__(self, arg0: "Keyboard") -> None: ...
        @overload
        def __init__(self, arg0: Resources, arg1: "Keyboard", arg2: XmlResourceParser) -> None: ...
