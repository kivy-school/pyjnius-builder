from typing import Any, ClassVar, overload
from android.icu.util.TimeZone import TimeZone
from android.icu.util.ULocale import ULocale
from java.util.Date import Date
from java.util.Locale import Locale

class IndianCalendar:
    AGRAHAYANA: ClassVar[int]
    ASADHA: ClassVar[int]
    ASVINA: ClassVar[int]
    BHADRA: ClassVar[int]
    CHAITRA: ClassVar[int]
    IE: ClassVar[int]
    JYAISTHA: ClassVar[int]
    KARTIKA: ClassVar[int]
    MAGHA: ClassVar[int]
    PAUSA: ClassVar[int]
    PHALGUNA: ClassVar[int]
    SRAVANA: ClassVar[int]
    VAISAKHA: ClassVar[int]
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: TimeZone) -> None: ...
    @overload
    def __init__(self, arg0: Locale) -> None: ...
    @overload
    def __init__(self, arg0: ULocale) -> None: ...
    @overload
    def __init__(self, arg0: TimeZone, arg1: Locale) -> None: ...
    @overload
    def __init__(self, arg0: TimeZone, arg1: ULocale) -> None: ...
    @overload
    def __init__(self, arg0: Date) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int, arg2: int, arg3: int, arg4: int, arg5: int) -> None: ...
    def handleGetExtendedYear(self) -> int: ...
    def handleGetYearLength(self, arg0: int) -> int: ...
    def handleGetMonthLength(self, arg0: int, arg1: int) -> int: ...
    def handleComputeFields(self, arg0: int) -> None: ...
    def handleGetLimit(self, arg0: int, arg1: int) -> int: ...
    def handleComputeMonthStart(self, arg0: int, arg1: int, arg2: bool) -> int: ...
    def getType(self) -> str: ...
