from typing import Any, ClassVar, overload

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Field:
    """Forward declaration for ``java.text.Format.Field``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('java.text.Format.Field')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://docs.oracle.com/javase/8/docs/api/java/text/Format/Field.html
    """
    ...

class ConstrainedFieldPosition:
    def __init__(self) -> None: ...
    def reset(self) -> None: ...
    def constrainField(self, arg0: Field) -> None: ...
    def constrainClass(self, arg0: type) -> None: ...
    def getField(self) -> Field: ...
    def getStart(self) -> int: ...
    def getLimit(self) -> int: ...
    def getFieldValue(self) -> Any: ...
    def getInt64IterationContext(self) -> int: ...
    def setInt64IterationContext(self, arg0: int) -> None: ...
    def setState(self, arg0: Field, arg1: Any, arg2: int, arg3: int) -> None: ...
    def matchesField(self, arg0: Field, arg1: Any) -> bool: ...
    def toString(self) -> str: ...
