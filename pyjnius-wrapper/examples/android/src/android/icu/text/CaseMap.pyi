from typing import Any, ClassVar, overload
from android.icu.text.BreakIterator import BreakIterator
from android.icu.text.Edits import Edits
from java.lang.Appendable import Appendable
from java.util.Locale import Locale

class CaseMap:
    @staticmethod
    def toLower() -> "Lower": ...
    @staticmethod
    def toUpper() -> "Upper": ...
    @staticmethod
    def toTitle() -> "Title": ...
    @staticmethod
    def fold() -> "Fold": ...
    def omitUnchangedText(self) -> "CaseMap": ...

    class Fold:
        def omitUnchangedText(self) -> "Fold": ...
        def turkic(self) -> "Fold": ...
        @overload
        def apply(self, arg0: str) -> str: ...
        @overload
        def apply(self, arg0: str, arg1: Appendable, arg2: Edits) -> Appendable: ...

    class Lower:
        def omitUnchangedText(self) -> "Lower": ...
        @overload
        def apply(self, arg0: Locale, arg1: str) -> str: ...
        @overload
        def apply(self, arg0: Locale, arg1: str, arg2: Appendable, arg3: Edits) -> Appendable: ...

    class Title:
        def wholeString(self) -> "Title": ...
        def sentences(self) -> "Title": ...
        def omitUnchangedText(self) -> "Title": ...
        def noLowercase(self) -> "Title": ...
        def noBreakAdjustment(self) -> "Title": ...
        def adjustToCased(self) -> "Title": ...
        @overload
        def apply(self, arg0: Locale, arg1: BreakIterator, arg2: str) -> str: ...
        @overload
        def apply(self, arg0: Locale, arg1: BreakIterator, arg2: str, arg3: Appendable, arg4: Edits) -> Appendable: ...

    class Upper:
        def omitUnchangedText(self) -> "Upper": ...
        @overload
        def apply(self, arg0: Locale, arg1: str) -> str: ...
        @overload
        def apply(self, arg0: Locale, arg1: str, arg2: Appendable, arg3: Edits) -> Appendable: ...
