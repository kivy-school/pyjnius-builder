from typing import Any, ClassVar, overload
from android.icu.text.UnicodeSet import UnicodeSet

class UnicodeSetIterator:
    IS_STRING: ClassVar[int]
    codepoint: int
    codepointEnd: int
    string: str
    @overload
    def __init__(self, arg0: UnicodeSet) -> None: ...
    @overload
    def __init__(self) -> None: ...
    def skipToStrings(self) -> "UnicodeSetIterator": ...
    def next(self) -> bool: ...
    def nextRange(self) -> bool: ...
    @overload
    def reset(self, arg0: UnicodeSet) -> None: ...
    @overload
    def reset(self) -> None: ...
    def getString(self) -> str: ...
