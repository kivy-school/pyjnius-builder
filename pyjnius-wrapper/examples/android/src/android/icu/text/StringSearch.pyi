from android.icu.util.ULocale import ULocale
from java.text.CharacterIterator import CharacterIterator
from java.util.Locale import Locale

class StringSearch:
    @overload
    def __init__(self, arg0: str, arg1: CharacterIterator, arg2: RuleBasedCollator, arg3: BreakIterator) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: CharacterIterator, arg2: RuleBasedCollator) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: CharacterIterator, arg2: Locale) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: CharacterIterator, arg2: ULocale) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: str) -> None: ...
    def getCollator(self) -> RuleBasedCollator: ...
    def setCollator(self, arg0: RuleBasedCollator) -> None: ...
    def getPattern(self) -> str: ...
    def setPattern(self, arg0: str) -> None: ...
    def isCanonical(self) -> bool: ...
    def setCanonical(self, arg0: bool) -> None: ...
    def setTarget(self, arg0: CharacterIterator) -> None: ...
    def getIndex(self) -> int: ...
    def setIndex(self, arg0: int) -> None: ...
    def reset(self) -> None: ...
    def handleNext(self, arg0: int) -> int: ...
    def handlePrevious(self, arg0: int) -> int: ...
