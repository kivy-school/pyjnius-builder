from typing import Any, ClassVar, overload

class MathContext:
    DEFAULT: ClassVar["MathContext"]
    ENGINEERING: ClassVar[int]
    PLAIN: ClassVar[int]
    ROUND_CEILING: ClassVar[int]
    ROUND_DOWN: ClassVar[int]
    ROUND_FLOOR: ClassVar[int]
    ROUND_HALF_DOWN: ClassVar[int]
    ROUND_HALF_EVEN: ClassVar[int]
    ROUND_HALF_UP: ClassVar[int]
    ROUND_UNNECESSARY: ClassVar[int]
    ROUND_UP: ClassVar[int]
    SCIENTIFIC: ClassVar[int]
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int, arg2: bool) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int, arg2: bool, arg3: int) -> None: ...
    def getDigits(self) -> int: ...
    def getForm(self) -> int: ...
    def getLostDigits(self) -> bool: ...
    def getRoundingMode(self) -> int: ...
    def toString(self) -> str: ...
