from typing import Any, ClassVar, overload

class Device:
    DEVICE_TYPE_CHEST_STRAP: ClassVar[int]
    DEVICE_TYPE_FITNESS_BAND: ClassVar[int]
    DEVICE_TYPE_HEAD_MOUNTED: ClassVar[int]
    DEVICE_TYPE_PHONE: ClassVar[int]
    DEVICE_TYPE_RING: ClassVar[int]
    DEVICE_TYPE_SCALE: ClassVar[int]
    DEVICE_TYPE_SMART_DISPLAY: ClassVar[int]
    DEVICE_TYPE_UNKNOWN: ClassVar[int]
    DEVICE_TYPE_WATCH: ClassVar[int]
    def getManufacturer(self) -> str: ...
    def getModel(self) -> str: ...
    def getType(self) -> int: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...

    class Builder:
        def __init__(self) -> None: ...
        def setManufacturer(self, arg0: str) -> "Builder": ...
        def setModel(self, arg0: str) -> "Builder": ...
        def setType(self, arg0: int) -> "Builder": ...
        def build(self) -> "Device": ...
