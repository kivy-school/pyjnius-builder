from typing import Any, ClassVar, overload
from android.health.connect.datatypes.units.Mass import Mass
from android.health.connect.datatypes.units.Power import Power
from android.health.connect.datatypes.units.Velocity import Velocity

class ExercisePerformanceGoal:

    class AmrapGoal:
        INSTANCE: ClassVar["AmrapGoal"]

    class CadenceGoal:
        def __init__(self, arg0: float, arg1: float) -> None: ...
        def getMinRpm(self) -> float: ...
        def getMaxRpm(self) -> float: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...

    class HeartRateGoal:
        def __init__(self, arg0: int, arg1: int) -> None: ...
        def getMinBpm(self) -> int: ...
        def getMaxBpm(self) -> int: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...

    class PowerGoal:
        def __init__(self, arg0: Power, arg1: Power) -> None: ...
        def getMinPower(self) -> Power: ...
        def getMaxPower(self) -> Power: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...

    class RateOfPerceivedExertionGoal:
        def __init__(self, arg0: int) -> None: ...
        def getRpe(self) -> int: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...

    class SpeedGoal:
        def __init__(self, arg0: Velocity, arg1: Velocity) -> None: ...
        def getMinSpeed(self) -> Velocity: ...
        def getMaxSpeed(self) -> Velocity: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...

    class UnknownGoal:
        INSTANCE: ClassVar["UnknownGoal"]

    class WeightGoal:
        def __init__(self, arg0: Mass) -> None: ...
        def getMass(self) -> Mass: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...
