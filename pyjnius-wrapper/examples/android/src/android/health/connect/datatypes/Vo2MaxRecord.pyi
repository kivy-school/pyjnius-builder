from typing import Any, ClassVar, overload
from android.health.connect.datatypes.Metadata import Metadata
from java.time.Instant import Instant
from java.time.ZoneOffset import ZoneOffset

class Vo2MaxRecord:
    def getMeasurementMethod(self) -> int: ...
    def getVo2MillilitersPerMinuteKilogram(self) -> float: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...

    class Builder:
        def __init__(self, arg0: Metadata, arg1: Instant, arg2: int, arg3: float) -> None: ...
        def setZoneOffset(self, arg0: ZoneOffset) -> "Builder": ...
        def clearZoneOffset(self) -> "Builder": ...
        def build(self) -> "Vo2MaxRecord": ...

    class Vo2MaxMeasurementMethod:
        MEASUREMENT_METHOD_COOPER_TEST: ClassVar[int]
        MEASUREMENT_METHOD_HEART_RATE_RATIO: ClassVar[int]
        MEASUREMENT_METHOD_METABOLIC_CART: ClassVar[int]
        MEASUREMENT_METHOD_MULTISTAGE_FITNESS_TEST: ClassVar[int]
        MEASUREMENT_METHOD_OTHER: ClassVar[int]
        MEASUREMENT_METHOD_ROCKPORT_FITNESS_TEST: ClassVar[int]
