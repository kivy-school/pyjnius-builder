from typing import Any, ClassVar, overload

class SynthesisCallback:
    def getMaxBufferSize(self) -> int: ...
    def start(self, arg0: int, arg1: int, arg2: int) -> int: ...
    def audioAvailable(self, arg0: list[int], arg1: int, arg2: int) -> int: ...
    def done(self) -> int: ...
    @overload
    def error(self) -> None: ...
    @overload
    def error(self, arg0: int) -> None: ...
    def hasStarted(self) -> bool: ...
    def hasFinished(self) -> bool: ...
    def rangeStart(self, arg0: int, arg1: int, arg2: int) -> None: ...
