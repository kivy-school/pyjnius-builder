from typing import Any, ClassVar, overload
from android.content.Context import Context

class RenderScript:
    CREATE_FLAG_LOW_LATENCY: ClassVar[int]
    CREATE_FLAG_LOW_POWER: ClassVar[int]
    CREATE_FLAG_NONE: ClassVar[int]
    @staticmethod
    def getMinorVersion() -> int: ...
    def setMessageHandler(self, arg0: "RSMessageHandler") -> None: ...
    def getMessageHandler(self) -> "RSMessageHandler": ...
    def sendMessage(self, arg0: int, arg1: list[int]) -> None: ...
    def setErrorHandler(self, arg0: "RSErrorHandler") -> None: ...
    def getErrorHandler(self) -> "RSErrorHandler": ...
    def setPriority(self, arg0: "Priority") -> None: ...
    def getApplicationContext(self) -> Context: ...
    @overload
    @staticmethod
    def create(arg0: Context) -> "RenderScript": ...
    @overload
    @staticmethod
    def create(arg0: Context, arg1: "ContextType") -> "RenderScript": ...
    @overload
    @staticmethod
    def create(arg0: Context, arg1: "ContextType", arg2: int) -> "RenderScript": ...
    @staticmethod
    def releaseAllContexts() -> None: ...
    @staticmethod
    def createMultiContext(arg0: Context, arg1: "ContextType", arg2: int, arg3: int) -> "RenderScript": ...
    def contextDump(self) -> None: ...
    def finish(self) -> None: ...
    def finalize(self) -> None: ...
    def destroy(self) -> None: ...

    class ContextType:
        NORMAL: ClassVar["ContextType"]
        DEBUG: ClassVar["ContextType"]
        PROFILE: ClassVar["ContextType"]
        @staticmethod
        def values() -> list["ContextType"]: ...
        @staticmethod
        def valueOf(arg0: str) -> "ContextType": ...

    class Priority:
        LOW: ClassVar["Priority"]
        NORMAL: ClassVar["Priority"]
        @staticmethod
        def values() -> list["Priority"]: ...
        @staticmethod
        def valueOf(arg0: str) -> "Priority": ...

    class RSErrorHandler:
        mErrorMessage: str
        mErrorNum: int
        def __init__(self) -> None: ...
        def run(self) -> None: ...

    class RSMessageHandler:
        mData: list[int]
        mID: int
        mLength: int
        def __init__(self) -> None: ...
        def run(self) -> None: ...
