from typing import Any, ClassVar, overload
from android.animation.Animator import Animator
from android.content.Context import Context
from android.transition.TransitionValues import TransitionValues
from android.util.AttributeSet import AttributeSet
from android.view.View import View
from android.view.ViewGroup import ViewGroup

class Visibility:
    MODE_IN: ClassVar[int]
    MODE_OUT: ClassVar[int]
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    def setMode(self, arg0: int) -> None: ...
    def getMode(self) -> int: ...
    def getTransitionProperties(self) -> list[str]: ...
    def captureStartValues(self, arg0: TransitionValues) -> None: ...
    def captureEndValues(self, arg0: TransitionValues) -> None: ...
    def isVisible(self, arg0: TransitionValues) -> bool: ...
    def createAnimator(self, arg0: ViewGroup, arg1: TransitionValues, arg2: TransitionValues) -> Animator: ...
    @overload
    def onAppear(self, arg0: ViewGroup, arg1: TransitionValues, arg2: int, arg3: TransitionValues, arg4: int) -> Animator: ...
    @overload
    def onAppear(self, arg0: ViewGroup, arg1: View, arg2: TransitionValues, arg3: TransitionValues) -> Animator: ...
    @overload
    def onDisappear(self, arg0: ViewGroup, arg1: TransitionValues, arg2: int, arg3: TransitionValues, arg4: int) -> Animator: ...
    @overload
    def onDisappear(self, arg0: ViewGroup, arg1: View, arg2: TransitionValues, arg3: TransitionValues) -> Animator: ...
    def isTransitionRequired(self, arg0: TransitionValues, arg1: TransitionValues) -> bool: ...
