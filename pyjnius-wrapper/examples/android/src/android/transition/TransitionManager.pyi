from typing import Any, ClassVar, overload
from android.transition.Scene import Scene
from android.transition.Transition import Transition
from android.view.ViewGroup import ViewGroup

class TransitionManager:
    def __init__(self) -> None: ...
    @overload
    def setTransition(self, arg0: Scene, arg1: Transition) -> None: ...
    @overload
    def setTransition(self, arg0: Scene, arg1: Scene, arg2: Transition) -> None: ...
    def transitionTo(self, arg0: Scene) -> None: ...
    @overload
    @staticmethod
    def go(arg0: Scene) -> None: ...
    @overload
    @staticmethod
    def go(arg0: Scene, arg1: Transition) -> None: ...
    @overload
    @staticmethod
    def beginDelayedTransition(arg0: ViewGroup) -> None: ...
    @overload
    @staticmethod
    def beginDelayedTransition(arg0: ViewGroup, arg1: Transition) -> None: ...
    @staticmethod
    def endTransitions(arg0: ViewGroup) -> None: ...
