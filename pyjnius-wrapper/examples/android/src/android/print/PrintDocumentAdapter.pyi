from typing import Any, ClassVar, overload
from android.os.Bundle import Bundle
from android.os.CancellationSignal import CancellationSignal
from android.os.ParcelFileDescriptor import ParcelFileDescriptor
from android.print.PageRange import PageRange
from android.print.PrintAttributes import PrintAttributes
from android.print.PrintDocumentInfo import PrintDocumentInfo

class PrintDocumentAdapter:
    EXTRA_PRINT_PREVIEW: ClassVar[str]
    def __init__(self) -> None: ...
    def onStart(self) -> None: ...
    def onLayout(self, arg0: PrintAttributes, arg1: PrintAttributes, arg2: CancellationSignal, arg3: "LayoutResultCallback", arg4: Bundle) -> None: ...
    def onWrite(self, arg0: list[PageRange], arg1: ParcelFileDescriptor, arg2: CancellationSignal, arg3: "WriteResultCallback") -> None: ...
    def onFinish(self) -> None: ...

    class LayoutResultCallback:
        def onLayoutFinished(self, arg0: PrintDocumentInfo, arg1: bool) -> None: ...
        def onLayoutFailed(self, arg0: str) -> None: ...
        def onLayoutCancelled(self) -> None: ...

    class WriteResultCallback:
        def onWriteFinished(self, arg0: list[PageRange]) -> None: ...
        def onWriteFailed(self, arg0: str) -> None: ...
        def onWriteCancelled(self) -> None: ...
