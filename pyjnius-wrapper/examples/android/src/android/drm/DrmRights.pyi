from typing import Any, ClassVar, overload
from android.drm.ProcessedData import ProcessedData
from java.io.File import File

class DrmRights:
    @overload
    def __init__(self, arg0: str, arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: str, arg2: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: str, arg2: str, arg3: str) -> None: ...
    @overload
    def __init__(self, arg0: File, arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: ProcessedData, arg1: str) -> None: ...
    def getData(self) -> list[int]: ...
    def getMimeType(self) -> str: ...
    def getAccountId(self) -> str: ...
    def getSubscriptionId(self) -> str: ...
