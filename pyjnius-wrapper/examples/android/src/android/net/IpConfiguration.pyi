    def getHttpProxy(self) -> ProxyInfo: ...
    def toString(self) -> str: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...

    class Builder:
        def __init__(self) -> None: ...
        def setStaticIpConfiguration(self, arg0: StaticIpConfiguration) -> "Builder": ...
        def setHttpProxy(self, arg0: ProxyInfo) -> "Builder": ...
        def build(self) -> "IpConfiguration": ...
