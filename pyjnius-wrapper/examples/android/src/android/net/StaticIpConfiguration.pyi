    def getIpAddress(self) -> LinkAddress: ...
    def getGateway(self) -> InetAddress: ...
    def getDnsServers(self) -> list: ...
    def getDomains(self) -> str: ...
    def toString(self) -> str: ...
    def hashCode(self) -> int: ...
    def equals(self, arg0: Any) -> bool: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...

    class Builder:
        def __init__(self) -> None: ...
        def setIpAddress(self, arg0: LinkAddress) -> "Builder": ...
        def setGateway(self, arg0: InetAddress) -> "Builder": ...
        def setDnsServers(self, arg0: Iterable) -> "Builder": ...
        def setDomains(self, arg0: str) -> "Builder": ...
        def build(self) -> "StaticIpConfiguration": ...
