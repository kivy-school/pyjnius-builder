from typing import Any, ClassVar, overload
from android.net.IpSecTransform import IpSecTransform
from java.io.FileDescriptor import FileDescriptor
from java.net.DatagramSocket import DatagramSocket
from java.net.InetAddress import InetAddress
from java.net.Socket import Socket

class IpSecManager:
    DIRECTION_IN: ClassVar[int]
    DIRECTION_OUT: ClassVar[int]
    @overload
    def allocateSecurityParameterIndex(self, arg0: InetAddress) -> "SecurityParameterIndex": ...
    @overload
    def allocateSecurityParameterIndex(self, arg0: InetAddress, arg1: int) -> "SecurityParameterIndex": ...
    @overload
    def applyTransportModeTransform(self, arg0: Socket, arg1: int, arg2: IpSecTransform) -> None: ...
    @overload
    def applyTransportModeTransform(self, arg0: DatagramSocket, arg1: int, arg2: IpSecTransform) -> None: ...
    @overload
    def applyTransportModeTransform(self, arg0: FileDescriptor, arg1: int, arg2: IpSecTransform) -> None: ...
    @overload
    def removeTransportModeTransforms(self, arg0: Socket) -> None: ...
    @overload
    def removeTransportModeTransforms(self, arg0: DatagramSocket) -> None: ...
    @overload
    def removeTransportModeTransforms(self, arg0: FileDescriptor) -> None: ...
    @overload
    def openUdpEncapsulationSocket(self, arg0: int) -> "UdpEncapsulationSocket": ...
    @overload
    def openUdpEncapsulationSocket(self) -> "UdpEncapsulationSocket": ...

    class ResourceUnavailableException:
        ...

    class SecurityParameterIndex:
        def getSpi(self) -> int: ...
        def close(self) -> None: ...
        def finalize(self) -> None: ...
        def toString(self) -> str: ...

    class SpiUnavailableException:
        def getSpi(self) -> int: ...

    class UdpEncapsulationSocket:
        def getFileDescriptor(self) -> FileDescriptor: ...
        def getPort(self) -> int: ...
        def close(self) -> None: ...
        def finalize(self) -> None: ...
        def toString(self) -> str: ...
