from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress

class RtpStream:
    MODE_NORMAL: ClassVar[int]
    MODE_RECEIVE_ONLY: ClassVar[int]
    MODE_SEND_ONLY: ClassVar[int]
    def getLocalAddress(self) -> InetAddress: ...
    def getLocalPort(self) -> int: ...
    def getRemoteAddress(self) -> InetAddress: ...
    def getRemotePort(self) -> int: ...
    def isBusy(self) -> bool: ...
    def getMode(self) -> int: ...
    def setMode(self, arg0: int) -> None: ...
    def associate(self, arg0: InetAddress, arg1: int) -> None: ...
    def release(self) -> None: ...
    def finalize(self) -> None: ...
