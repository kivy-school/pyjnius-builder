from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.net.rtp.AudioStream import AudioStream

class AudioGroup:
    MODE_ECHO_SUPPRESSION: ClassVar[int]
    MODE_MUTED: ClassVar[int]
    MODE_NORMAL: ClassVar[int]
    MODE_ON_HOLD: ClassVar[int]
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: Context) -> None: ...
    def getStreams(self) -> list[AudioStream]: ...
    def getMode(self) -> int: ...
    def setMode(self, arg0: int) -> None: ...
    def sendDtmf(self, arg0: int) -> None: ...
    def clear(self) -> None: ...
    def finalize(self) -> None: ...
