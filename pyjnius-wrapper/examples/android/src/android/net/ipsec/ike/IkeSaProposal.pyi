    @staticmethod
    def getSupportedIntegrityAlgorithms() -> set: ...
    @staticmethod
    def getSupportedPseudorandomFunctions() -> set: ...
    def getPseudorandomFunctions(self) -> list: ...
    def hashCode(self) -> int: ...
    def equals(self, arg0: Any) -> bool: ...

    class Builder:
