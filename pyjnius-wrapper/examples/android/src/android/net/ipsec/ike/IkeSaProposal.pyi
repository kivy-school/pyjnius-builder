        def addIntegrityAlgorithm(self, arg0: int) -> "Builder": ...
        def addDhGroup(self, arg0: int) -> "Builder": ...
        def addPseudorandomFunction(self, arg0: int) -> "Builder": ...
        def build(self) -> "IkeSaProposal": ...
