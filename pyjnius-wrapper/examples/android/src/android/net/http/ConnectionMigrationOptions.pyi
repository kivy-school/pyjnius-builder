from typing import Any, ClassVar, overload

class ConnectionMigrationOptions:
    MIGRATION_OPTION_DISABLED: ClassVar[int]
    MIGRATION_OPTION_ENABLED: ClassVar[int]
    MIGRATION_OPTION_UNSPECIFIED: ClassVar[int]
    def getDefaultNetworkMigration(self) -> int: ...
    def getPathDegradationMigration(self) -> int: ...
    def getAllowNonDefaultNetworkUsage(self) -> int: ...

    class Builder:
        def __init__(self) -> None: ...
        def setDefaultNetworkMigration(self, arg0: int) -> "Builder": ...
        def setPathDegradationMigration(self, arg0: int) -> "Builder": ...
        def setAllowNonDefaultNetworkUsage(self, arg0: int) -> "Builder": ...
        def build(self) -> "ConnectionMigrationOptions": ...
