from typing import Any, ClassVar, overload
from android.net.MacAddress import MacAddress
from android.net.wifi.WpsInfo import WpsInfo
from android.os.Parcel import Parcel

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class WifiP2pConfig:
    CREATOR: ClassVar[Creator]
    GROUP_CLIENT_IP_PROVISIONING_MODE_IPV4_DHCP: ClassVar[int]
    GROUP_CLIENT_IP_PROVISIONING_MODE_IPV6_LINK_LOCAL: ClassVar[int]
    GROUP_OWNER_BAND_2GHZ: ClassVar[int]
    GROUP_OWNER_BAND_5GHZ: ClassVar[int]
    GROUP_OWNER_BAND_AUTO: ClassVar[int]
    GROUP_OWNER_INTENT_AUTO: ClassVar[int]
    GROUP_OWNER_INTENT_MAX: ClassVar[int]
    GROUP_OWNER_INTENT_MIN: ClassVar[int]
    deviceAddress: str
    groupOwnerIntent: int
    wps: WpsInfo
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: "WifiP2pConfig") -> None: ...
    def getNetworkName(self) -> str: ...
    def getPassphrase(self) -> str: ...
    def getGroupOwnerBand(self) -> int: ...
    def getNetworkId(self) -> int: ...
    def getGroupClientIpProvisioningMode(self) -> int: ...
    def toString(self) -> str: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...

    class Builder:
        def __init__(self) -> None: ...
        def setDeviceAddress(self, arg0: MacAddress) -> "Builder": ...
        def setNetworkName(self, arg0: str) -> "Builder": ...
        def setPassphrase(self, arg0: str) -> "Builder": ...
        def setGroupOperatingBand(self, arg0: int) -> "Builder": ...
        def setGroupOperatingFrequency(self, arg0: int) -> "Builder": ...
        def enablePersistentMode(self, arg0: bool) -> "Builder": ...
        def setGroupClientIpProvisioningMode(self, arg0: int) -> "Builder": ...
        def build(self) -> "WifiP2pConfig": ...
