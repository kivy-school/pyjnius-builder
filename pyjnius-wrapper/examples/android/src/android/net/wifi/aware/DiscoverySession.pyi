from typing import Any, ClassVar, overload
from android.net.NetworkSpecifier import NetworkSpecifier
from android.net.wifi.aware.PeerHandle import PeerHandle

class DiscoverySession:
    def close(self) -> None: ...
    def finalize(self) -> None: ...
    def sendMessage(self, arg0: PeerHandle, arg1: int, arg2: list[int]) -> None: ...
    def initiatePairingRequest(self, arg0: PeerHandle, arg1: str, arg2: int, arg3: str) -> None: ...
    def acceptPairingRequest(self, arg0: int, arg1: PeerHandle, arg2: str, arg3: int, arg4: str) -> None: ...
    def rejectPairingRequest(self, arg0: int, arg1: PeerHandle) -> None: ...
    def initiateBootstrappingRequest(self, arg0: PeerHandle, arg1: int) -> None: ...
    def createNetworkSpecifierOpen(self, arg0: PeerHandle) -> NetworkSpecifier: ...
    def createNetworkSpecifierPassphrase(self, arg0: PeerHandle, arg1: str) -> NetworkSpecifier: ...
