from typing import Any, ClassVar, overload
from android.net.NetworkSpecifier import NetworkSpecifier
from android.net.wifi.aware.DiscoverySessionCallback import DiscoverySessionCallback
from android.net.wifi.aware.PublishConfig import PublishConfig
from android.net.wifi.aware.SubscribeConfig import SubscribeConfig
from android.os.Handler import Handler

class WifiAwareSession:
    def close(self) -> None: ...
    def finalize(self) -> None: ...
    def publish(self, arg0: PublishConfig, arg1: DiscoverySessionCallback, arg2: Handler) -> None: ...
    def subscribe(self, arg0: SubscribeConfig, arg1: DiscoverySessionCallback, arg2: Handler) -> None: ...
    def createNetworkSpecifierOpen(self, arg0: int, arg1: list[int]) -> NetworkSpecifier: ...
    def createNetworkSpecifierPassphrase(self, arg0: int, arg1: list[int], arg2: str) -> NetworkSpecifier: ...
