from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.graphics.BlendMode import BlendMode
from android.graphics.Canvas import Canvas
from android.util.AttributeSet import AttributeSet

class EdgeEffect:
    DEFAULT_BLEND_MODE: ClassVar[BlendMode]
    @overload
    def __init__(self, arg0: Context) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    def setSize(self, arg0: int, arg1: int) -> None: ...
    def isFinished(self) -> bool: ...
    def finish(self) -> None: ...
    @overload
    def onPull(self, arg0: float) -> None: ...
    @overload
    def onPull(self, arg0: float, arg1: float) -> None: ...
    def onPullDistance(self, arg0: float, arg1: float) -> float: ...
    def getDistance(self) -> float: ...
    def onRelease(self) -> None: ...
    def onAbsorb(self, arg0: int) -> None: ...
    def setColor(self, arg0: int) -> None: ...
    def setBlendMode(self, arg0: BlendMode) -> None: ...
    def getColor(self) -> int: ...
    def getBlendMode(self) -> BlendMode: ...
    def draw(self, arg0: Canvas) -> bool: ...
    def getMaxHeight(self) -> int: ...
