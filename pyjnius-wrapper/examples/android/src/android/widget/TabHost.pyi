from typing import Any, ClassVar, overload
from android.app.LocalActivityManager import LocalActivityManager
from android.content.Context import Context
from android.content.Intent import Intent
from android.graphics.drawable.Drawable import Drawable
from android.util.AttributeSet import AttributeSet
from android.view.KeyEvent import KeyEvent
from android.view.View import View
from android.widget.FrameLayout import FrameLayout
from android.widget.TabWidget import TabWidget

class TabHost:
    @overload
    def __init__(self, arg0: Context) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int, arg3: int) -> None: ...
    def newTabSpec(self, arg0: str) -> "TabSpec": ...
    @overload
    def setup(self) -> None: ...
    @overload
    def setup(self, arg0: LocalActivityManager) -> None: ...
    def onTouchModeChanged(self, arg0: bool) -> None: ...
    def addTab(self, arg0: "TabSpec") -> None: ...
    def clearAllTabs(self) -> None: ...
    def getTabWidget(self) -> TabWidget: ...
    def getCurrentTab(self) -> int: ...
    def getCurrentTabTag(self) -> str: ...
    def getCurrentTabView(self) -> View: ...
    def getCurrentView(self) -> View: ...
    def setCurrentTabByTag(self, arg0: str) -> None: ...
    def getTabContentView(self) -> FrameLayout: ...
    def dispatchKeyEvent(self, arg0: KeyEvent) -> bool: ...
    def dispatchWindowFocusChanged(self, arg0: bool) -> None: ...
    def getAccessibilityClassName(self) -> str: ...
    def setCurrentTab(self, arg0: int) -> None: ...
    def setOnTabChangedListener(self, arg0: "OnTabChangeListener") -> None: ...

    class OnTabChangeListener:
        def onTabChanged(self, arg0: str) -> None: ...

    class TabContentFactory:
        def createTabContent(self, arg0: str) -> View: ...

    class TabSpec:
        @overload
        def setIndicator(self, arg0: str) -> "TabSpec": ...
        @overload
        def setIndicator(self, arg0: str, arg1: Drawable) -> "TabSpec": ...
        @overload
        def setIndicator(self, arg0: View) -> "TabSpec": ...
        @overload
        def setContent(self, arg0: int) -> "TabSpec": ...
        @overload
        def setContent(self, arg0: "TabContentFactory") -> "TabSpec": ...
        @overload
        def setContent(self, arg0: Intent) -> "TabSpec": ...
        def getTag(self) -> str: ...
