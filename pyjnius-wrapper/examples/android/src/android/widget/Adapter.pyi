from typing import Any, ClassVar, overload
from android.database.DataSetObserver import DataSetObserver
from android.view.View import View
from android.view.ViewGroup import ViewGroup

class Adapter:
    IGNORE_ITEM_VIEW_TYPE: ClassVar[int]
    NO_SELECTION: ClassVar[int]
    def registerDataSetObserver(self, arg0: DataSetObserver) -> None: ...
    def unregisterDataSetObserver(self, arg0: DataSetObserver) -> None: ...
    def getCount(self) -> int: ...
    def getItem(self, arg0: int) -> Any: ...
    def getItemId(self, arg0: int) -> int: ...
    def hasStableIds(self) -> bool: ...
    def getView(self, arg0: int, arg1: View, arg2: ViewGroup) -> View: ...
    def getItemViewType(self, arg0: int) -> int: ...
    def getViewTypeCount(self) -> int: ...
    def isEmpty(self) -> bool: ...
    def getAutofillOptions(self) -> list[str]: ...
