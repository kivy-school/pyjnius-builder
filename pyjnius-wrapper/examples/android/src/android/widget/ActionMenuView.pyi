from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.content.res.Configuration import Configuration
from android.graphics.drawable.Drawable import Drawable
from android.util.AttributeSet import AttributeSet
from android.view.Menu import Menu
from android.view.MenuItem import MenuItem

class ActionMenuView:
    @overload
    def __init__(self, arg0: Context) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    def setPopupTheme(self, arg0: int) -> None: ...
    def getPopupTheme(self) -> int: ...
    def onConfigurationChanged(self, arg0: Configuration) -> None: ...
    def setOnMenuItemClickListener(self, arg0: "OnMenuItemClickListener") -> None: ...
    def onMeasure(self, arg0: int, arg1: int) -> None: ...
    def onLayout(self, arg0: bool, arg1: int, arg2: int, arg3: int, arg4: int) -> None: ...
    def onDetachedFromWindow(self) -> None: ...
    def setOverflowIcon(self, arg0: Drawable) -> None: ...
    def getOverflowIcon(self) -> Drawable: ...
    def generateDefaultLayoutParams(self) -> "LayoutParams": ...
    @overload
    def generateLayoutParams(self, arg0: AttributeSet) -> "LayoutParams": ...
    @overload
    def generateLayoutParams(self, arg0: "LayoutParams") -> "LayoutParams": ...
    def checkLayoutParams(self, arg0: "LayoutParams") -> bool: ...
    def getMenu(self) -> Menu: ...
    def showOverflowMenu(self) -> bool: ...
    def hideOverflowMenu(self) -> bool: ...
    def isOverflowMenuShowing(self) -> bool: ...
    def dismissPopupMenus(self) -> None: ...

    class LayoutParams:
        @overload
        def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
        @overload
        def __init__(self, arg0: "LayoutParams") -> None: ...
        @overload
        def __init__(self, arg0: "LayoutParams") -> None: ...
        @overload
        def __init__(self, arg0: int, arg1: int) -> None: ...

    class OnMenuItemClickListener:
        def onMenuItemClick(self, arg0: MenuItem) -> bool: ...
