    def setGravity(self, arg0: int) -> None: ...
    def getGravity(self) -> int: ...
    def getDragToOpenListener(self) -> OnTouchListener: ...
    def getMenu(self) -> Menu: ...
    def getMenuInflater(self) -> MenuInflater: ...
    def inflate(self, arg0: int) -> None: ...
    def show(self) -> None: ...
    def dismiss(self) -> None: ...
