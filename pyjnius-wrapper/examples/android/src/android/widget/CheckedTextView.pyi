    def setCheckMarkTintBlendMode(self, arg0: BlendMode) -> None: ...
    def getCheckMarkTintMode(self) -> Mode: ...
    def getCheckMarkTintBlendMode(self) -> BlendMode: ...
    def setVisibility(self, arg0: int) -> None: ...
