    def onDraw(self, arg0: Canvas) -> None: ...
    def onCreateDrawableState(self, arg0: int) -> list[int]: ...
    def drawableStateChanged(self) -> None: ...
    def drawableHotspotChanged(self, arg0: float, arg1: float) -> None: ...
    def getAccessibilityClassName(self) -> str: ...
