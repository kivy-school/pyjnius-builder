from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.util.AttributeSet import AttributeSet

class AbsoluteLayout:
    @overload
    def __init__(self, arg0: Context) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int, arg3: int) -> None: ...
    def onMeasure(self, arg0: int, arg1: int) -> None: ...
    def generateDefaultLayoutParams(self) -> "LayoutParams": ...
    def onLayout(self, arg0: bool, arg1: int, arg2: int, arg3: int, arg4: int) -> None: ...
    @overload
    def generateLayoutParams(self, arg0: AttributeSet) -> "LayoutParams": ...
    @overload
    def generateLayoutParams(self, arg0: "LayoutParams") -> "LayoutParams": ...
    def checkLayoutParams(self, arg0: "LayoutParams") -> bool: ...
    def shouldDelayChildPressedState(self) -> bool: ...

    class LayoutParams:
        x: int
        y: int
        @overload
        def __init__(self, arg0: int, arg1: int, arg2: int, arg3: int) -> None: ...
        @overload
        def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
        @overload
        def __init__(self, arg0: "LayoutParams") -> None: ...
        def debug(self, arg0: str) -> str: ...
