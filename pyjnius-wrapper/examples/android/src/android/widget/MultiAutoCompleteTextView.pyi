from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.util.AttributeSet import AttributeSet

class MultiAutoCompleteTextView:
    @overload
    def __init__(self, arg0: Context) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int, arg3: int) -> None: ...
    def setTokenizer(self, arg0: "Tokenizer") -> None: ...
    @overload
    def performFiltering(self, arg0: str, arg1: int) -> None: ...
    @overload
    def performFiltering(self, arg0: str, arg1: int, arg2: int, arg3: int) -> None: ...
    def enoughToFilter(self) -> bool: ...
    def performValidation(self) -> None: ...
    def replaceText(self, arg0: str) -> None: ...
    def getAccessibilityClassName(self) -> str: ...

    class CommaTokenizer:
        def __init__(self) -> None: ...
        def findTokenStart(self, arg0: str, arg1: int) -> int: ...
        def findTokenEnd(self, arg0: str, arg1: int) -> int: ...
        def terminateToken(self, arg0: str) -> str: ...

    class Tokenizer:
        def findTokenStart(self, arg0: str, arg1: int) -> int: ...
        def findTokenEnd(self, arg0: str, arg1: int) -> int: ...
        def terminateToken(self, arg0: str) -> str: ...
