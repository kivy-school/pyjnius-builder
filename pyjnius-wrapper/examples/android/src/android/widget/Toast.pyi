from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.view.View import View

class Toast:
    LENGTH_LONG: ClassVar[int]
    LENGTH_SHORT: ClassVar[int]
    def __init__(self, arg0: Context) -> None: ...
    def show(self) -> None: ...
    def cancel(self) -> None: ...
    def setView(self, arg0: View) -> None: ...
    def getView(self) -> View: ...
    def setDuration(self, arg0: int) -> None: ...
    def getDuration(self) -> int: ...
    def setMargin(self, arg0: float, arg1: float) -> None: ...
    def getHorizontalMargin(self) -> float: ...
    def getVerticalMargin(self) -> float: ...
    def setGravity(self, arg0: int, arg1: int, arg2: int) -> None: ...
    def getGravity(self) -> int: ...
    def getXOffset(self) -> int: ...
    def getYOffset(self) -> int: ...
    def addCallback(self, arg0: "Callback") -> None: ...
    def removeCallback(self, arg0: "Callback") -> None: ...
    @overload
    @staticmethod
    def makeText(arg0: Context, arg1: str, arg2: int) -> "Toast": ...
    @overload
    @staticmethod
    def makeText(arg0: Context, arg1: int, arg2: int) -> "Toast": ...
