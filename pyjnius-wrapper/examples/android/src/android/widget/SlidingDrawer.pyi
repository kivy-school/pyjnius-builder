from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.graphics.Canvas import Canvas
from android.util.AttributeSet import AttributeSet
from android.view.MotionEvent import MotionEvent
from android.view.View import View

class SlidingDrawer:
    ORIENTATION_HORIZONTAL: ClassVar[int]
    ORIENTATION_VERTICAL: ClassVar[int]
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: AttributeSet, arg2: int, arg3: int) -> None: ...
    def onFinishInflate(self) -> None: ...
    def onMeasure(self, arg0: int, arg1: int) -> None: ...
    def dispatchDraw(self, arg0: Canvas) -> None: ...
    def onLayout(self, arg0: bool, arg1: int, arg2: int, arg3: int, arg4: int) -> None: ...
    def onInterceptTouchEvent(self, arg0: MotionEvent) -> bool: ...
    def onTouchEvent(self, arg0: MotionEvent) -> bool: ...
    def toggle(self) -> None: ...
    def animateToggle(self) -> None: ...
    def open(self) -> None: ...
    def close(self) -> None: ...
    def animateClose(self) -> None: ...
    def animateOpen(self) -> None: ...
    def getAccessibilityClassName(self) -> str: ...
    def setOnDrawerOpenListener(self, arg0: "OnDrawerOpenListener") -> None: ...
    def setOnDrawerCloseListener(self, arg0: "OnDrawerCloseListener") -> None: ...
    def setOnDrawerScrollListener(self, arg0: "OnDrawerScrollListener") -> None: ...
    def getHandle(self) -> View: ...
    def getContent(self) -> View: ...
    def unlock(self) -> None: ...
    def lock(self) -> None: ...
    def isOpened(self) -> bool: ...
    def isMoving(self) -> bool: ...

    class OnDrawerCloseListener:
        def onDrawerClosed(self) -> None: ...

    class OnDrawerOpenListener:
        def onDrawerOpened(self) -> None: ...

    class OnDrawerScrollListener:
        def onScrollStarted(self) -> None: ...
        def onScrollEnded(self) -> None: ...
