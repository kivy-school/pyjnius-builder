from typing import Any, ClassVar, overload
from android.graphics.PointF import PointF

class PointFEvaluator:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: PointF) -> None: ...
    def evaluate(self, arg0: float, arg1: PointF, arg2: PointF) -> PointF: ...
