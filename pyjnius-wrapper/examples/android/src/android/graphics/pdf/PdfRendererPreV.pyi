from typing import Any, ClassVar, overload
from android.graphics.Bitmap import Bitmap
from android.graphics.Matrix import Matrix
from android.graphics.Rect import Rect
from android.graphics.pdf.LoadParams import LoadParams
from android.graphics.pdf.RenderParams import RenderParams
from android.graphics.pdf.models.FormEditRecord import FormEditRecord
from android.graphics.pdf.models.FormWidgetInfo import FormWidgetInfo
from android.graphics.pdf.models.selection.PageSelection import PageSelection
from android.graphics.pdf.models.selection.SelectionBoundary import SelectionBoundary
from android.os.ParcelFileDescriptor import ParcelFileDescriptor

class PdfRendererPreV:
    DOCUMENT_LINEARIZED_TYPE_LINEARIZED: ClassVar[int]
    DOCUMENT_LINEARIZED_TYPE_NON_LINEARIZED: ClassVar[int]
    PDF_FORM_TYPE_ACRO_FORM: ClassVar[int]
    PDF_FORM_TYPE_NONE: ClassVar[int]
    PDF_FORM_TYPE_XFA_FOREGROUND: ClassVar[int]
    PDF_FORM_TYPE_XFA_FULL: ClassVar[int]
    @overload
    def __init__(self, arg0: ParcelFileDescriptor) -> None: ...
    @overload
    def __init__(self, arg0: ParcelFileDescriptor, arg1: LoadParams) -> None: ...
    def getPageCount(self) -> int: ...
    def getDocumentLinearizationType(self) -> int: ...
    def openPage(self, arg0: int) -> "Page": ...
    def getPdfFormType(self) -> int: ...
    def write(self, arg0: ParcelFileDescriptor, arg1: bool) -> None: ...
    def close(self) -> None: ...
    def finalize(self) -> None: ...

    class Page:
        def getIndex(self) -> int: ...
        def render(self, arg0: Bitmap, arg1: Rect, arg2: Matrix, arg3: RenderParams) -> None: ...
        def getTextContents(self) -> list: ...
        def getImageContents(self) -> list: ...
        def getWidth(self) -> int: ...
        def getHeight(self) -> int: ...
        def searchText(self, arg0: str) -> list: ...
        def selectContent(self, arg0: SelectionBoundary, arg1: SelectionBoundary) -> PageSelection: ...
        def getLinkContents(self) -> list: ...
        def getGotoLinks(self) -> list: ...
        @overload
        def getFormWidgetInfos(self) -> list: ...
        @overload
        def getFormWidgetInfos(self, arg0: list[int]) -> list: ...
        def getFormWidgetInfoAtIndex(self, arg0: int) -> FormWidgetInfo: ...
        def getFormWidgetInfoAtPosition(self, arg0: int, arg1: int) -> FormWidgetInfo: ...
        def applyEdit(self, arg0: FormEditRecord) -> list: ...
        def close(self) -> None: ...
        def finalize(self) -> None: ...
