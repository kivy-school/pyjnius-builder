from typing import Any, ClassVar, overload
from android.graphics.Canvas import Canvas
from android.graphics.Rect import Rect
from java.io.OutputStream import OutputStream

class PdfDocument:
    def __init__(self) -> None: ...
    def startPage(self, arg0: "PageInfo") -> "Page": ...
    def finishPage(self, arg0: "Page") -> None: ...
    def writeTo(self, arg0: OutputStream) -> None: ...
    def getPages(self) -> list: ...
    def close(self) -> None: ...
    def finalize(self) -> None: ...

    class Page:
        def getCanvas(self) -> Canvas: ...
        def getInfo(self) -> "PageInfo": ...

    class PageInfo:
        def getPageWidth(self) -> int: ...
        def getPageHeight(self) -> int: ...
        def getContentRect(self) -> Rect: ...
        def getPageNumber(self) -> int: ...

        class Builder:
            def __init__(self, arg0: int, arg1: int, arg2: int) -> None: ...
            def setContentRect(self, arg0: Rect) -> "Builder": ...
            def create(self) -> "PageInfo": ...
