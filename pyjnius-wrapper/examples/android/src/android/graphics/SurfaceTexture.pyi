from typing import Any, ClassVar, overload
from android.os.Handler import Handler

class SurfaceTexture:
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: bool) -> None: ...
    @overload
    def __init__(self, arg0: bool) -> None: ...
    @overload
    def setOnFrameAvailableListener(self, arg0: "OnFrameAvailableListener") -> None: ...
    @overload
    def setOnFrameAvailableListener(self, arg0: "OnFrameAvailableListener", arg1: Handler) -> None: ...
    def setDefaultBufferSize(self, arg0: int, arg1: int) -> None: ...
    def updateTexImage(self) -> None: ...
    def releaseTexImage(self) -> None: ...
    def detachFromGLContext(self) -> None: ...
    def attachToGLContext(self, arg0: int) -> None: ...
    def getTransformMatrix(self, arg0: list[float]) -> None: ...
    def getTimestamp(self) -> int: ...
    def getDataSpace(self) -> int: ...
    def release(self) -> None: ...
    def isReleased(self) -> bool: ...
    def finalize(self) -> None: ...

    class OnFrameAvailableListener:
        def onFrameAvailable(self, arg0: "SurfaceTexture") -> None: ...

    class OutOfResourcesException:
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, arg0: str) -> None: ...
