from typing import Any, ClassVar, overload
from android.graphics.Color import Color
from android.graphics.MeshSpecification import MeshSpecification
from android.graphics.RectF import RectF
from java.nio.Buffer import Buffer
from java.nio.ShortBuffer import ShortBuffer

class Mesh:
    TRIANGLES: ClassVar[int]
    TRIANGLE_STRIP: ClassVar[int]
    @overload
    def __init__(self, arg0: MeshSpecification, arg1: int, arg2: Buffer, arg3: int, arg4: RectF) -> None: ...
    @overload
    def __init__(self, arg0: MeshSpecification, arg1: int, arg2: Buffer, arg3: int, arg4: ShortBuffer, arg5: RectF) -> None: ...
    @overload
    def setColorUniform(self, arg0: str, arg1: int) -> None: ...
    @overload
    def setColorUniform(self, arg0: str, arg1: int) -> None: ...
    @overload
    def setColorUniform(self, arg0: str, arg1: Color) -> None: ...
    @overload
    def setFloatUniform(self, arg0: str, arg1: float) -> None: ...
    @overload
    def setFloatUniform(self, arg0: str, arg1: float, arg2: float) -> None: ...
    @overload
    def setFloatUniform(self, arg0: str, arg1: float, arg2: float, arg3: float) -> None: ...
    @overload
    def setFloatUniform(self, arg0: str, arg1: float, arg2: float, arg3: float, arg4: float) -> None: ...
    @overload
    def setFloatUniform(self, arg0: str, arg1: list[float]) -> None: ...
    @overload
    def setIntUniform(self, arg0: str, arg1: int) -> None: ...
    @overload
    def setIntUniform(self, arg0: str, arg1: int, arg2: int) -> None: ...
    @overload
    def setIntUniform(self, arg0: str, arg1: int, arg2: int, arg3: int) -> None: ...
    @overload
    def setIntUniform(self, arg0: str, arg1: int, arg2: int, arg3: int, arg4: int) -> None: ...
    @overload
    def setIntUniform(self, arg0: str, arg1: list[int]) -> None: ...
