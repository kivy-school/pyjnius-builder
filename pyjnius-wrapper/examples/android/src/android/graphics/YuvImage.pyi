from typing import Any, ClassVar, overload
from android.graphics.ColorSpace import ColorSpace
from android.graphics.Rect import Rect
from java.io.OutputStream import OutputStream

class YuvImage:
    @overload
    def __init__(self, arg0: list[int], arg1: int, arg2: int, arg3: int, arg4: list[int]) -> None: ...
    @overload
    def __init__(self, arg0: list[int], arg1: int, arg2: int, arg3: int, arg4: list[int], arg5: ColorSpace) -> None: ...
    def compressToJpeg(self, arg0: Rect, arg1: int, arg2: OutputStream) -> bool: ...
    def compressToJpegR(self, arg0: "YuvImage", arg1: int, arg2: OutputStream) -> bool: ...
    def getYuvData(self) -> list[int]: ...
    def getYuvFormat(self) -> int: ...
    def getStrides(self) -> list[int]: ...
    def getWidth(self) -> int: ...
    def getHeight(self) -> int: ...
    def getColorSpace(self) -> ColorSpace: ...
