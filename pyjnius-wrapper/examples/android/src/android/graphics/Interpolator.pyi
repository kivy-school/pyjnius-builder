from typing import Any, ClassVar, overload

class Interpolator:
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int) -> None: ...
    @overload
    def reset(self, arg0: int) -> None: ...
    @overload
    def reset(self, arg0: int, arg1: int) -> None: ...
    def getKeyFrameCount(self) -> int: ...
    def getValueCount(self) -> int: ...
    @overload
    def setKeyFrame(self, arg0: int, arg1: int, arg2: list[float]) -> None: ...
    @overload
    def setKeyFrame(self, arg0: int, arg1: int, arg2: list[float], arg3: list[float]) -> None: ...
    def setRepeatMirror(self, arg0: float, arg1: bool) -> None: ...
    @overload
    def timeToValues(self, arg0: list[float]) -> "Result": ...
    @overload
    def timeToValues(self, arg0: int, arg1: list[float]) -> "Result": ...
    def finalize(self) -> None: ...

    class Result:
        NORMAL: ClassVar["Result"]
        FREEZE_START: ClassVar["Result"]
        FREEZE_END: ClassVar["Result"]
        @staticmethod
        def values() -> list["Result"]: ...
        @staticmethod
        def valueOf(arg0: str) -> "Result": ...
