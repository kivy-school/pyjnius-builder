    BREAK_STRATEGY_HIGH_QUALITY: ClassVar[int]
    BREAK_STRATEGY_SIMPLE: ClassVar[int]
    HYPHENATION_FREQUENCY_FULL: ClassVar[int]
    HYPHENATION_FREQUENCY_NONE: ClassVar[int]
    HYPHENATION_FREQUENCY_NORMAL: ClassVar[int]
    JUSTIFICATION_MODE_INTER_CHARACTER: ClassVar[int]
    JUSTIFICATION_MODE_INTER_WORD: ClassVar[int]
    JUSTIFICATION_MODE_NONE: ClassVar[int]
    def computeLineBreaks(self, arg0: MeasuredText, arg1: "ParagraphConstraints", arg2: int) -> "Result": ...

    class Builder:
        def __init__(self) -> None: ...
        def setBreakStrategy(self, arg0: int) -> "Builder": ...
        def setHyphenationFrequency(self, arg0: int) -> "Builder": ...
        def setJustificationMode(self, arg0: int) -> "Builder": ...
        def setIndents(self, arg0: list[int]) -> "Builder": ...
        def setUseBoundsForWidth(self, arg0: bool) -> "Builder": ...
        def build(self) -> "LineBreaker": ...

    class ParagraphConstraints:
        def __init__(self) -> None: ...
        def setWidth(self, arg0: float) -> None: ...
        def setIndent(self, arg0: float, arg1: int) -> None: ...
        def setTabStops(self, arg0: list[float], arg1: float) -> None: ...
        def getWidth(self) -> float: ...
        def getFirstWidth(self) -> float: ...
        def getFirstWidthLineCount(self) -> int: ...
        def getTabStops(self) -> list[float]: ...
        def getDefaultTabStop(self) -> float: ...

    class Result:
        def getLineCount(self) -> int: ...
        def getLineBreakOffset(self, arg0: int) -> int: ...
        def getLineWidth(self, arg0: int) -> float: ...
        def getLineAscent(self, arg0: int) -> float: ...
        def getLineDescent(self, arg0: int) -> float: ...
        def hasLineTab(self, arg0: int) -> bool: ...
        def getStartLineHyphenEdit(self, arg0: int) -> int: ...
        def getEndLineHyphenEdit(self, arg0: int) -> int: ...
