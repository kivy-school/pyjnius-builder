from typing import Any, ClassVar, overload
from android.graphics.Canvas import Canvas

class Picture:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: "Picture") -> None: ...
    def finalize(self) -> None: ...
    def beginRecording(self, arg0: int, arg1: int) -> Canvas: ...
    def endRecording(self) -> None: ...
    def getWidth(self) -> int: ...
    def getHeight(self) -> int: ...
    def requiresHardwareAcceleration(self) -> bool: ...
    def draw(self, arg0: Canvas) -> None: ...
