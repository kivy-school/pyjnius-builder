from typing import Any, ClassVar, overload
from android.graphics.ColorSpace import ColorSpace
from android.graphics.RenderNode import RenderNode
from android.hardware.HardwareBuffer import HardwareBuffer
from android.hardware.SyncFence import SyncFence
from java.util.concurrent.Executor import Executor
from java.util.function.Consumer import Consumer

class HardwareBufferRenderer:
    def __init__(self, arg0: HardwareBuffer) -> None: ...
    def setContentRoot(self, arg0: RenderNode) -> None: ...
    def obtainRenderRequest(self) -> "RenderRequest": ...
    def isClosed(self) -> bool: ...
    def close(self) -> None: ...
    def setLightSourceGeometry(self, arg0: float, arg1: float, arg2: float, arg3: float) -> None: ...
    def setLightSourceAlpha(self, arg0: float, arg1: float) -> None: ...

    class RenderRequest:
        def draw(self, arg0: Executor, arg1: Consumer) -> None: ...
        def setColorSpace(self, arg0: ColorSpace) -> "RenderRequest": ...
        def setBufferTransform(self, arg0: int) -> "RenderRequest": ...

    class RenderResult:
        ERROR_UNKNOWN: ClassVar[int]
        SUCCESS: ClassVar[int]
        def getFence(self) -> SyncFence: ...
        def getStatus(self) -> int: ...
