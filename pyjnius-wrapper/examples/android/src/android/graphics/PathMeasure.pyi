from typing import Any, ClassVar, overload
from android.graphics.Matrix import Matrix
from android.graphics.Path import Path

class PathMeasure:
    POSITION_MATRIX_FLAG: ClassVar[int]
    TANGENT_MATRIX_FLAG: ClassVar[int]
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: Path, arg1: bool) -> None: ...
    def setPath(self, arg0: Path, arg1: bool) -> None: ...
    def getLength(self) -> float: ...
    def getPosTan(self, arg0: float, arg1: list[float], arg2: list[float]) -> bool: ...
    def getMatrix(self, arg0: float, arg1: Matrix, arg2: int) -> bool: ...
    def getSegment(self, arg0: float, arg1: float, arg2: Path, arg3: bool) -> bool: ...
    def isClosed(self) -> bool: ...
    def nextContour(self) -> bool: ...
    def finalize(self) -> None: ...
