from typing import Any, ClassVar, overload
from android.telecom.DisconnectCause import DisconnectCause
from java.util.function.Consumer import Consumer

class CallControlCallback:
    def onSetActive(self, arg0: Consumer) -> None: ...
    def onSetInactive(self, arg0: Consumer) -> None: ...
    def onAnswer(self, arg0: int, arg1: Consumer) -> None: ...
    def onDisconnect(self, arg0: DisconnectCause, arg1: Consumer) -> None: ...
    def onCallStreamingStarted(self, arg0: Consumer) -> None: ...
