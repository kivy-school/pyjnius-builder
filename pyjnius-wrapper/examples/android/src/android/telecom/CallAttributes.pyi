from typing import Any, ClassVar, overload
from android.net.Uri import Uri
from android.os.Parcel import Parcel
from android.telecom.PhoneAccountHandle import PhoneAccountHandle

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class CallAttributes:
    AUDIO_CALL: ClassVar[int]
    CREATOR: ClassVar[Creator]
    DIRECTION_INCOMING: ClassVar[int]
    DIRECTION_OUTGOING: ClassVar[int]
    SUPPORTS_SET_INACTIVE: ClassVar[int]
    SUPPORTS_STREAM: ClassVar[int]
    SUPPORTS_TRANSFER: ClassVar[int]
    SUPPORTS_VIDEO_CALLING: ClassVar[int]
    VIDEO_CALL: ClassVar[int]
    def getPhoneAccountHandle(self) -> PhoneAccountHandle: ...
    def getDisplayName(self) -> str: ...
    def getAddress(self) -> Uri: ...
    def getDirection(self) -> int: ...
    def getCallType(self) -> int: ...
    def getCallCapabilities(self) -> int: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def toString(self) -> str: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...

    class Builder:
        def __init__(self, arg0: PhoneAccountHandle, arg1: int, arg2: str, arg3: Uri) -> None: ...
        def setCallType(self, arg0: int) -> "Builder": ...
        def setCallCapabilities(self, arg0: int) -> "Builder": ...
        def build(self) -> "CallAttributes": ...
