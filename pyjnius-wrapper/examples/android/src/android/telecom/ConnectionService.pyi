    def conferenceRemoteConnections(self, arg0: RemoteConnection, arg1: RemoteConnection) -> None: ...
    def addConference(self, arg0: Conference) -> None: ...
    def addExistingConnection(self, arg0: PhoneAccountHandle, arg1: Connection) -> None: ...
    def connectionServiceFocusReleased(self) -> None: ...
    def getAllConnections(self) -> list: ...
    def getAllConferences(self) -> list: ...
    def onCreateIncomingConnection(self, arg0: PhoneAccountHandle, arg1: ConnectionRequest) -> Connection: ...
    def onCreateIncomingConference(self, arg0: PhoneAccountHandle, arg1: ConnectionRequest) -> Conference: ...
    def onCreateIncomingConnectionFailed(self, arg0: PhoneAccountHandle, arg1: ConnectionRequest) -> None: ...
    def onCreateOutgoingConnectionFailed(self, arg0: PhoneAccountHandle, arg1: ConnectionRequest) -> None: ...
    def onCreateIncomingConferenceFailed(self, arg0: PhoneAccountHandle, arg1: ConnectionRequest) -> None: ...
    def onCreateOutgoingConferenceFailed(self, arg0: PhoneAccountHandle, arg1: ConnectionRequest) -> None: ...
    def onCreateOutgoingConnection(self, arg0: PhoneAccountHandle, arg1: ConnectionRequest) -> Connection: ...
