    def onCreateIncomingHandoverConnection(self, arg0: PhoneAccountHandle, arg1: ConnectionRequest) -> Connection: ...
    def onHandoverFailed(self, arg0: ConnectionRequest, arg1: int) -> None: ...
    def onConference(self, arg0: Connection, arg1: Connection) -> None: ...
    def onRemoteConferenceAdded(self, arg0: RemoteConference) -> None: ...
    def onRemoteExistingConnectionAdded(self, arg0: RemoteConnection) -> None: ...
    def onConnectionServiceFocusLost(self) -> None: ...
    def onConnectionServiceFocusGained(self) -> None: ...
