from typing import Any, ClassVar, overload
from android.os.Parcel import Parcel

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class VideoProfile:
    CREATOR: ClassVar[Creator]
    QUALITY_DEFAULT: ClassVar[int]
    QUALITY_HIGH: ClassVar[int]
    QUALITY_LOW: ClassVar[int]
    QUALITY_MEDIUM: ClassVar[int]
    STATE_AUDIO_ONLY: ClassVar[int]
    STATE_BIDIRECTIONAL: ClassVar[int]
    STATE_PAUSED: ClassVar[int]
    STATE_RX_ENABLED: ClassVar[int]
    STATE_TX_ENABLED: ClassVar[int]
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int) -> None: ...
    def getVideoState(self) -> int: ...
    def getQuality(self) -> int: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def toString(self) -> str: ...
    @staticmethod
    def videoStateToString(arg0: int) -> str: ...
    @staticmethod
    def isAudioOnly(arg0: int) -> bool: ...
    @staticmethod
    def isVideo(arg0: int) -> bool: ...
    @staticmethod
    def isTransmissionEnabled(arg0: int) -> bool: ...
    @staticmethod
    def isReceptionEnabled(arg0: int) -> bool: ...
    @staticmethod
    def isBidirectional(arg0: int) -> bool: ...
    @staticmethod
    def isPaused(arg0: int) -> bool: ...

    class CameraCapabilities:
        CREATOR: ClassVar[Creator]
        @overload
        def __init__(self, arg0: int, arg1: int) -> None: ...
        @overload
        def __init__(self, arg0: int, arg1: int, arg2: bool, arg3: float) -> None: ...
        def describeContents(self) -> int: ...
        def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
        def getWidth(self) -> int: ...
        def getHeight(self) -> int: ...
        def isZoomSupported(self) -> bool: ...
        def getMaxZoom(self) -> float: ...
