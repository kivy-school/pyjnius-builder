from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.content.res.ColorStateList import ColorStateList
from android.graphics.Typeface import Typeface
from android.os.LocaleList import LocaleList
from android.os.Parcel import Parcel
from android.text.TextPaint import TextPaint

class TextAppearanceSpan:
