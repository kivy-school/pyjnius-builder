from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.os.Parcel import Parcel
from android.text.TextPaint import TextPaint
from java.util.Locale import Locale

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class SuggestionSpan:
    ACTION_SUGGESTION_PICKED: ClassVar[str]
    CREATOR: ClassVar[Creator]
    FLAG_AUTO_CORRECTION: ClassVar[int]
    FLAG_EASY_CORRECT: ClassVar[int]
    FLAG_GRAMMAR_ERROR: ClassVar[int]
    FLAG_MISSPELLED: ClassVar[int]
    SUGGESTIONS_MAX_SIZE: ClassVar[int]
    SUGGESTION_SPAN_PICKED_AFTER: ClassVar[str]
    SUGGESTION_SPAN_PICKED_BEFORE: ClassVar[str]
    SUGGESTION_SPAN_PICKED_HASHCODE: ClassVar[str]
    @overload
    def __init__(self, arg0: Context, arg1: list[str], arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Locale, arg1: list[str], arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: Locale, arg2: list[str], arg3: int, arg4: type) -> None: ...
    @overload
    def __init__(self, arg0: Parcel) -> None: ...
    def getSuggestions(self) -> list[str]: ...
    def getLocale(self) -> str: ...
    def getLocaleObject(self) -> Locale: ...
    def getFlags(self) -> int: ...
    def setFlags(self, arg0: int) -> None: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def getSpanTypeId(self) -> int: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def updateDrawState(self, arg0: TextPaint) -> None: ...
    def getUnderlineColor(self) -> int: ...
