from typing import Any, ClassVar, overload
from android.os.Parcel import Parcel
from android.text.TextPaint import TextPaint

class AbsoluteSizeSpan:
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: bool) -> None: ...
    @overload
    def __init__(self, arg0: Parcel) -> None: ...
    def getSpanTypeId(self) -> int: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def getSize(self) -> int: ...
    def getDip(self) -> bool: ...
    def updateDrawState(self, arg0: TextPaint) -> None: ...
    def updateMeasureState(self, arg0: TextPaint) -> None: ...
    def toString(self) -> str: ...
