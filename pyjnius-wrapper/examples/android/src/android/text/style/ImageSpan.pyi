from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.graphics.Bitmap import Bitmap
from android.graphics.drawable.Drawable import Drawable
from android.net.Uri import Uri

class ImageSpan:
    @overload
    def __init__(self, arg0: Bitmap) -> None: ...
    @overload
    def __init__(self, arg0: Bitmap, arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: Bitmap) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: Bitmap, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Drawable) -> None: ...
    @overload
    def __init__(self, arg0: Drawable, arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: Drawable, arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: Drawable, arg1: str, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: Uri) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: Uri, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: int, arg2: int) -> None: ...
    def getDrawable(self) -> Drawable: ...
    def getSource(self) -> str: ...
    def toString(self) -> str: ...
