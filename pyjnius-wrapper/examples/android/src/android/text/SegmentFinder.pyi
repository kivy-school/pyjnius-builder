from typing import Any, ClassVar, overload

class SegmentFinder:
    DONE: ClassVar[int]
    def __init__(self) -> None: ...
    def previousStartBoundary(self, arg0: int) -> int: ...
    def previousEndBoundary(self, arg0: int) -> int: ...
    def nextStartBoundary(self, arg0: int) -> int: ...
    def nextEndBoundary(self, arg0: int) -> int: ...

    class PrescribedSegmentFinder:
        def __init__(self, arg0: list[int]) -> None: ...
        def previousStartBoundary(self, arg0: int) -> int: ...
        def previousEndBoundary(self, arg0: int) -> int: ...
        def nextStartBoundary(self, arg0: int) -> int: ...
        def nextEndBoundary(self, arg0: int) -> int: ...
