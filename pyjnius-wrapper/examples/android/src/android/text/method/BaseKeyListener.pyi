from typing import Any, ClassVar, overload
from android.text.Editable import Editable
from android.view.KeyEvent import KeyEvent
from android.view.View import View

class BaseKeyListener:
    def __init__(self) -> None: ...
    def backspace(self, arg0: View, arg1: Editable, arg2: int, arg3: KeyEvent) -> bool: ...
    def forwardDelete(self, arg0: View, arg1: Editable, arg2: int, arg3: KeyEvent) -> bool: ...
    def onKeyDown(self, arg0: View, arg1: Editable, arg2: int, arg3: KeyEvent) -> bool: ...
    def onKeyOther(self, arg0: View, arg1: Editable, arg2: KeyEvent) -> bool: ...
