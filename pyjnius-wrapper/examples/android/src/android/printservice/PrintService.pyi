from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.content.Intent import Intent
from android.os.IBinder import IBinder
from android.print.PrinterId import PrinterId
from android.printservice.PrintJob import PrintJob
from android.printservice.PrinterDiscoverySession import PrinterDiscoverySession

class PrintService:
    EXTRA_CAN_SELECT_PRINTER: ClassVar[str]
    EXTRA_PRINTER_INFO: ClassVar[str]
    EXTRA_PRINT_DOCUMENT_INFO: ClassVar[str]
    EXTRA_PRINT_JOB_INFO: ClassVar[str]
    EXTRA_SELECT_PRINTER: ClassVar[str]
    SERVICE_INTERFACE: ClassVar[str]
    SERVICE_META_DATA: ClassVar[str]
    def __init__(self) -> None: ...
    def attachBaseContext(self, arg0: Context) -> None: ...
    def onConnected(self) -> None: ...
    def onDisconnected(self) -> None: ...
    def onCreatePrinterDiscoverySession(self) -> PrinterDiscoverySession: ...
    def onRequestCancelPrintJob(self, arg0: PrintJob) -> None: ...
    def onPrintJobQueued(self, arg0: PrintJob) -> None: ...
    def getActivePrintJobs(self) -> list: ...
    def generatePrinterId(self, arg0: str) -> PrinterId: ...
    def onBind(self, arg0: Intent) -> IBinder: ...
