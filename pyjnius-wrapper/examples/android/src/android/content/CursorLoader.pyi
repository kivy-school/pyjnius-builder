    def __init__(self, arg0: Context) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: Uri, arg2: list[str], arg3: str, arg4: list[str], arg5: str) -> None: ...
    def loadInBackground(self) -> Cursor: ...
    def cancelLoadInBackground(self) -> None: ...
    def deliverResult(self, arg0: Cursor) -> None: ...
    def onStartLoading(self) -> None: ...
    def onStopLoading(self) -> None: ...
    def onCanceled(self, arg0: Cursor) -> None: ...
    def onReset(self) -> None: ...
    def getUri(self) -> Uri: ...
    def setUri(self, arg0: Uri) -> None: ...
    def getProjection(self) -> list[str]: ...
    def setProjection(self, arg0: list[str]) -> None: ...
    def getSelection(self) -> str: ...
    def setSelection(self, arg0: str) -> None: ...
    def getSelectionArgs(self) -> list[str]: ...
    def setSelectionArgs(self, arg0: list[str]) -> None: ...
    def getSortOrder(self) -> str: ...
    def setSortOrder(self, arg0: str) -> None: ...
