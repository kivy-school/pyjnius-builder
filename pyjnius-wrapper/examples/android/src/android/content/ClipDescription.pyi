from typing import Any, ClassVar, overload
from android.os.Parcel import Parcel
from android.os.PersistableBundle import PersistableBundle

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class ClipDescription:
    CLASSIFICATION_COMPLETE: ClassVar[int]
    CLASSIFICATION_NOT_COMPLETE: ClassVar[int]
    CLASSIFICATION_NOT_PERFORMED: ClassVar[int]
    CREATOR: ClassVar[Creator]
    EXTRA_IS_REMOTE_DEVICE: ClassVar[str]
    EXTRA_IS_SENSITIVE: ClassVar[str]
    MIMETYPE_TEXT_HTML: ClassVar[str]
    MIMETYPE_TEXT_INTENT: ClassVar[str]
    MIMETYPE_TEXT_PLAIN: ClassVar[str]
    MIMETYPE_TEXT_URILIST: ClassVar[str]
    MIMETYPE_UNKNOWN: ClassVar[str]
    @overload
    def __init__(self, arg0: str, arg1: list[str]) -> None: ...
    @overload
    def __init__(self, arg0: "ClipDescription") -> None: ...
    @staticmethod
    def compareMimeTypes(arg0: str, arg1: str) -> bool: ...
    def getTimestamp(self) -> int: ...
    def getLabel(self) -> str: ...
    def hasMimeType(self, arg0: str) -> bool: ...
    def filterMimeTypes(self, arg0: str) -> list[str]: ...
    def getMimeTypeCount(self) -> int: ...
    def getMimeType(self, arg0: int) -> str: ...
    def getExtras(self) -> PersistableBundle: ...
    def setExtras(self, arg0: PersistableBundle) -> None: ...
    def isStyledText(self) -> bool: ...
    def getConfidenceScore(self, arg0: str) -> float: ...
    def getClassificationStatus(self) -> int: ...
    def toString(self) -> str: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
