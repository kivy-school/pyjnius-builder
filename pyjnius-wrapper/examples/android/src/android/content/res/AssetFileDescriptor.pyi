from typing import Any, ClassVar, overload
from android.os.Bundle import Bundle
from android.os.Parcel import Parcel
from android.os.ParcelFileDescriptor import ParcelFileDescriptor
from java.io.FileDescriptor import FileDescriptor
from java.io.FileInputStream import FileInputStream
from java.io.FileOutputStream import FileOutputStream
from java.nio.channels.FileChannel import FileChannel

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class AssetFileDescriptor:
    CREATOR: ClassVar[Creator]
    UNKNOWN_LENGTH: ClassVar[int]
    @overload
    def __init__(self, arg0: ParcelFileDescriptor, arg1: int, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: ParcelFileDescriptor, arg1: int, arg2: int, arg3: Bundle) -> None: ...
    def getParcelFileDescriptor(self) -> ParcelFileDescriptor: ...
    def getFileDescriptor(self) -> FileDescriptor: ...
    def getStartOffset(self) -> int: ...
    def getExtras(self) -> Bundle: ...
    def getLength(self) -> int: ...
    def getDeclaredLength(self) -> int: ...
    def close(self) -> None: ...
    def createInputStream(self) -> FileInputStream: ...
    def createOutputStream(self) -> FileOutputStream: ...
    def toString(self) -> str: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...

    class AutoCloseInputStream:
        def __init__(self, arg0: "AssetFileDescriptor") -> None: ...
        def available(self) -> int: ...
        @overload
        def read(self) -> int: ...
        @overload
        def read(self, arg0: list[int], arg1: int, arg2: int) -> int: ...
        @overload
        def read(self, arg0: list[int]) -> int: ...
        def skip(self, arg0: int) -> int: ...
        def mark(self, arg0: int) -> None: ...
        def markSupported(self) -> bool: ...
        def reset(self) -> None: ...
        def getChannel(self) -> FileChannel: ...
        def close(self) -> None: ...

    class AutoCloseOutputStream:
        def __init__(self, arg0: "AssetFileDescriptor") -> None: ...
        @overload
        def write(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
        @overload
        def write(self, arg0: list[int]) -> None: ...
        @overload
        def write(self, arg0: int) -> None: ...
