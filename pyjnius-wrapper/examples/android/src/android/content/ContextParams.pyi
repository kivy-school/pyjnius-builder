from typing import Any, ClassVar, overload
from android.content.AttributionSource import AttributionSource

class ContextParams:
    def getAttributionTag(self) -> str: ...
    def getNextAttributionSource(self) -> AttributionSource: ...
    def shouldRegisterAttributionSource(self) -> bool: ...

    class Builder:
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, arg0: "ContextParams") -> None: ...
        def setAttributionTag(self, arg0: str) -> "Builder": ...
        def setNextAttributionSource(self, arg0: AttributionSource) -> "Builder": ...
        def setShouldRegisterAttributionSource(self, arg0: bool) -> "Builder": ...
        def build(self) -> "ContextParams": ...
