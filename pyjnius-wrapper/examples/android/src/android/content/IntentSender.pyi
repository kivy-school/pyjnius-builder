from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.content.Intent import Intent
from android.os.Bundle import Bundle
from android.os.Handler import Handler
from android.os.Parcel import Parcel
from android.os.UserHandle import UserHandle
from java.lang.Exception import Exception

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class IntentSender:
    CREATOR: ClassVar[Creator]
    @overload
    def sendIntent(self, arg0: Context, arg1: int, arg2: Intent, arg3: "OnFinished", arg4: Handler) -> None: ...
    @overload
    def sendIntent(self, arg0: Context, arg1: int, arg2: Intent, arg3: "OnFinished", arg4: Handler, arg5: str) -> None: ...
    def getTargetPackage(self) -> str: ...
    def getCreatorPackage(self) -> str: ...
    def getCreatorUid(self) -> int: ...
    def getCreatorUserHandle(self) -> UserHandle: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def toString(self) -> str: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    @staticmethod
    def writeIntentSenderOrNullToParcel(arg0: "IntentSender", arg1: Parcel) -> None: ...
    @staticmethod
    def readIntentSenderOrNullFromParcel(arg0: Parcel) -> "IntentSender": ...

    class OnFinished:
        def onSendFinished(self, arg0: "IntentSender", arg1: Intent, arg2: int, arg3: str, arg4: Bundle) -> None: ...

    class SendIntentException:
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, arg0: str) -> None: ...
        @overload
        def __init__(self, arg0: Exception) -> None: ...
