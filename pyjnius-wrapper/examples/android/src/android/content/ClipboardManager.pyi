from typing import Any, ClassVar, overload
from android.content.ClipData import ClipData
from android.content.ClipDescription import ClipDescription

class ClipboardManager:
    def setPrimaryClip(self, arg0: ClipData) -> None: ...
    def clearPrimaryClip(self) -> None: ...
    def getPrimaryClip(self) -> ClipData: ...
    def getPrimaryClipDescription(self) -> ClipDescription: ...
    def hasPrimaryClip(self) -> bool: ...
    def addPrimaryClipChangedListener(self, arg0: "OnPrimaryClipChangedListener") -> None: ...
    def removePrimaryClipChangedListener(self, arg0: "OnPrimaryClipChangedListener") -> None: ...
    def getText(self) -> str: ...
    def setText(self, arg0: str) -> None: ...
    def hasText(self) -> bool: ...

    class OnPrimaryClipChangedListener:
        def onPrimaryClipChanged(self) -> None: ...
