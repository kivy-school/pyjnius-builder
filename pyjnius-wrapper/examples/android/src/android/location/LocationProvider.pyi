from typing import Any, ClassVar, overload
from android.location.Criteria import Criteria

class LocationProvider:
    AVAILABLE: ClassVar[int]
    OUT_OF_SERVICE: ClassVar[int]
    TEMPORARILY_UNAVAILABLE: ClassVar[int]
    def getName(self) -> str: ...
    def meetsCriteria(self, arg0: Criteria) -> bool: ...
    def requiresNetwork(self) -> bool: ...
    def requiresSatellite(self) -> bool: ...
    def requiresCell(self) -> bool: ...
    def hasMonetaryCost(self) -> bool: ...
    def supportsAltitude(self) -> bool: ...
    def supportsSpeed(self) -> bool: ...
    def supportsBearing(self) -> bool: ...
    def getPowerRequirement(self) -> int: ...
    def getAccuracy(self) -> int: ...
