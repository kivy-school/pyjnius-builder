from typing import Any, ClassVar, overload
from android.os.Parcel import Parcel

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class LocationRequest:
    CREATOR: ClassVar[Creator]
    PASSIVE_INTERVAL: ClassVar[int]
    QUALITY_BALANCED_POWER_ACCURACY: ClassVar[int]
    QUALITY_HIGH_ACCURACY: ClassVar[int]
    QUALITY_LOW_POWER: ClassVar[int]
    def getQuality(self) -> int: ...
    def getIntervalMillis(self) -> int: ...
    def getDurationMillis(self) -> int: ...
    def getMaxUpdates(self) -> int: ...
    def getMinUpdateIntervalMillis(self) -> int: ...
    def getMinUpdateDistanceMeters(self) -> float: ...
    def getMaxUpdateDelayMillis(self) -> int: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def toString(self) -> str: ...

    class Builder:
        @overload
        def __init__(self, arg0: int) -> None: ...
        @overload
        def __init__(self, arg0: "LocationRequest") -> None: ...
        def setIntervalMillis(self, arg0: int) -> "Builder": ...
        def setQuality(self, arg0: int) -> "Builder": ...
        def setDurationMillis(self, arg0: int) -> "Builder": ...
        def setMaxUpdates(self, arg0: int) -> "Builder": ...
        def setMinUpdateIntervalMillis(self, arg0: int) -> "Builder": ...
        def clearMinUpdateIntervalMillis(self) -> "Builder": ...
        def setMinUpdateDistanceMeters(self, arg0: float) -> "Builder": ...
        def setMaxUpdateDelayMillis(self, arg0: int) -> "Builder": ...
        def build(self) -> "LocationRequest": ...
