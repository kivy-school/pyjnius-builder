    def hasBiasUncertaintyNanos(self) -> bool: ...
    def getBiasUncertaintyNanos(self) -> float: ...
    def hasDriftNanosPerSecond(self) -> bool: ...
    def getDriftNanosPerSecond(self) -> float: ...
    def hasDriftUncertaintyNanosPerSecond(self) -> bool: ...
    def getDriftUncertaintyNanosPerSecond(self) -> float: ...
    def hasElapsedRealtimeNanos(self) -> bool: ...
    def getElapsedRealtimeNanos(self) -> int: ...
    def hasElapsedRealtimeUncertaintyNanos(self) -> bool: ...
    def getElapsedRealtimeUncertaintyNanos(self) -> float: ...
