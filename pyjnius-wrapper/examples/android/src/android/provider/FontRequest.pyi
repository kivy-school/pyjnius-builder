from typing import Any, ClassVar, overload

class FontRequest:
    @overload
    def __init__(self, arg0: str, arg1: str, arg2: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: str, arg2: str, arg3: list) -> None: ...
    def getProviderAuthority(self) -> str: ...
    def getProviderPackage(self) -> str: ...
    def getQuery(self) -> str: ...
    def getCertificates(self) -> list: ...
    def toString(self) -> str: ...
