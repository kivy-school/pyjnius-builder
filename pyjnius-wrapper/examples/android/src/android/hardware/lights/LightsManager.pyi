from typing import Any, ClassVar, overload
from android.hardware.lights.Light import Light
from android.hardware.lights.LightState import LightState
from android.hardware.lights.LightsRequest import LightsRequest

class LightsManager:
    def getLights(self) -> list: ...
    def getLightState(self, arg0: Light) -> LightState: ...
    def openSession(self) -> "LightsSession": ...

    class LightsSession:
        def requestLights(self, arg0: LightsRequest) -> None: ...
        def close(self) -> None: ...
