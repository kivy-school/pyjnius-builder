# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class ViewBehavior:
    """Forward declaration for ``android.view.InputDevice.ViewBehavior``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.view.InputDevice.ViewBehavior')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/view/InputDevice/ViewBehavior
    """
    ...

class InputManager:
    ACTION_QUERY_KEYBOARD_LAYOUTS: ClassVar[str]
    META_DATA_KEYBOARD_LAYOUTS: ClassVar[str]
    def getInputDevice(self, arg0: int) -> InputDevice: ...
    def getInputDeviceViewBehavior(self, arg0: int) -> ViewBehavior: ...
    def getInputDeviceIds(self) -> list[int]: ...
    def registerInputDeviceListener(self, arg0: "InputDeviceListener", arg1: Handler) -> None: ...
    def unregisterInputDeviceListener(self, arg0: "InputDeviceListener") -> None: ...
    def getMaximumObscuringOpacityForTouch(self) -> float: ...
    def verifyInputEvent(self, arg0: InputEvent) -> VerifiedInputEvent: ...
    def isStylusPointerIconEnabled(self) -> bool: ...
    def getHostUsiVersion(self, arg0: Display) -> HostUsiVersion: ...

    class InputDeviceListener:
        def onInputDeviceAdded(self, arg0: int) -> None: ...
        def onInputDeviceRemoved(self, arg0: int) -> None: ...
        def onInputDeviceChanged(self, arg0: int) -> None: ...
