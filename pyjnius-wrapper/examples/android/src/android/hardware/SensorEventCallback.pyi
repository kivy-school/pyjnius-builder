from typing import Any, ClassVar, overload
from android.hardware.Sensor import Sensor
from android.hardware.SensorAdditionalInfo import SensorAdditionalInfo
from android.hardware.SensorEvent import SensorEvent

class SensorEventCallback:
    def __init__(self) -> None: ...
    def onSensorChanged(self, arg0: SensorEvent) -> None: ...
    def onAccuracyChanged(self, arg0: Sensor, arg1: int) -> None: ...
    def onFlushCompleted(self, arg0: Sensor) -> None: ...
    def onSensorAdditionalInfo(self, arg0: SensorAdditionalInfo) -> None: ...
