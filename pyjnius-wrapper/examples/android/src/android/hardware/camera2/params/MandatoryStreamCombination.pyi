from typing import Any, ClassVar, overload

class MandatoryStreamCombination:
    def getDescription(self) -> str: ...
    def isReprocessable(self) -> bool: ...
    def getStreamsInformation(self) -> list: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...

    class MandatoryStreamInformation:
        def isInput(self) -> bool: ...
        def isUltraHighResolution(self) -> bool: ...
        def isMaximumSize(self) -> bool: ...
        def is10BitCapable(self) -> bool: ...
        def getAvailableSizes(self) -> list: ...
        def getFormat(self) -> int: ...
        def get10BitFormat(self) -> int: ...
        def getStreamUseCase(self) -> int: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...
