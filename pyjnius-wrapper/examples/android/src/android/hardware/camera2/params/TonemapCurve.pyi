    def getPointCount(self, arg0: int) -> int: ...
    def getPoint(self, arg0: int, arg1: int) -> PointF: ...
    def copyColorCurve(self, arg0: int, arg1: list[float], arg2: int) -> None: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def toString(self) -> str: ...
