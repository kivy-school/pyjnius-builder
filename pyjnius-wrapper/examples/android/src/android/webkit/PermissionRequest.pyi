from typing import Any, ClassVar, overload
from android.net.Uri import Uri

class PermissionRequest:
    RESOURCE_AUDIO_CAPTURE: ClassVar[str]
    RESOURCE_MIDI_SYSEX: ClassVar[str]
    RESOURCE_PROTECTED_MEDIA_ID: ClassVar[str]
    RESOURCE_VIDEO_CAPTURE: ClassVar[str]
    def __init__(self) -> None: ...
    def getOrigin(self) -> Uri: ...
    def getResources(self) -> list[str]: ...
    def grant(self, arg0: list[str]) -> None: ...
    def deny(self) -> None: ...
