from typing import Any, ClassVar, overload
from android.os.Handler import Handler
from android.webkit.WebMessage import WebMessage

class WebMessagePort:
    def postMessage(self, arg0: WebMessage) -> None: ...
    def close(self) -> None: ...
    @overload
    def setWebMessageCallback(self, arg0: "WebMessageCallback") -> None: ...
    @overload
    def setWebMessageCallback(self, arg0: "WebMessageCallback", arg1: Handler) -> None: ...

    class WebMessageCallback:
        def __init__(self) -> None: ...
        def onMessage(self, arg0: "WebMessagePort", arg1: WebMessage) -> None: ...
