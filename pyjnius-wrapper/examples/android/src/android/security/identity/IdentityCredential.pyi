from typing import Any, ClassVar, overload
from android.security.identity.PersonalizationData import PersonalizationData
from android.security.identity.ResultData import ResultData
from java.security.KeyPair import KeyPair
from java.security.PublicKey import PublicKey
from java.security.cert.X509Certificate import X509Certificate
from java.time.Instant import Instant

class IdentityCredential:
    def createEphemeralKeyPair(self) -> KeyPair: ...
    def setReaderEphemeralPublicKey(self, arg0: PublicKey) -> None: ...
    def encryptMessageToReader(self, arg0: list[int]) -> list[int]: ...
    def decryptMessageFromReader(self, arg0: list[int]) -> list[int]: ...
    def getCredentialKeyCertificateChain(self) -> list: ...
    def setAllowUsingExhaustedKeys(self, arg0: bool) -> None: ...
    def setAllowUsingExpiredKeys(self, arg0: bool) -> None: ...
    def getEntries(self, arg0: list[int], arg1: dict, arg2: list[int], arg3: list[int]) -> ResultData: ...
    @overload
    def setAvailableAuthenticationKeys(self, arg0: int, arg1: int) -> None: ...
    @overload
    def setAvailableAuthenticationKeys(self, arg0: int, arg1: int, arg2: int) -> None: ...
    def getAuthKeysNeedingCertification(self) -> list: ...
    @overload
    def storeStaticAuthenticationData(self, arg0: X509Certificate, arg1: list[int]) -> None: ...
    @overload
    def storeStaticAuthenticationData(self, arg0: X509Certificate, arg1: Instant, arg2: list[int]) -> None: ...
    def getAuthenticationDataUsageCount(self) -> list[int]: ...
    def proveOwnership(self, arg0: list[int]) -> list[int]: ...
    def delete(self, arg0: list[int]) -> list[int]: ...
    def update(self, arg0: PersonalizationData) -> list[int]: ...
    def getAuthenticationKeyMetadata(self) -> list: ...
