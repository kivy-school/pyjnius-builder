from typing import Any, ClassVar, overload
from android.content.Context import Context
from java.math.BigInteger import BigInteger
from java.security.spec.AlgorithmParameterSpec import AlgorithmParameterSpec
from java.util.Date import Date
from javax.security.auth.x500.X500Principal import X500Principal

class KeyPairGeneratorSpec:
    def getContext(self) -> Context: ...
    def getKeystoreAlias(self) -> str: ...
    def getKeyType(self) -> str: ...
    def getKeySize(self) -> int: ...
    def getAlgorithmParameterSpec(self) -> AlgorithmParameterSpec: ...
    def getSubjectDN(self) -> X500Principal: ...
    def getSerialNumber(self) -> BigInteger: ...
    def getStartDate(self) -> Date: ...
    def getEndDate(self) -> Date: ...
    def isEncryptionRequired(self) -> bool: ...

    class Builder:
        def __init__(self, arg0: Context) -> None: ...
        def setAlias(self, arg0: str) -> "Builder": ...
        def setKeyType(self, arg0: str) -> "Builder": ...
        def setKeySize(self, arg0: int) -> "Builder": ...
        def setAlgorithmParameterSpec(self, arg0: AlgorithmParameterSpec) -> "Builder": ...
        def setSubject(self, arg0: X500Principal) -> "Builder": ...
        def setSerialNumber(self, arg0: BigInteger) -> "Builder": ...
        def setStartDate(self, arg0: Date) -> "Builder": ...
        def setEndDate(self, arg0: Date) -> "Builder": ...
        def setEncryptionRequired(self) -> "Builder": ...
        def build(self) -> "KeyPairGeneratorSpec": ...
