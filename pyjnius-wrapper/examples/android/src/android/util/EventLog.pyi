from typing import Any, ClassVar, overload

class EventLog:
    @overload
    @staticmethod
    def writeEvent(arg0: int, arg1: int) -> int: ...
    @overload
    @staticmethod
    def writeEvent(arg0: int, arg1: int) -> int: ...
    @overload
    @staticmethod
    def writeEvent(arg0: int, arg1: float) -> int: ...
    @overload
    @staticmethod
    def writeEvent(arg0: int, arg1: str) -> int: ...
    @overload
    @staticmethod
    def writeEvent(arg0: int, *arg1: Any) -> int: ...
    @staticmethod
    def readEvents(arg0: list[int], arg1: list) -> None: ...
    @staticmethod
    def getTagName(arg0: int) -> str: ...
    @staticmethod
    def getTagCode(arg0: str) -> int: ...

    class Event:
        def getProcessId(self) -> int: ...
        def getThreadId(self) -> int: ...
        def getTimeNanos(self) -> int: ...
        def getTag(self) -> int: ...
        def getData(self) -> Any: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...
