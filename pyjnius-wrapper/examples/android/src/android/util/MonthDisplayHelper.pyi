from typing import Any, ClassVar, overload

class MonthDisplayHelper:
    @overload
    def __init__(self, arg0: int, arg1: int, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int) -> None: ...
    def getYear(self) -> int: ...
    def getMonth(self) -> int: ...
    def getWeekStartDay(self) -> int: ...
    def getFirstDayOfMonth(self) -> int: ...
    def getNumberOfDaysInMonth(self) -> int: ...
    def getOffset(self) -> int: ...
    def getDigitsForRow(self, arg0: int) -> list[int]: ...
    def getDayAt(self, arg0: int, arg1: int) -> int: ...
    def getRowOf(self, arg0: int) -> int: ...
    def getColumnOf(self, arg0: int) -> int: ...
    def previousMonth(self) -> None: ...
    def nextMonth(self) -> None: ...
    def isWithinCurrentMonth(self, arg0: int, arg1: int) -> bool: ...
