    def __init__(self) -> None: ...
    def setOrientationStyle(self, arg0: int) -> None: ...
    def getOrientationStyle(self) -> int: ...
    def setSequenceType(self, arg0: int) -> None: ...
    def getSequenceType(self) -> int: ...
    def getGestureEntries(self) -> set: ...
    def recognize(self, arg0: Gesture) -> list: ...
    def addGesture(self, arg0: str, arg1: Gesture) -> None: ...
    def removeGesture(self, arg0: str, arg1: Gesture) -> None: ...
    def removeEntry(self, arg0: str) -> None: ...
    def getGestures(self, arg0: str) -> list: ...
    def hasChanged(self) -> bool: ...
    @overload
    def save(self, arg0: OutputStream) -> None: ...
    @overload
    def save(self, arg0: OutputStream, arg1: bool) -> None: ...
    @overload
    def load(self, arg0: InputStream) -> None: ...
    @overload
    def load(self, arg0: InputStream, arg1: bool) -> None: ...
