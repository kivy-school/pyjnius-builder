from typing import Any, ClassVar, overload
from android.gesture.GestureStroke import GestureStroke
from android.graphics.Bitmap import Bitmap
from android.graphics.Path import Path
from android.graphics.RectF import RectF
from android.os.Parcel import Parcel

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class Gesture:
    CREATOR: ClassVar[Creator]
    def __init__(self) -> None: ...
    def clone(self) -> Any: ...
    def getStrokes(self) -> list: ...
    def getStrokesCount(self) -> int: ...
    def addStroke(self, arg0: GestureStroke) -> None: ...
    def getLength(self) -> float: ...
    def getBoundingBox(self) -> RectF: ...
    @overload
    def toPath(self) -> Path: ...
    @overload
    def toPath(self, arg0: Path) -> Path: ...
    @overload
    def toPath(self, arg0: int, arg1: int, arg2: int, arg3: int) -> Path: ...
    @overload
    def toPath(self, arg0: Path, arg1: int, arg2: int, arg3: int, arg4: int) -> Path: ...
    def getID(self) -> int: ...
    @overload
    def toBitmap(self, arg0: int, arg1: int, arg2: int, arg3: int, arg4: int) -> Bitmap: ...
    @overload
    def toBitmap(self, arg0: int, arg1: int, arg2: int, arg3: int) -> Bitmap: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def describeContents(self) -> int: ...
