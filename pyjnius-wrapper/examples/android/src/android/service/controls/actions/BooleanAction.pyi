from typing import Any, ClassVar, overload

class BooleanAction:
    @overload
    def __init__(self, arg0: str, arg1: bool) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: bool, arg2: str) -> None: ...
    def getNewState(self) -> bool: ...
    def getActionType(self) -> int: ...
