from typing import Any, ClassVar, overload
from android.content.Intent import Intent
from android.net.Uri import Uri
from android.os.IBinder import IBinder
from android.service.carrier.MessagePdu import MessagePdu

class CarrierMessagingService:
    DOWNLOAD_STATUS_ERROR: ClassVar[int]
    DOWNLOAD_STATUS_OK: ClassVar[int]
    DOWNLOAD_STATUS_RETRY_ON_CARRIER_NETWORK: ClassVar[int]
    RECEIVE_OPTIONS_DEFAULT: ClassVar[int]
    RECEIVE_OPTIONS_DROP: ClassVar[int]
    RECEIVE_OPTIONS_SKIP_NOTIFY_WHEN_CREDENTIAL_PROTECTED_STORAGE_UNAVAILABLE: ClassVar[int]
    SEND_FLAG_REQUEST_DELIVERY_STATUS: ClassVar[int]
    SEND_STATUS_ERROR: ClassVar[int]
    SEND_STATUS_OK: ClassVar[int]
    SEND_STATUS_RETRY_ON_CARRIER_NETWORK: ClassVar[int]
    SERVICE_INTERFACE: ClassVar[str]
    def __init__(self) -> None: ...
    def onFilterSms(self, arg0: MessagePdu, arg1: str, arg2: int, arg3: int, arg4: "ResultCallback") -> None: ...
    def onReceiveTextSms(self, arg0: MessagePdu, arg1: str, arg2: int, arg3: int, arg4: "ResultCallback") -> None: ...
    @overload
    def onSendTextSms(self, arg0: str, arg1: int, arg2: str, arg3: "ResultCallback") -> None: ...
    @overload
    def onSendTextSms(self, arg0: str, arg1: int, arg2: str, arg3: int, arg4: "ResultCallback") -> None: ...
    @overload
    def onSendDataSms(self, arg0: list[int], arg1: int, arg2: str, arg3: int, arg4: "ResultCallback") -> None: ...
    @overload
    def onSendDataSms(self, arg0: list[int], arg1: int, arg2: str, arg3: int, arg4: int, arg5: "ResultCallback") -> None: ...
    @overload
    def onSendMultipartTextSms(self, arg0: list, arg1: int, arg2: str, arg3: "ResultCallback") -> None: ...
    @overload
    def onSendMultipartTextSms(self, arg0: list, arg1: int, arg2: str, arg3: int, arg4: "ResultCallback") -> None: ...
    def onSendMms(self, arg0: Uri, arg1: int, arg2: Uri, arg3: "ResultCallback") -> None: ...
    def onDownloadMms(self, arg0: Uri, arg1: int, arg2: Uri, arg3: "ResultCallback") -> None: ...
    def onBind(self, arg0: Intent) -> IBinder: ...

    class ResultCallback:
        def onReceiveResult(self, arg0: Any) -> None: ...

    class SendMmsResult:
        def __init__(self, arg0: int, arg1: list[int]) -> None: ...
        def getSendStatus(self) -> int: ...
        def getSendConfPdu(self) -> list[int]: ...

    class SendMultipartSmsResult:
        def __init__(self, arg0: int, arg1: list[int]) -> None: ...
        def getMessageRefs(self) -> list[int]: ...
        def getSendStatus(self) -> int: ...

    class SendSmsResult:
        def __init__(self, arg0: int, arg1: int) -> None: ...
        def getMessageRef(self) -> int: ...
        def getSendStatus(self) -> int: ...
