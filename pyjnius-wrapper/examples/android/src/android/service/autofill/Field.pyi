from typing import Any, ClassVar, overload
from android.service.autofill.Presentations import Presentations
from android.view.autofill.AutofillValue import AutofillValue
from java.util.regex.Pattern import Pattern

class Field:
    def getValue(self) -> AutofillValue: ...
    def getFilter(self) -> Pattern: ...
    def getPresentations(self) -> Presentations: ...

    class Builder:
        def __init__(self) -> None: ...
        def setValue(self, arg0: AutofillValue) -> "Builder": ...
        def setFilter(self, arg0: Pattern) -> "Builder": ...
        def setPresentations(self, arg0: Presentations) -> "Builder": ...
        def build(self) -> "Field": ...
