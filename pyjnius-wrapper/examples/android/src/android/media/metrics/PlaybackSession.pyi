from typing import Any, ClassVar, overload
from android.media.metrics.LogSessionId import LogSessionId
from android.media.metrics.NetworkEvent import NetworkEvent
from android.media.metrics.PlaybackErrorEvent import PlaybackErrorEvent
from android.media.metrics.PlaybackMetrics import PlaybackMetrics
from android.media.metrics.PlaybackStateEvent import PlaybackStateEvent
from android.media.metrics.TrackChangeEvent import TrackChangeEvent

class PlaybackSession:
    def reportPlaybackMetrics(self, arg0: PlaybackMetrics) -> None: ...
    def reportPlaybackErrorEvent(self, arg0: PlaybackErrorEvent) -> None: ...
    def reportNetworkEvent(self, arg0: NetworkEvent) -> None: ...
    def reportPlaybackStateEvent(self, arg0: PlaybackStateEvent) -> None: ...
    def reportTrackChangeEvent(self, arg0: TrackChangeEvent) -> None: ...
    def getSessionId(self) -> LogSessionId: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def close(self) -> None: ...
