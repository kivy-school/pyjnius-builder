from typing import Any, ClassVar, overload

class MediaActionSound:
    FOCUS_COMPLETE: ClassVar[int]
    SHUTTER_CLICK: ClassVar[int]
    START_VIDEO_RECORDING: ClassVar[int]
    STOP_VIDEO_RECORDING: ClassVar[int]
    def __init__(self) -> None: ...
    @staticmethod
    def mustPlayShutterSound() -> bool: ...
    def load(self, arg0: int) -> None: ...
    def play(self, arg0: int) -> None: ...
    def release(self) -> None: ...
