from typing import Any, ClassVar, overload

class EncoderProfiles:
    def getDefaultDurationSeconds(self) -> int: ...
    def getRecommendedFileFormat(self) -> int: ...
    def getAudioProfiles(self) -> list: ...
    def getVideoProfiles(self) -> list: ...

    class AudioProfile:
        def getCodec(self) -> int: ...
        def getMediaType(self) -> str: ...
        def getBitrate(self) -> int: ...
        def getSampleRate(self) -> int: ...
        def getChannels(self) -> int: ...
        def getProfile(self) -> int: ...

    class VideoProfile:
        HDR_DOLBY_VISION: ClassVar[int]
        HDR_HDR10: ClassVar[int]
        HDR_HDR10PLUS: ClassVar[int]
        HDR_HLG: ClassVar[int]
        HDR_NONE: ClassVar[int]
        YUV_420: ClassVar[int]
        YUV_422: ClassVar[int]
        YUV_444: ClassVar[int]
        def getCodec(self) -> int: ...
        def getMediaType(self) -> str: ...
        def getBitrate(self) -> int: ...
        def getFrameRate(self) -> int: ...
        def getWidth(self) -> int: ...
        def getHeight(self) -> int: ...
        def getProfile(self) -> int: ...
        def getBitDepth(self) -> int: ...
        def getChromaSubsampling(self) -> int: ...
        def getHdrFormat(self) -> int: ...
