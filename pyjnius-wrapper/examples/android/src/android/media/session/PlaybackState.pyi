    ACTION_REWIND: ClassVar[int]
    ACTION_SEEK_TO: ClassVar[int]
    ACTION_SET_PLAYBACK_SPEED: ClassVar[int]
    ACTION_SET_RATING: ClassVar[int]
    ACTION_SKIP_TO_NEXT: ClassVar[int]
    ACTION_SKIP_TO_PREVIOUS: ClassVar[int]
    ACTION_SKIP_TO_QUEUE_ITEM: ClassVar[int]
    ACTION_STOP: ClassVar[int]
    CREATOR: ClassVar[Creator]
    PLAYBACK_POSITION_UNKNOWN: ClassVar[int]
    STATE_BUFFERING: ClassVar[int]
    STATE_CONNECTING: ClassVar[int]
    STATE_ERROR: ClassVar[int]
    STATE_FAST_FORWARDING: ClassVar[int]
    STATE_NONE: ClassVar[int]
    STATE_PAUSED: ClassVar[int]
    STATE_PLAYING: ClassVar[int]
    STATE_REWINDING: ClassVar[int]
    STATE_SKIPPING_TO_NEXT: ClassVar[int]
    STATE_SKIPPING_TO_PREVIOUS: ClassVar[int]
    STATE_SKIPPING_TO_QUEUE_ITEM: ClassVar[int]
    STATE_STOPPED: ClassVar[int]
    def toString(self) -> str: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def getState(self) -> int: ...
    def getPosition(self) -> int: ...
    def getBufferedPosition(self) -> int: ...
    def getPlaybackSpeed(self) -> float: ...
    def getActions(self) -> int: ...
    def getCustomActions(self) -> list: ...
    def getErrorMessage(self) -> str: ...
    def getLastPositionUpdateTime(self) -> int: ...
    def getActiveQueueItemId(self) -> int: ...
    def getExtras(self) -> Bundle: ...
    def isActive(self) -> bool: ...

    class Builder:
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, arg0: "PlaybackState") -> None: ...
        @overload
        def setState(self, arg0: int, arg1: int, arg2: float, arg3: int) -> "Builder": ...
        @overload
        def setState(self, arg0: int, arg1: int, arg2: float) -> "Builder": ...
        def setActions(self, arg0: int) -> "Builder": ...
        @overload
        def addCustomAction(self, arg0: str, arg1: str, arg2: int) -> "Builder": ...
        @overload
        def addCustomAction(self, arg0: "CustomAction") -> "Builder": ...
        def setBufferedPosition(self, arg0: int) -> "Builder": ...
        def setActiveQueueItemId(self, arg0: int) -> "Builder": ...
        def setErrorMessage(self, arg0: str) -> "Builder": ...
        def setExtras(self, arg0: Bundle) -> "Builder": ...
        def build(self) -> "PlaybackState": ...

    class CustomAction:
        CREATOR: ClassVar[Creator]
        def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
        def describeContents(self) -> int: ...
        def getAction(self) -> str: ...
