    def getVersion(self) -> int: ...
    def getSize(self) -> int: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...

    class Builder:
        def __init__(self, arg0: int, arg1: int, arg2: int, arg3: int, arg4: int) -> None: ...
        def setTableUri(self, arg0: Uri) -> "Builder": ...
        def setTableByteArray(self, arg0: list[int]) -> "Builder": ...
        def setTableSharedMemory(self, arg0: SharedMemory) -> "Builder": ...
        def build(self) -> "TableResponse": ...
