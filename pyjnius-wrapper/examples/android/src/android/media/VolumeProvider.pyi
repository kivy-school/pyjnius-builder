from typing import Any, ClassVar, overload

class VolumeProvider:
    VOLUME_CONTROL_ABSOLUTE: ClassVar[int]
    VOLUME_CONTROL_FIXED: ClassVar[int]
    VOLUME_CONTROL_RELATIVE: ClassVar[int]
    @overload
    def __init__(self, arg0: int, arg1: int, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: int, arg2: int, arg3: str) -> None: ...
    def getVolumeControl(self) -> int: ...
    def getMaxVolume(self) -> int: ...
    def getCurrentVolume(self) -> int: ...
    def setCurrentVolume(self, arg0: int) -> None: ...
    def getVolumeControlId(self) -> str: ...
    def onSetVolumeTo(self, arg0: int) -> None: ...
    def onAdjustVolume(self, arg0: int) -> None: ...
