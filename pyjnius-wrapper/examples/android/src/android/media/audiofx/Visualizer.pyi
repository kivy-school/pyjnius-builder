from typing import Any, ClassVar, overload

class Visualizer:
    ALREADY_EXISTS: ClassVar[int]
    ERROR: ClassVar[int]
    ERROR_BAD_VALUE: ClassVar[int]
    ERROR_DEAD_OBJECT: ClassVar[int]
    ERROR_INVALID_OPERATION: ClassVar[int]
    ERROR_NO_INIT: ClassVar[int]
    ERROR_NO_MEMORY: ClassVar[int]
    MEASUREMENT_MODE_NONE: ClassVar[int]
    MEASUREMENT_MODE_PEAK_RMS: ClassVar[int]
    SCALING_MODE_AS_PLAYED: ClassVar[int]
    SCALING_MODE_NORMALIZED: ClassVar[int]
    STATE_ENABLED: ClassVar[int]
    STATE_INITIALIZED: ClassVar[int]
    STATE_UNINITIALIZED: ClassVar[int]
    SUCCESS: ClassVar[int]
    def __init__(self, arg0: int) -> None: ...
    def release(self) -> None: ...
    def finalize(self) -> None: ...
    def setEnabled(self, arg0: bool) -> int: ...
    def getEnabled(self) -> bool: ...
    @staticmethod
    def getCaptureSizeRange() -> list[int]: ...
    @staticmethod
    def getMaxCaptureRate() -> int: ...
    def setCaptureSize(self, arg0: int) -> int: ...
    def getCaptureSize(self) -> int: ...
    def setScalingMode(self, arg0: int) -> int: ...
    def getScalingMode(self) -> int: ...
    def setMeasurementMode(self, arg0: int) -> int: ...
    def getMeasurementMode(self) -> int: ...
    def getSamplingRate(self) -> int: ...
    def getWaveForm(self, arg0: list[int]) -> int: ...
    def getFft(self, arg0: list[int]) -> int: ...
    def getMeasurementPeakRms(self, arg0: "MeasurementPeakRms") -> int: ...
    def setDataCaptureListener(self, arg0: "OnDataCaptureListener", arg1: int, arg2: bool, arg3: bool) -> int: ...

    class MeasurementPeakRms:
        mPeak: int
        mRms: int
        def __init__(self) -> None: ...

    class OnDataCaptureListener:
        def onWaveFormDataCapture(self, arg0: "Visualizer", arg1: list[int], arg2: int) -> None: ...
        def onFftDataCapture(self, arg0: "Visualizer", arg1: list[int], arg2: int) -> None: ...
