from typing import Any, ClassVar, overload

class Virtualizer:
    PARAM_STRENGTH: ClassVar[int]
    PARAM_STRENGTH_SUPPORTED: ClassVar[int]
    VIRTUALIZATION_MODE_AUTO: ClassVar[int]
    VIRTUALIZATION_MODE_BINAURAL: ClassVar[int]
    VIRTUALIZATION_MODE_OFF: ClassVar[int]
    VIRTUALIZATION_MODE_TRANSAURAL: ClassVar[int]
    def __init__(self, arg0: int, arg1: int) -> None: ...
    def getStrengthSupported(self) -> bool: ...
    def setStrength(self, arg0: int) -> None: ...
    def getRoundedStrength(self) -> int: ...
    def canVirtualize(self, arg0: int, arg1: int) -> bool: ...
    def getSpeakerAngles(self, arg0: int, arg1: int, arg2: list[int]) -> bool: ...
    def forceVirtualizationMode(self, arg0: int) -> bool: ...
    def getVirtualizationMode(self) -> int: ...
    def setParameterListener(self, arg0: "OnParameterChangeListener") -> None: ...
    def getProperties(self) -> "Settings": ...
    def setProperties(self, arg0: "Settings") -> None: ...

    class OnParameterChangeListener:
        def onParameterChange(self, arg0: "Virtualizer", arg1: int, arg2: int, arg3: int) -> None: ...

    class Settings:
        strength: int
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, arg0: str) -> None: ...
        def toString(self) -> str: ...
