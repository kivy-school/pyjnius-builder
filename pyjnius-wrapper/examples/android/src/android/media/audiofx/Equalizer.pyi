from typing import Any, ClassVar, overload

class Equalizer:
    PARAM_BAND_FREQ_RANGE: ClassVar[int]
    PARAM_BAND_LEVEL: ClassVar[int]
    PARAM_CENTER_FREQ: ClassVar[int]
    PARAM_CURRENT_PRESET: ClassVar[int]
    PARAM_GET_BAND: ClassVar[int]
    PARAM_GET_NUM_OF_PRESETS: ClassVar[int]
    PARAM_GET_PRESET_NAME: ClassVar[int]
    PARAM_LEVEL_RANGE: ClassVar[int]
    PARAM_NUM_BANDS: ClassVar[int]
    PARAM_STRING_SIZE_MAX: ClassVar[int]
    def __init__(self, arg0: int, arg1: int) -> None: ...
    def getNumberOfBands(self) -> int: ...
    def getBandLevelRange(self) -> list[int]: ...
    def setBandLevel(self, arg0: int, arg1: int) -> None: ...
    def getBandLevel(self, arg0: int) -> int: ...
    def getCenterFreq(self, arg0: int) -> int: ...
    def getBandFreqRange(self, arg0: int) -> list[int]: ...
    def getBand(self, arg0: int) -> int: ...
    def getCurrentPreset(self) -> int: ...
    def usePreset(self, arg0: int) -> None: ...
    def getNumberOfPresets(self) -> int: ...
    def getPresetName(self, arg0: int) -> str: ...
    def setParameterListener(self, arg0: "OnParameterChangeListener") -> None: ...
    def getProperties(self) -> "Settings": ...
    def setProperties(self, arg0: "Settings") -> None: ...

    class OnParameterChangeListener:
        def onParameterChange(self, arg0: "Equalizer", arg1: int, arg2: int, arg3: int, arg4: int) -> None: ...

    class Settings:
        bandLevels: list[int]
        curPreset: int
        numBands: int
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, arg0: str) -> None: ...
        def toString(self) -> str: ...
