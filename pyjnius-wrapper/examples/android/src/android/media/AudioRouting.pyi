from typing import Any, ClassVar, overload
from android.media.AudioDeviceInfo import AudioDeviceInfo
from android.os.Handler import Handler

class AudioRouting:
    def setPreferredDevice(self, arg0: AudioDeviceInfo) -> bool: ...
    def getPreferredDevice(self) -> AudioDeviceInfo: ...
    def getRoutedDevice(self) -> AudioDeviceInfo: ...
    def addOnRoutingChangedListener(self, arg0: "OnRoutingChangedListener", arg1: Handler) -> None: ...
    def removeOnRoutingChangedListener(self, arg0: "OnRoutingChangedListener") -> None: ...

    class OnRoutingChangedListener:
        def onRoutingChanged(self, arg0: "AudioRouting") -> None: ...
