from typing import Any, ClassVar, overload
from android.media.midi.MidiDeviceInfo import MidiDeviceInfo
from android.media.midi.MidiInputPort import MidiInputPort
from android.media.midi.MidiOutputPort import MidiOutputPort

class MidiDevice:
    def getInfo(self) -> MidiDeviceInfo: ...
    def openInputPort(self, arg0: int) -> MidiInputPort: ...
    def openOutputPort(self, arg0: int) -> MidiOutputPort: ...
    def connectPorts(self, arg0: MidiInputPort, arg1: int) -> "MidiConnection": ...
    def close(self) -> None: ...
    def finalize(self) -> None: ...
    def toString(self) -> str: ...

    class MidiConnection:
        def close(self) -> None: ...
        def finalize(self) -> None: ...
