from typing import Any, ClassVar, overload

class MidiReceiver:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: int) -> None: ...
    def onSend(self, arg0: list[int], arg1: int, arg2: int, arg3: int) -> None: ...
    def flush(self) -> None: ...
    def onFlush(self) -> None: ...
    def getMaxMessageSize(self) -> int: ...
    @overload
    def send(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    @overload
    def send(self, arg0: list[int], arg1: int, arg2: int, arg3: int) -> None: ...
