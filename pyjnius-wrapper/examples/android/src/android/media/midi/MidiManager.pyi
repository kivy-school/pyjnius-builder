from typing import Any, ClassVar, overload
from android.bluetooth.BluetoothDevice import BluetoothDevice
from android.media.midi.MidiDevice import MidiDevice
from android.media.midi.MidiDeviceInfo import MidiDeviceInfo
from android.media.midi.MidiDeviceStatus import MidiDeviceStatus
from android.os.Handler import Handler
from java.util.concurrent.Executor import Executor

class MidiManager:
    TRANSPORT_MIDI_BYTE_STREAM: ClassVar[int]
    TRANSPORT_UNIVERSAL_MIDI_PACKETS: ClassVar[int]
    @overload
    def registerDeviceCallback(self, arg0: "DeviceCallback", arg1: Handler) -> None: ...
    @overload
    def registerDeviceCallback(self, arg0: int, arg1: Executor, arg2: "DeviceCallback") -> None: ...
    def unregisterDeviceCallback(self, arg0: "DeviceCallback") -> None: ...
    def getDevices(self) -> list[MidiDeviceInfo]: ...
    def getDevicesForTransport(self, arg0: int) -> set: ...
    def openDevice(self, arg0: MidiDeviceInfo, arg1: "OnDeviceOpenedListener", arg2: Handler) -> None: ...
    def openBluetoothDevice(self, arg0: BluetoothDevice, arg1: "OnDeviceOpenedListener", arg2: Handler) -> None: ...

    class DeviceCallback:
        def __init__(self) -> None: ...
        def onDeviceAdded(self, arg0: MidiDeviceInfo) -> None: ...
        def onDeviceRemoved(self, arg0: MidiDeviceInfo) -> None: ...
        def onDeviceStatusChanged(self, arg0: MidiDeviceStatus) -> None: ...

    class OnDeviceOpenedListener:
        def onDeviceOpened(self, arg0: MidiDevice) -> None: ...
