from typing import Any, ClassVar, overload
from android.graphics.Bitmap import Bitmap
from android.graphics.PointF import PointF

class FaceDetector:
    def __init__(self, arg0: int, arg1: int, arg2: int) -> None: ...
    def findFaces(self, arg0: Bitmap, arg1: list["Face"]) -> int: ...
    def finalize(self) -> None: ...

    class Face:
        CONFIDENCE_THRESHOLD: ClassVar[float]
        EULER_X: ClassVar[int]
        EULER_Y: ClassVar[int]
        EULER_Z: ClassVar[int]
        def confidence(self) -> float: ...
        def getMidPoint(self, arg0: PointF) -> None: ...
        def eyesDistance(self) -> float: ...
        def pose(self, arg0: int) -> float: ...
