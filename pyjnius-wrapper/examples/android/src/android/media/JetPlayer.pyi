from typing import Any, ClassVar, overload
from android.content.res.AssetFileDescriptor import AssetFileDescriptor
from android.os.Handler import Handler

class JetPlayer:
    @staticmethod
    def getJetPlayer() -> "JetPlayer": ...
    def clone(self) -> Any: ...
    def finalize(self) -> None: ...
    def release(self) -> None: ...
    @staticmethod
    def getMaxTracks() -> int: ...
    @overload
    def loadJetFile(self, arg0: str) -> bool: ...
    @overload
    def loadJetFile(self, arg0: AssetFileDescriptor) -> bool: ...
    def closeJetFile(self) -> bool: ...
    def play(self) -> bool: ...
    def pause(self) -> bool: ...
    def queueJetSegment(self, arg0: int, arg1: int, arg2: int, arg3: int, arg4: int, arg5: int) -> bool: ...
    def queueJetSegmentMuteArray(self, arg0: int, arg1: int, arg2: int, arg3: int, arg4: list[bool], arg5: int) -> bool: ...
    def setMuteFlags(self, arg0: int, arg1: bool) -> bool: ...
    def setMuteArray(self, arg0: list[bool], arg1: bool) -> bool: ...
    def setMuteFlag(self, arg0: int, arg1: bool, arg2: bool) -> bool: ...
    def triggerClip(self, arg0: int) -> bool: ...
    def clearQueue(self) -> bool: ...
    @overload
    def setEventListener(self, arg0: "OnJetEventListener") -> None: ...
    @overload
    def setEventListener(self, arg0: "OnJetEventListener", arg1: Handler) -> None: ...

    class OnJetEventListener:
        def onJetEvent(self, arg0: "JetPlayer", arg1: int, arg2: int, arg3: int, arg4: int, arg5: int) -> None: ...
        def onJetUserIdUpdate(self, arg0: "JetPlayer", arg1: int, arg2: int) -> None: ...
        def onJetNumQueuedSegmentUpdate(self, arg0: "JetPlayer", arg1: int) -> None: ...
        def onJetPauseUpdate(self, arg0: "JetPlayer", arg1: int) -> None: ...
