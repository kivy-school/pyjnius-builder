from typing import Any, ClassVar, overload
from android.app.PendingIntent import PendingIntent
from android.graphics.Bitmap import Bitmap
from android.media.session.MediaSession import MediaSession
from android.os.Looper import Looper

class RemoteControlClient:
    FLAG_KEY_MEDIA_FAST_FORWARD: ClassVar[int]
    FLAG_KEY_MEDIA_NEXT: ClassVar[int]
    FLAG_KEY_MEDIA_PAUSE: ClassVar[int]
    FLAG_KEY_MEDIA_PLAY: ClassVar[int]
    FLAG_KEY_MEDIA_PLAY_PAUSE: ClassVar[int]
    FLAG_KEY_MEDIA_POSITION_UPDATE: ClassVar[int]
    FLAG_KEY_MEDIA_PREVIOUS: ClassVar[int]
    FLAG_KEY_MEDIA_RATING: ClassVar[int]
    FLAG_KEY_MEDIA_REWIND: ClassVar[int]
    FLAG_KEY_MEDIA_STOP: ClassVar[int]
    PLAYSTATE_BUFFERING: ClassVar[int]
    PLAYSTATE_ERROR: ClassVar[int]
    PLAYSTATE_FAST_FORWARDING: ClassVar[int]
    PLAYSTATE_PAUSED: ClassVar[int]
    PLAYSTATE_PLAYING: ClassVar[int]
    PLAYSTATE_REWINDING: ClassVar[int]
    PLAYSTATE_SKIPPING_BACKWARDS: ClassVar[int]
    PLAYSTATE_SKIPPING_FORWARDS: ClassVar[int]
    PLAYSTATE_STOPPED: ClassVar[int]
    @overload
    def __init__(self, arg0: PendingIntent) -> None: ...
    @overload
    def __init__(self, arg0: PendingIntent, arg1: Looper) -> None: ...
    def getMediaSession(self) -> MediaSession: ...
    def editMetadata(self, arg0: bool) -> "MetadataEditor": ...
    @overload
    def setPlaybackState(self, arg0: int) -> None: ...
    @overload
    def setPlaybackState(self, arg0: int, arg1: int, arg2: float) -> None: ...
    def setTransportControlFlags(self, arg0: int) -> None: ...
    def setMetadataUpdateListener(self, arg0: "OnMetadataUpdateListener") -> None: ...
    def setPlaybackPositionUpdateListener(self, arg0: "OnPlaybackPositionUpdateListener") -> None: ...
    def setOnGetPlaybackPositionListener(self, arg0: "OnGetPlaybackPositionListener") -> None: ...

    class MetadataEditor:
        BITMAP_KEY_ARTWORK: ClassVar[int]
        def clone(self) -> Any: ...
        def putString(self, arg0: int, arg1: str) -> "MetadataEditor": ...
        def putLong(self, arg0: int, arg1: int) -> "MetadataEditor": ...
        def putBitmap(self, arg0: int, arg1: Bitmap) -> "MetadataEditor": ...
        def putObject(self, arg0: int, arg1: Any) -> "MetadataEditor": ...
        def clear(self) -> None: ...
        def apply(self) -> None: ...

    class OnGetPlaybackPositionListener:
        def onGetPlaybackPosition(self) -> int: ...

    class OnMetadataUpdateListener:
        def onMetadataUpdate(self, arg0: int, arg1: Any) -> None: ...

    class OnPlaybackPositionUpdateListener:
        def onPlaybackPositionUpdate(self, arg0: int) -> None: ...
