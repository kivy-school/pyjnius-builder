from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.content.Intent import Intent
from android.content.SharedPreferences import SharedPreferences
from android.preference.Preference import Preference
from android.preference.PreferenceDataStore import PreferenceDataStore
from android.preference.PreferenceScreen import PreferenceScreen

class PreferenceManager:
    KEY_HAS_SET_DEFAULT_VALUES: ClassVar[str]
    METADATA_KEY_PREFERENCES: ClassVar[str]
    def setPreferenceDataStore(self, arg0: PreferenceDataStore) -> None: ...
    def getPreferenceDataStore(self) -> PreferenceDataStore: ...
    def createPreferenceScreen(self, arg0: Context) -> PreferenceScreen: ...
    def getSharedPreferencesName(self) -> str: ...
    def setSharedPreferencesName(self, arg0: str) -> None: ...
    def getSharedPreferencesMode(self) -> int: ...
    def setSharedPreferencesMode(self, arg0: int) -> None: ...
    def setStorageDefault(self) -> None: ...
    def setStorageDeviceProtected(self) -> None: ...
    def isStorageDefault(self) -> bool: ...
    def isStorageDeviceProtected(self) -> bool: ...
    def getSharedPreferences(self) -> SharedPreferences: ...
    @staticmethod
    def getDefaultSharedPreferences(arg0: Context) -> SharedPreferences: ...
    @staticmethod
    def getDefaultSharedPreferencesName(arg0: Context) -> str: ...
    def findPreference(self, arg0: str) -> Preference: ...
    @overload
    @staticmethod
    def setDefaultValues(arg0: Context, arg1: int, arg2: bool) -> None: ...
    @overload
    @staticmethod
    def setDefaultValues(arg0: Context, arg1: str, arg2: int, arg3: int, arg4: bool) -> None: ...

    class OnActivityDestroyListener:
        def onActivityDestroy(self) -> None: ...

    class OnActivityResultListener:
        def onActivityResult(self, arg0: int, arg1: int, arg2: Intent) -> bool: ...

    class OnActivityStopListener:
        def onActivityStop(self) -> None: ...
