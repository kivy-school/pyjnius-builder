from typing import Any, ClassVar, overload
from android.adservices.ondevicepersonalization.DownloadCompletedInput import DownloadCompletedInput
from android.adservices.ondevicepersonalization.EventInput import EventInput
from android.adservices.ondevicepersonalization.ExecuteInput import ExecuteInput
from android.adservices.ondevicepersonalization.RenderInput import RenderInput
from android.adservices.ondevicepersonalization.TrainingExamplesInput import TrainingExamplesInput
from android.adservices.ondevicepersonalization.WebTriggerInput import WebTriggerInput
from android.os.OutcomeReceiver import OutcomeReceiver

class IsolatedWorker:
    def onExecute(self, arg0: ExecuteInput, arg1: OutcomeReceiver) -> None: ...
    def onDownloadCompleted(self, arg0: DownloadCompletedInput, arg1: OutcomeReceiver) -> None: ...
    def onRender(self, arg0: RenderInput, arg1: OutcomeReceiver) -> None: ...
    def onEvent(self, arg0: EventInput, arg1: OutcomeReceiver) -> None: ...
    def onTrainingExamples(self, arg0: TrainingExamplesInput, arg1: OutcomeReceiver) -> None: ...
    def onWebTrigger(self, arg0: WebTriggerInput, arg1: OutcomeReceiver) -> None: ...
