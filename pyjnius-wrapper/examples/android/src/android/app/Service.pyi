from typing import Any, ClassVar, overload
from android.app.Application import Application
from android.app.Notification import Notification
from android.content.Context import Context
from android.content.Intent import Intent
from android.content.res.Configuration import Configuration
from android.os.IBinder import IBinder
from java.io.FileDescriptor import FileDescriptor
from java.io.PrintWriter import PrintWriter

class Service:
    START_CONTINUATION_MASK: ClassVar[int]
    START_FLAG_REDELIVERY: ClassVar[int]
    START_FLAG_RETRY: ClassVar[int]
    START_NOT_STICKY: ClassVar[int]
    START_REDELIVER_INTENT: ClassVar[int]
    START_STICKY: ClassVar[int]
    START_STICKY_COMPATIBILITY: ClassVar[int]
    STOP_FOREGROUND_DETACH: ClassVar[int]
    STOP_FOREGROUND_LEGACY: ClassVar[int]
    STOP_FOREGROUND_REMOVE: ClassVar[int]
    def __init__(self) -> None: ...
    def getApplication(self) -> Application: ...
    def onCreate(self) -> None: ...
    def onStart(self, arg0: Intent, arg1: int) -> None: ...
    def onStartCommand(self, arg0: Intent, arg1: int, arg2: int) -> int: ...
    def onDestroy(self) -> None: ...
    def onConfigurationChanged(self, arg0: Configuration) -> None: ...
    def onLowMemory(self) -> None: ...
    def onTrimMemory(self, arg0: int) -> None: ...
    def onBind(self, arg0: Intent) -> IBinder: ...
    def onUnbind(self, arg0: Intent) -> bool: ...
    def onRebind(self, arg0: Intent) -> None: ...
    def onTaskRemoved(self, arg0: Intent) -> None: ...
    @overload
    def stopSelf(self) -> None: ...
    @overload
    def stopSelf(self, arg0: int) -> None: ...
    def stopSelfResult(self, arg0: int) -> bool: ...
    @overload
    def startForeground(self, arg0: int, arg1: Notification) -> None: ...
    @overload
    def startForeground(self, arg0: int, arg1: Notification, arg2: int) -> None: ...
    @overload
    def stopForeground(self, arg0: bool) -> None: ...
    @overload
    def stopForeground(self, arg0: int) -> None: ...
    def getForegroundServiceType(self) -> int: ...
    def dump(self, arg0: FileDescriptor, arg1: PrintWriter, arg2: list[str]) -> None: ...
    def attachBaseContext(self, arg0: Context) -> None: ...
    @overload
    def onTimeout(self, arg0: int) -> None: ...
    @overload
    def onTimeout(self, arg0: int, arg1: int) -> None: ...
