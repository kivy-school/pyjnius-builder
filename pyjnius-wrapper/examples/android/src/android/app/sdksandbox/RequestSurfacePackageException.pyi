from typing import Any, ClassVar, overload
from android.os.Bundle import Bundle
from java.lang.Throwable import Throwable

class RequestSurfacePackageException:
    @overload
    def __init__(self, arg0: int, arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: str, arg2: Throwable) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: str, arg2: Throwable, arg3: Bundle) -> None: ...
    def getRequestSurfacePackageErrorCode(self) -> int: ...
    def getExtraErrorInformation(self) -> Bundle: ...
