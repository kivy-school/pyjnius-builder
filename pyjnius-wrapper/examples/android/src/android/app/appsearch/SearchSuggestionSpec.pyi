from typing import Any, ClassVar, overload
from android.os.Parcel import Parcel

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class SearchSuggestionSpec:
    CREATOR: ClassVar[Creator]
    SUGGESTION_RANKING_STRATEGY_DOCUMENT_COUNT: ClassVar[int]
    SUGGESTION_RANKING_STRATEGY_NONE: ClassVar[int]
    SUGGESTION_RANKING_STRATEGY_TERM_FREQUENCY: ClassVar[int]
    def getMaximumResultCount(self) -> int: ...
    def getFilterNamespaces(self) -> list: ...
    def getRankingStrategy(self) -> int: ...
    def getFilterSchemas(self) -> list: ...
    def getFilterProperties(self) -> dict: ...
    def getFilterDocumentIds(self) -> dict: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def describeContents(self) -> int: ...

    class Builder:
        def __init__(self, arg0: int) -> None: ...
        @overload
        def addFilterNamespaces(self, *arg0: str) -> "Builder": ...
        @overload
        def addFilterNamespaces(self, arg0: list) -> "Builder": ...
        def setRankingStrategy(self, arg0: int) -> "Builder": ...
        @overload
        def addFilterSchemas(self, *arg0: str) -> "Builder": ...
        @overload
        def addFilterSchemas(self, arg0: list) -> "Builder": ...
        def addFilterProperties(self, arg0: str, arg1: list) -> "Builder": ...
        def addFilterPropertyPaths(self, arg0: str, arg1: list) -> "Builder": ...
        @overload
        def addFilterDocumentIds(self, arg0: str, *arg1: str) -> "Builder": ...
        @overload
        def addFilterDocumentIds(self, arg0: str, arg1: list) -> "Builder": ...
        def build(self) -> "SearchSuggestionSpec": ...
