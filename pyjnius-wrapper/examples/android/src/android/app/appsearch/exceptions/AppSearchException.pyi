from typing import Any, ClassVar, overload
from android.app.appsearch.AppSearchResult import AppSearchResult
from java.lang.Throwable import Throwable

class AppSearchException:
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: str, arg2: Throwable) -> None: ...
    def getResultCode(self) -> int: ...
    def toAppSearchResult(self) -> AppSearchResult: ...
