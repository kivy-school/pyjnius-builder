from typing import Any, ClassVar, overload
from android.app.Activity import Activity
from android.content.Context import Context
from android.os.Bundle import Bundle
from android.os.Parcel import Parcel
from java.lang.Runnable import Runnable
from java.util.concurrent.Executor import Executor

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class VoiceInteractor:
    @overload
    def submitRequest(self, arg0: "Request") -> bool: ...
    @overload
    def submitRequest(self, arg0: "Request", arg1: str) -> bool: ...
    def getActiveRequests(self) -> list["Request"]: ...
    def getActiveRequest(self, arg0: str) -> "Request": ...
    def supportsCommands(self, arg0: list[str]) -> list[bool]: ...
    def isDestroyed(self) -> bool: ...
    def registerOnDestroyedCallback(self, arg0: Executor, arg1: Runnable) -> bool: ...
    def unregisterOnDestroyedCallback(self, arg0: Runnable) -> bool: ...
    def notifyDirectActionsChanged(self) -> None: ...
    def getPackageName(self) -> str: ...

    class AbortVoiceRequest:
        def __init__(self, arg0: "Prompt", arg1: Bundle) -> None: ...
        def onAbortResult(self, arg0: Bundle) -> None: ...

    class CommandRequest:
        def __init__(self, arg0: str, arg1: Bundle) -> None: ...
        def onCommandResult(self, arg0: bool, arg1: Bundle) -> None: ...

    class CompleteVoiceRequest:
        def __init__(self, arg0: "Prompt", arg1: Bundle) -> None: ...
        def onCompleteResult(self, arg0: Bundle) -> None: ...

    class ConfirmationRequest:
        def __init__(self, arg0: "Prompt", arg1: Bundle) -> None: ...
        def onConfirmationResult(self, arg0: bool, arg1: Bundle) -> None: ...

    class PickOptionRequest:
        def __init__(self, arg0: "Prompt", arg1: list["Option"], arg2: Bundle) -> None: ...
        def onPickOptionResult(self, arg0: bool, arg1: list["Option"], arg2: Bundle) -> None: ...

        class Option:
            CREATOR: ClassVar[Creator]
            def __init__(self, arg0: str, arg1: int) -> None: ...
            def addSynonym(self, arg0: str) -> "Option": ...
            def getLabel(self) -> str: ...
            def getIndex(self) -> int: ...
            def countSynonyms(self) -> int: ...
            def getSynonymAt(self, arg0: int) -> str: ...
            def setExtras(self, arg0: Bundle) -> None: ...
            def getExtras(self) -> Bundle: ...
            def describeContents(self) -> int: ...
            def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...

    class Prompt:
        CREATOR: ClassVar[Creator]
        @overload
        def __init__(self, arg0: list[str], arg1: str) -> None: ...
        @overload
        def __init__(self, arg0: str) -> None: ...
        def getVoicePromptAt(self, arg0: int) -> str: ...
        def countVoicePrompts(self) -> int: ...
        def getVisualPrompt(self) -> str: ...
        def toString(self) -> str: ...
        def describeContents(self) -> int: ...
        def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...

    class Request:
        def getName(self) -> str: ...
        def cancel(self) -> None: ...
        def getContext(self) -> Context: ...
        def getActivity(self) -> Activity: ...
        def onCancel(self) -> None: ...
        def onAttached(self, arg0: Activity) -> None: ...
        def onDetached(self) -> None: ...
        def toString(self) -> str: ...
