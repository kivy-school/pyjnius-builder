from typing import Any, ClassVar, overload
from android.graphics.drawable.Drawable import Drawable
from android.graphics.drawable.Icon import Icon
from java.util.function.Supplier import Supplier

class DevicePolicyResourcesManager:
    @overload
    def getDrawable(self, arg0: str, arg1: str, arg2: Supplier) -> Drawable: ...
    @overload
    def getDrawable(self, arg0: str, arg1: str, arg2: str, arg3: Supplier) -> Drawable: ...
    @overload
    def getDrawableForDensity(self, arg0: str, arg1: str, arg2: int, arg3: Supplier) -> Drawable: ...
    @overload
    def getDrawableForDensity(self, arg0: str, arg1: str, arg2: str, arg3: int, arg4: Supplier) -> Drawable: ...
    @overload
    def getDrawableAsIcon(self, arg0: str, arg1: str, arg2: str, arg3: Icon) -> Icon: ...
    @overload
    def getDrawableAsIcon(self, arg0: str, arg1: str, arg2: Icon) -> Icon: ...
    @overload
    def getString(self, arg0: str, arg1: Supplier) -> str: ...
    @overload
    def getString(self, arg0: str, arg1: Supplier, *arg2: Any) -> str: ...
