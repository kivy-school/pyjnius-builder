    def createWindowedInstallPolicy(arg0: int, arg1: int) -> "SystemUpdatePolicy": ...
    @staticmethod
    def createPostponeInstallPolicy() -> "SystemUpdatePolicy": ...
    def getPolicyType(self) -> int: ...
    def getInstallWindowStart(self) -> int: ...
    def getInstallWindowEnd(self) -> int: ...
    def setFreezePeriods(self, arg0: list) -> "SystemUpdatePolicy": ...
    def getFreezePeriods(self) -> list: ...
    def toString(self) -> str: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...

    class ValidationFailedException:
        CREATOR: ClassVar[Creator]
        ERROR_COMBINED_FREEZE_PERIOD_TOO_CLOSE: ClassVar[int]
        ERROR_COMBINED_FREEZE_PERIOD_TOO_LONG: ClassVar[int]
        ERROR_DUPLICATE_OR_OVERLAP: ClassVar[int]
        ERROR_NEW_FREEZE_PERIOD_TOO_CLOSE: ClassVar[int]
        ERROR_NEW_FREEZE_PERIOD_TOO_LONG: ClassVar[int]
        ERROR_UNKNOWN: ClassVar[int]
        def getErrorCode(self) -> int: ...
        def describeContents(self) -> int: ...
        def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
