from typing import Any, ClassVar, overload
from android.app.LocaleConfig import LocaleConfig
from android.os.LocaleList import LocaleList

class LocaleManager:
    def setApplicationLocales(self, arg0: LocaleList) -> None: ...
    @overload
    def getApplicationLocales(self) -> LocaleList: ...
    @overload
    def getApplicationLocales(self, arg0: str) -> LocaleList: ...
    def getSystemLocales(self) -> LocaleList: ...
    def setOverrideLocaleConfig(self, arg0: LocaleConfig) -> None: ...
    def getOverrideLocaleConfig(self) -> LocaleConfig: ...
