from typing import Any, ClassVar, overload
from android.app.backup.BackupDataInput import BackupDataInput
from android.app.backup.BackupDataOutput import BackupDataOutput
from android.app.backup.FullBackupDataOutput import FullBackupDataOutput
from android.os.ParcelFileDescriptor import ParcelFileDescriptor
from java.io.File import File

class BackupAgent:
    FLAG_CLIENT_SIDE_ENCRYPTION_ENABLED: ClassVar[int]
    FLAG_DEVICE_TO_DEVICE_TRANSFER: ClassVar[int]
    TYPE_DIRECTORY: ClassVar[int]
    TYPE_FILE: ClassVar[int]
    def __init__(self) -> None: ...
    def onCreate(self) -> None: ...
    def onDestroy(self) -> None: ...
    def onBackup(self, arg0: ParcelFileDescriptor, arg1: BackupDataOutput, arg2: ParcelFileDescriptor) -> None: ...
    @overload
    def onRestore(self, arg0: BackupDataInput, arg1: int, arg2: ParcelFileDescriptor) -> None: ...
    @overload
    def onRestore(self, arg0: BackupDataInput, arg1: int, arg2: ParcelFileDescriptor) -> None: ...
    def onFullBackup(self, arg0: FullBackupDataOutput) -> None: ...
    def onQuotaExceeded(self, arg0: int, arg1: int) -> None: ...
    def fullBackupFile(self, arg0: File, arg1: FullBackupDataOutput) -> None: ...
    def onRestoreFile(self, arg0: ParcelFileDescriptor, arg1: int, arg2: File, arg3: int, arg4: int, arg5: int) -> None: ...
    def onRestoreFinished(self) -> None: ...
