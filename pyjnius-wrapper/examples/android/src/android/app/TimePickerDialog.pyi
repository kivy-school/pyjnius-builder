from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.content.DialogInterface import DialogInterface
from android.os.Bundle import Bundle
from android.widget.TimePicker import TimePicker

class TimePickerDialog:
    @overload
    def __init__(self, arg0: Context, arg1: "OnTimeSetListener", arg2: int, arg3: int, arg4: bool) -> None: ...
    @overload
    def __init__(self, arg0: Context, arg1: int, arg2: "OnTimeSetListener", arg3: int, arg4: int, arg5: bool) -> None: ...
    def onTimeChanged(self, arg0: TimePicker, arg1: int, arg2: int) -> None: ...
    def show(self) -> None: ...
    def onClick(self, arg0: DialogInterface, arg1: int) -> None: ...
    def updateTime(self, arg0: int, arg1: int) -> None: ...
    def onSaveInstanceState(self) -> Bundle: ...
    def onRestoreInstanceState(self, arg0: Bundle) -> None: ...

    class OnTimeSetListener:
        def onTimeSet(self, arg0: TimePicker, arg1: int, arg2: int) -> None: ...
