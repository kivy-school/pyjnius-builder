from typing import Any, ClassVar, overload
from android.app.Activity import Activity
from android.content.Intent import Intent
from android.os.Bundle import Bundle
from android.view.Window import Window

class LocalActivityManager:
    def __init__(self, arg0: Activity, arg1: bool) -> None: ...
    def startActivity(self, arg0: str, arg1: Intent) -> Window: ...
    def destroyActivity(self, arg0: str, arg1: bool) -> Window: ...
    def getCurrentActivity(self) -> Activity: ...
    def getCurrentId(self) -> str: ...
    def getActivity(self, arg0: str) -> Activity: ...
    def dispatchCreate(self, arg0: Bundle) -> None: ...
    def saveInstanceState(self) -> Bundle: ...
    def dispatchResume(self) -> None: ...
    def dispatchPause(self, arg0: bool) -> None: ...
    def dispatchStop(self) -> None: ...
    def removeAllActivities(self) -> None: ...
    def dispatchDestroy(self, arg0: bool) -> None: ...
