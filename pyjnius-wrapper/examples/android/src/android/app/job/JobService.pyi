    def updateTransferredNetworkBytes(self, arg0: JobParameters, arg1: JobWorkItem, arg2: int, arg3: int) -> None: ...
    def setNotification(self, arg0: JobParameters, arg1: int, arg2: Notification, arg3: int) -> None: ...
