    def updateEstimatedNetworkBytes(self, arg0: JobParameters, arg1: int, arg2: int) -> None: ...
    @overload
    def updateEstimatedNetworkBytes(self, arg0: JobParameters, arg1: JobWorkItem, arg2: int, arg3: int) -> None: ...
    @overload
    def updateTransferredNetworkBytes(self, arg0: JobParameters, arg1: int, arg2: int) -> None: ...
