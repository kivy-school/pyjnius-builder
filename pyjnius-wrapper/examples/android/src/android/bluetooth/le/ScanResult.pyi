from typing import Any, ClassVar, overload
from android.bluetooth.BluetoothDevice import BluetoothDevice
from android.bluetooth.le.ScanRecord import ScanRecord
from android.os.Parcel import Parcel

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Creator:
    """Forward declaration for ``android.os.Parcelable.Creator``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('android.os.Parcelable.Creator')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://developer.android.com/reference/android/os/Parcelable/Creator
    """
    ...

class ScanResult:
    CREATOR: ClassVar[Creator]
    DATA_COMPLETE: ClassVar[int]
    DATA_TRUNCATED: ClassVar[int]
    PERIODIC_INTERVAL_NOT_PRESENT: ClassVar[int]
    PHY_UNUSED: ClassVar[int]
    SID_NOT_PRESENT: ClassVar[int]
    TX_POWER_NOT_PRESENT: ClassVar[int]
    @overload
    def __init__(self, arg0: BluetoothDevice, arg1: ScanRecord, arg2: int, arg3: int) -> None: ...
    @overload
    def __init__(self, arg0: BluetoothDevice, arg1: int, arg2: int, arg3: int, arg4: int, arg5: int, arg6: int, arg7: int, arg8: ScanRecord, arg9: int) -> None: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def describeContents(self) -> int: ...
    def getDevice(self) -> BluetoothDevice: ...
    def getScanRecord(self) -> ScanRecord: ...
    def getRssi(self) -> int: ...
    def getTimestampNanos(self) -> int: ...
    def isLegacy(self) -> bool: ...
    def isConnectable(self) -> bool: ...
    def getDataStatus(self) -> int: ...
    def getPrimaryPhy(self) -> int: ...
    def getSecondaryPhy(self) -> int: ...
    def getAdvertisingSid(self) -> int: ...
    def getTxPower(self) -> int: ...
    def getPeriodicAdvertisingInterval(self) -> int: ...
    def hashCode(self) -> int: ...
    def equals(self, arg0: Any) -> bool: ...
    def toString(self) -> str: ...
