from typing import Any, ClassVar, overload
from android.bluetooth.le.AdvertisingSet import AdvertisingSet

class AdvertisingSetCallback:
    ADVERTISE_FAILED_ALREADY_STARTED: ClassVar[int]
    ADVERTISE_FAILED_DATA_TOO_LARGE: ClassVar[int]
    ADVERTISE_FAILED_FEATURE_UNSUPPORTED: ClassVar[int]
    ADVERTISE_FAILED_INTERNAL_ERROR: ClassVar[int]
    ADVERTISE_FAILED_TOO_MANY_ADVERTISERS: ClassVar[int]
    ADVERTISE_SUCCESS: ClassVar[int]
    def __init__(self) -> None: ...
    def onAdvertisingSetStarted(self, arg0: AdvertisingSet, arg1: int, arg2: int) -> None: ...
    def onAdvertisingSetStopped(self, arg0: AdvertisingSet) -> None: ...
    def onAdvertisingEnabled(self, arg0: AdvertisingSet, arg1: bool, arg2: int) -> None: ...
    def onAdvertisingDataSet(self, arg0: AdvertisingSet, arg1: int) -> None: ...
    def onScanResponseDataSet(self, arg0: AdvertisingSet, arg1: int) -> None: ...
    def onAdvertisingParametersUpdated(self, arg0: AdvertisingSet, arg1: int, arg2: int) -> None: ...
    def onPeriodicAdvertisingParametersUpdated(self, arg0: AdvertisingSet, arg1: int) -> None: ...
    def onPeriodicAdvertisingDataSet(self, arg0: AdvertisingSet, arg1: int) -> None: ...
    def onPeriodicAdvertisingEnabled(self, arg0: AdvertisingSet, arg1: bool, arg2: int) -> None: ...
