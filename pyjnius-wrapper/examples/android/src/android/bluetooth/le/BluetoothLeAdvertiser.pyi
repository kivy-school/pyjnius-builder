from typing import Any, ClassVar, overload
from android.bluetooth.le.AdvertiseCallback import AdvertiseCallback
from android.bluetooth.le.AdvertiseData import AdvertiseData
from android.bluetooth.le.AdvertiseSettings import AdvertiseSettings
from android.bluetooth.le.AdvertisingSetCallback import AdvertisingSetCallback
from android.bluetooth.le.AdvertisingSetParameters import AdvertisingSetParameters
from android.bluetooth.le.PeriodicAdvertisingParameters import PeriodicAdvertisingParameters
from android.os.Handler import Handler

class BluetoothLeAdvertiser:
    @overload
    def startAdvertising(self, arg0: AdvertiseSettings, arg1: AdvertiseData, arg2: AdvertiseCallback) -> None: ...
    @overload
    def startAdvertising(self, arg0: AdvertiseSettings, arg1: AdvertiseData, arg2: AdvertiseData, arg3: AdvertiseCallback) -> None: ...
    def stopAdvertising(self, arg0: AdvertiseCallback) -> None: ...
    @overload
    def startAdvertisingSet(self, arg0: AdvertisingSetParameters, arg1: AdvertiseData, arg2: AdvertiseData, arg3: PeriodicAdvertisingParameters, arg4: AdvertiseData, arg5: AdvertisingSetCallback) -> None: ...
    @overload
    def startAdvertisingSet(self, arg0: AdvertisingSetParameters, arg1: AdvertiseData, arg2: AdvertiseData, arg3: PeriodicAdvertisingParameters, arg4: AdvertiseData, arg5: AdvertisingSetCallback, arg6: Handler) -> None: ...
    @overload
    def startAdvertisingSet(self, arg0: AdvertisingSetParameters, arg1: AdvertiseData, arg2: AdvertiseData, arg3: PeriodicAdvertisingParameters, arg4: AdvertiseData, arg5: int, arg6: int, arg7: AdvertisingSetCallback) -> None: ...
    @overload
    def startAdvertisingSet(self, arg0: AdvertisingSetParameters, arg1: AdvertiseData, arg2: AdvertiseData, arg3: PeriodicAdvertisingParameters, arg4: AdvertiseData, arg5: int, arg6: int, arg7: AdvertisingSetCallback, arg8: Handler) -> None: ...
    def stopAdvertisingSet(self, arg0: AdvertisingSetCallback) -> None: ...
