from typing import Any, ClassVar, overload
from android.database.CursorWindow import CursorWindow
from android.database.sqlite.SQLiteCursorDriver import SQLiteCursorDriver
from android.database.sqlite.SQLiteDatabase import SQLiteDatabase
from android.database.sqlite.SQLiteQuery import SQLiteQuery

class SQLiteCursor:
    @overload
    def __init__(self, arg0: SQLiteDatabase, arg1: SQLiteCursorDriver, arg2: str, arg3: SQLiteQuery) -> None: ...
    @overload
    def __init__(self, arg0: SQLiteCursorDriver, arg1: str, arg2: SQLiteQuery) -> None: ...
    def getDatabase(self) -> SQLiteDatabase: ...
    def onMove(self, arg0: int, arg1: int) -> bool: ...
    def getCount(self) -> int: ...
    def getColumnIndex(self, arg0: str) -> int: ...
    def getColumnNames(self) -> list[str]: ...
    def deactivate(self) -> None: ...
    def close(self) -> None: ...
    def requery(self) -> bool: ...
    def setWindow(self, arg0: CursorWindow) -> None: ...
    def setSelectionArguments(self, arg0: list[str]) -> None: ...
    def setFillWindowForwardOnly(self, arg0: bool) -> None: ...
    def finalize(self) -> None: ...
