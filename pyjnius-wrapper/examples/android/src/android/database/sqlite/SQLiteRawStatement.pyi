from typing import Any, ClassVar, overload

class SQLiteRawStatement:
    SQLITE_DATA_TYPE_BLOB: ClassVar[int]
    SQLITE_DATA_TYPE_FLOAT: ClassVar[int]
    SQLITE_DATA_TYPE_INTEGER: ClassVar[int]
    SQLITE_DATA_TYPE_NULL: ClassVar[int]
    SQLITE_DATA_TYPE_TEXT: ClassVar[int]
    def close(self) -> None: ...
    def isOpen(self) -> bool: ...
    def step(self) -> bool: ...
    def reset(self) -> None: ...
    def clearBindings(self) -> None: ...
    def getParameterCount(self) -> int: ...
    def getParameterIndex(self, arg0: str) -> int: ...
    def getParameterName(self, arg0: int) -> str: ...
    @overload
    def bindBlob(self, arg0: int, arg1: list[int]) -> None: ...
    @overload
    def bindBlob(self, arg0: int, arg1: list[int], arg2: int, arg3: int) -> None: ...
    def bindDouble(self, arg0: int, arg1: float) -> None: ...
    def bindInt(self, arg0: int, arg1: int) -> None: ...
    def bindLong(self, arg0: int, arg1: int) -> None: ...
    def bindNull(self, arg0: int) -> None: ...
    def bindText(self, arg0: int, arg1: str) -> None: ...
    def getResultColumnCount(self) -> int: ...
    def getColumnType(self, arg0: int) -> int: ...
    def getColumnName(self, arg0: int) -> str: ...
    def getColumnLength(self, arg0: int) -> int: ...
    def getColumnBlob(self, arg0: int) -> list[int]: ...
    def readColumnBlob(self, arg0: int, arg1: list[int], arg2: int, arg3: int, arg4: int) -> int: ...
    def getColumnDouble(self, arg0: int) -> float: ...
    def getColumnInt(self, arg0: int) -> int: ...
    def getColumnLong(self, arg0: int) -> int: ...
    def getColumnText(self, arg0: int) -> str: ...
    def toString(self) -> str: ...
