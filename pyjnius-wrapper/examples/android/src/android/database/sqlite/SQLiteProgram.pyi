from typing import Any, ClassVar, overload

class SQLiteProgram:
    def getUniqueId(self) -> int: ...
    def bindNull(self, arg0: int) -> None: ...
    def bindLong(self, arg0: int, arg1: int) -> None: ...
    def bindDouble(self, arg0: int, arg1: float) -> None: ...
    def bindString(self, arg0: int, arg1: str) -> None: ...
    def bindBlob(self, arg0: int, arg1: list[int]) -> None: ...
    def clearBindings(self) -> None: ...
    def bindAllArgsAsStrings(self, arg0: list[str]) -> None: ...
    def onAllReferencesReleased(self) -> None: ...
