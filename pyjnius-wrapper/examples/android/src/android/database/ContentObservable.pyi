from typing import Any, ClassVar, overload
from android.database.ContentObserver import ContentObserver
from android.net.Uri import Uri

class ContentObservable:
    def __init__(self) -> None: ...
    def registerObserver(self, arg0: ContentObserver) -> None: ...
    @overload
    def dispatchChange(self, arg0: bool) -> None: ...
    @overload
    def dispatchChange(self, arg0: bool, arg1: Uri) -> None: ...
    def notifyChange(self, arg0: bool) -> None: ...
