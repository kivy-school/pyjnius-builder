from typing import Any, ClassVar, overload
from java.lang.Iterable import Iterable

class MatrixCursor:
    @overload
    def __init__(self, arg0: list[str], arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: list[str]) -> None: ...
    def newRow(self) -> "RowBuilder": ...
    @overload
    def addRow(self, arg0: list) -> None: ...
    @overload
    def addRow(self, arg0: Iterable) -> None: ...
    def getCount(self) -> int: ...
    def getColumnNames(self) -> list[str]: ...
    def getString(self, arg0: int) -> str: ...
    def getShort(self, arg0: int) -> int: ...
    def getInt(self, arg0: int) -> int: ...
    def getLong(self, arg0: int) -> int: ...
    def getFloat(self, arg0: int) -> float: ...
    def getDouble(self, arg0: int) -> float: ...
    def getBlob(self, arg0: int) -> list[int]: ...
    def getType(self, arg0: int) -> int: ...
    def isNull(self, arg0: int) -> bool: ...

    class RowBuilder:
        @overload
        def add(self, arg0: Any) -> "RowBuilder": ...
        @overload
        def add(self, arg0: str, arg1: Any) -> "RowBuilder": ...
