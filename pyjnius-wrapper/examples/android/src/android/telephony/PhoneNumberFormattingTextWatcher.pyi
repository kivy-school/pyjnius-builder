from typing import Any, ClassVar, overload
from android.text.Editable import Editable

class PhoneNumberFormattingTextWatcher:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: str) -> None: ...
    def beforeTextChanged(self, arg0: str, arg1: int, arg2: int, arg3: int) -> None: ...
    def onTextChanged(self, arg0: str, arg1: int, arg2: int, arg3: int) -> None: ...
    def afterTextChanged(self, arg0: Editable) -> None: ...
