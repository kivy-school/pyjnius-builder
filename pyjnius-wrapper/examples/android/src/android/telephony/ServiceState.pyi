    @overload
    def __init__(self, arg0: "ServiceState") -> None: ...
    @overload
    def __init__(self, arg0: Parcel) -> None: ...
    def copyFrom(self, arg0: "ServiceState") -> None: ...
    def writeToParcel(self, arg0: Parcel, arg1: int) -> None: ...
    def describeContents(self) -> int: ...
    def getState(self) -> int: ...
    def getDuplexMode(self) -> int: ...
    def getChannelNumber(self) -> int: ...
    def getCellBandwidths(self) -> list[int]: ...
    def getRoaming(self) -> bool: ...
    def getOperatorAlphaLong(self) -> str: ...
    def getOperatorAlphaShort(self) -> str: ...
    def getOperatorNumeric(self) -> str: ...
    def getIsManualSelection(self) -> bool: ...
    def hashCode(self) -> int: ...
    def equals(self, arg0: Any) -> bool: ...
    def toString(self) -> str: ...
    def setStateOutOfService(self) -> None: ...
    def setStateOff(self) -> None: ...
    def setState(self, arg0: int) -> None: ...
    def setRoaming(self, arg0: bool) -> None: ...
    def setOperatorName(self, arg0: str, arg1: str, arg2: str) -> None: ...
    def setIsManualSelection(self, arg0: bool) -> None: ...
