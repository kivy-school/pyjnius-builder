from typing import Any, ClassVar, overload
from java.lang.ClassLoader import ClassLoader
from java.net.URL import URL
from java.util.Enumeration import Enumeration

class DelegateLastClassLoader:
    @overload
    def __init__(self, arg0: str, arg1: ClassLoader) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: str, arg2: ClassLoader) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: str, arg2: ClassLoader, arg3: bool) -> None: ...
    def loadClass(self, arg0: str, arg1: bool) -> type: ...
    def getResource(self, arg0: str) -> URL: ...
    def getResources(self, arg0: str) -> Enumeration: ...
