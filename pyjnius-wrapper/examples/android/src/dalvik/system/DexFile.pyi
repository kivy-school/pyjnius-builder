from typing import Any, ClassVar, overload
from java.io.File import File
from java.lang.ClassLoader import ClassLoader
from java.util.Enumeration import Enumeration

class DexFile:
    @overload
    def __init__(self, arg0: File) -> None: ...
    @overload
    def __init__(self, arg0: str) -> None: ...
    @staticmethod
    def loadDex(arg0: str, arg1: str, arg2: int) -> "DexFile": ...
    def getName(self) -> str: ...
    def toString(self) -> str: ...
    def close(self) -> None: ...
    def loadClass(self, arg0: str, arg1: ClassLoader) -> type: ...
    def entries(self) -> Enumeration: ...
    def finalize(self) -> None: ...
    @staticmethod
    def isDexOptNeeded(arg0: str) -> bool: ...

    class OptimizationInfo:
        def isVerified(self) -> bool: ...
        def isOptimized(self) -> bool: ...
        def isFullyCompiled(self) -> bool: ...
