from typing import Any, ClassVar, overload
from java.io.File import File
from java.io.InputStream import InputStream
from javax.xml.validation.Schema import Schema
from org.xml.sax.HandlerBase import HandlerBase
from org.xml.sax.InputSource import InputSource
from org.xml.sax.Parser import Parser
from org.xml.sax.XMLReader import XMLReader
from org.xml.sax.helpers.DefaultHandler import DefaultHandler

class SAXParser:
    def __init__(self) -> None: ...
    def reset(self) -> None: ...
    @overload
    def parse(self, arg0: InputStream, arg1: HandlerBase) -> None: ...
    @overload
    def parse(self, arg0: InputStream, arg1: HandlerBase, arg2: str) -> None: ...
    @overload
    def parse(self, arg0: InputStream, arg1: DefaultHandler) -> None: ...
    @overload
    def parse(self, arg0: InputStream, arg1: DefaultHandler, arg2: str) -> None: ...
    @overload
    def parse(self, arg0: str, arg1: HandlerBase) -> None: ...
    @overload
    def parse(self, arg0: str, arg1: DefaultHandler) -> None: ...
    @overload
    def parse(self, arg0: File, arg1: HandlerBase) -> None: ...
    @overload
    def parse(self, arg0: File, arg1: DefaultHandler) -> None: ...
    @overload
    def parse(self, arg0: InputSource, arg1: HandlerBase) -> None: ...
    @overload
    def parse(self, arg0: InputSource, arg1: DefaultHandler) -> None: ...
    def getParser(self) -> Parser: ...
    def getXMLReader(self) -> XMLReader: ...
    def isNamespaceAware(self) -> bool: ...
    def isValidating(self) -> bool: ...
    def setProperty(self, arg0: str, arg1: Any) -> None: ...
    def getProperty(self, arg0: str) -> Any: ...
    def getSchema(self) -> Schema: ...
    def isXIncludeAware(self) -> bool: ...
