from typing import Any, ClassVar, overload
from java.io.File import File
from java.io.InputStream import InputStream
from javax.xml.validation.Schema import Schema
from org.w3c.dom.DOMImplementation import DOMImplementation
from org.w3c.dom.Document import Document
from org.xml.sax.EntityResolver import EntityResolver
from org.xml.sax.ErrorHandler import ErrorHandler
from org.xml.sax.InputSource import InputSource

class DocumentBuilder:
    def __init__(self) -> None: ...
    def reset(self) -> None: ...
    @overload
    def parse(self, arg0: InputStream) -> Document: ...
    @overload
    def parse(self, arg0: InputStream, arg1: str) -> Document: ...
    @overload
    def parse(self, arg0: str) -> Document: ...
    @overload
    def parse(self, arg0: File) -> Document: ...
    @overload
    def parse(self, arg0: InputSource) -> Document: ...
    def isNamespaceAware(self) -> bool: ...
    def isValidating(self) -> bool: ...
    def setEntityResolver(self, arg0: EntityResolver) -> None: ...
    def setErrorHandler(self, arg0: ErrorHandler) -> None: ...
    def newDocument(self) -> Document: ...
    def getDOMImplementation(self) -> DOMImplementation: ...
    def getSchema(self) -> Schema: ...
    def isXIncludeAware(self) -> bool: ...
