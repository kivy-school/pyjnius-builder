from typing import Any, ClassVar, overload
from java.lang.Throwable import Throwable
from javax.xml.transform.SourceLocator import SourceLocator

class TransformerConfigurationException:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: str) -> None: ...
    @overload
    def __init__(self, arg0: Throwable) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: Throwable) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: SourceLocator) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: SourceLocator, arg2: Throwable) -> None: ...
