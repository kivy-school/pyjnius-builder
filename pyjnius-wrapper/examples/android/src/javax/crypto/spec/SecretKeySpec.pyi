from typing import Any, ClassVar, overload

class SecretKeySpec:
    @overload
    def __init__(self, arg0: list[int], arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: list[int], arg1: int, arg2: int, arg3: str) -> None: ...
    def getAlgorithm(self) -> str: ...
    def getFormat(self) -> str: ...
    def getEncoded(self) -> list[int]: ...
    def hashCode(self) -> int: ...
    def equals(self, arg0: Any) -> bool: ...
