from typing import Any, ClassVar, overload

class DESKeySpec:
    DES_KEY_LEN: ClassVar[int]
    @overload
    def __init__(self, arg0: list[int]) -> None: ...
    @overload
    def __init__(self, arg0: list[int], arg1: int) -> None: ...
    def getKey(self) -> list[int]: ...
    @staticmethod
    def isParityAdjusted(arg0: list[int], arg1: int) -> bool: ...
    @staticmethod
    def isWeak(arg0: list[int], arg1: int) -> bool: ...
