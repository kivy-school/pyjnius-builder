from typing import Any, ClassVar, overload

class RC2ParameterSpec:
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: list[int]) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: list[int], arg2: int) -> None: ...
    def getEffectiveKeyBits(self) -> int: ...
    def getIV(self) -> list[int]: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
