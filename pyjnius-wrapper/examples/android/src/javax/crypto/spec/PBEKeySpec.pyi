from typing import Any, ClassVar, overload

class PBEKeySpec:
    @overload
    def __init__(self, arg0: list[str]) -> None: ...
    @overload
    def __init__(self, arg0: list[str], arg1: list[int], arg2: int, arg3: int) -> None: ...
    @overload
    def __init__(self, arg0: list[str], arg1: list[int], arg2: int) -> None: ...
    def clearPassword(self) -> None: ...
    def getPassword(self) -> list[str]: ...
    def getSalt(self) -> list[int]: ...
    def getIterationCount(self) -> int: ...
    def getKeyLength(self) -> int: ...
