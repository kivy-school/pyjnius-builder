from typing import Any, ClassVar, overload
from java.security.AlgorithmParameters import AlgorithmParameters
from java.security.Key import Key
from java.security.spec.AlgorithmParameterSpec import AlgorithmParameterSpec

class ExemptionMechanismSpi:
    def __init__(self) -> None: ...
    def engineGetOutputSize(self, arg0: int) -> int: ...
    @overload
    def engineInit(self, arg0: Key) -> None: ...
    @overload
    def engineInit(self, arg0: Key, arg1: AlgorithmParameterSpec) -> None: ...
    @overload
    def engineInit(self, arg0: Key, arg1: AlgorithmParameters) -> None: ...
    @overload
    def engineGenExemptionBlob(self) -> list[int]: ...
    @overload
    def engineGenExemptionBlob(self, arg0: list[int], arg1: int) -> int: ...
