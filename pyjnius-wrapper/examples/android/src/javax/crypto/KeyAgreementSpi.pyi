from typing import Any, ClassVar, overload
from java.security.Key import Key
from java.security.SecureRandom import SecureRandom
from java.security.spec.AlgorithmParameterSpec import AlgorithmParameterSpec
from javax.crypto.SecretKey import SecretKey

class KeyAgreementSpi:
    def __init__(self) -> None: ...
    @overload
    def engineInit(self, arg0: Key, arg1: SecureRandom) -> None: ...
    @overload
    def engineInit(self, arg0: Key, arg1: AlgorithmParameterSpec, arg2: SecureRandom) -> None: ...
    def engineDoPhase(self, arg0: Key, arg1: bool) -> Key: ...
    @overload
    def engineGenerateSecret(self) -> list[int]: ...
    @overload
    def engineGenerateSecret(self, arg0: list[int], arg1: int) -> int: ...
    @overload
    def engineGenerateSecret(self, arg0: str) -> SecretKey: ...
