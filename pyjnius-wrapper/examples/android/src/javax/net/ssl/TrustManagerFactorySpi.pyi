from typing import Any, ClassVar, overload
from java.security.KeyStore import KeyStore
from javax.net.ssl.ManagerFactoryParameters import ManagerFactoryParameters
from javax.net.ssl.TrustManager import TrustManager

class TrustManagerFactorySpi:
    def __init__(self) -> None: ...
    @overload
    def engineInit(self, arg0: KeyStore) -> None: ...
    @overload
    def engineInit(self, arg0: ManagerFactoryParameters) -> None: ...
    def engineGetTrustManagers(self) -> list[TrustManager]: ...
