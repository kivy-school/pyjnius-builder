from typing import Any, ClassVar, overload
from java.security.SecureRandom import SecureRandom
from javax.net.ssl.KeyManager import KeyManager
from javax.net.ssl.SSLEngine import SSLEngine
from javax.net.ssl.SSLParameters import SSLParameters
from javax.net.ssl.SSLServerSocketFactory import SSLServerSocketFactory
from javax.net.ssl.SSLSessionContext import SSLSessionContext
from javax.net.ssl.SSLSocketFactory import SSLSocketFactory
from javax.net.ssl.TrustManager import TrustManager

class SSLContextSpi:
    def __init__(self) -> None: ...
    def engineInit(self, arg0: list[KeyManager], arg1: list[TrustManager], arg2: SecureRandom) -> None: ...
    def engineGetSocketFactory(self) -> SSLSocketFactory: ...
    def engineGetServerSocketFactory(self) -> SSLServerSocketFactory: ...
    @overload
    def engineCreateSSLEngine(self) -> SSLEngine: ...
    @overload
    def engineCreateSSLEngine(self, arg0: str, arg1: int) -> SSLEngine: ...
    def engineGetServerSessionContext(self) -> SSLSessionContext: ...
    def engineGetClientSessionContext(self) -> SSLSessionContext: ...
    def engineGetDefaultSSLParameters(self) -> SSLParameters: ...
    def engineGetSupportedSSLParameters(self) -> SSLParameters: ...
