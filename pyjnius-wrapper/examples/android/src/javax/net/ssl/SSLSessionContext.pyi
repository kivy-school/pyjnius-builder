from typing import Any, ClassVar, overload
from java.util.Enumeration import Enumeration
from javax.net.ssl.SSLSession import SSLSession

class SSLSessionContext:
    def getSession(self, arg0: list[int]) -> SSLSession: ...
    def getIds(self) -> Enumeration: ...
    def setSessionTimeout(self, arg0: int) -> None: ...
    def getSessionTimeout(self) -> int: ...
    def setSessionCacheSize(self, arg0: int) -> None: ...
    def getSessionCacheSize(self) -> int: ...
