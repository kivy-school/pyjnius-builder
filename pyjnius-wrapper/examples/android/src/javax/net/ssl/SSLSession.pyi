from typing import Any, ClassVar, overload
from java.security.Principal import Principal
from java.security.cert.Certificate import Certificate
from javax.net.ssl.SSLSessionContext import SSLSessionContext
from javax.security.cert.X509Certificate import X509Certificate

class SSLSession:
    def getId(self) -> list[int]: ...
    def getSessionContext(self) -> SSLSessionContext: ...
    def getCreationTime(self) -> int: ...
    def getLastAccessedTime(self) -> int: ...
    def invalidate(self) -> None: ...
    def isValid(self) -> bool: ...
    def putValue(self, arg0: str, arg1: Any) -> None: ...
    def getValue(self, arg0: str) -> Any: ...
    def removeValue(self, arg0: str) -> None: ...
    def getValueNames(self) -> list[str]: ...
    def getPeerCertificates(self) -> list[Certificate]: ...
    def getLocalCertificates(self) -> list[Certificate]: ...
    def getPeerCertificateChain(self) -> list[X509Certificate]: ...
    def getPeerPrincipal(self) -> Principal: ...
    def getLocalPrincipal(self) -> Principal: ...
    def getCipherSuite(self) -> str: ...
    def getProtocol(self) -> str: ...
    def getPeerHost(self) -> str: ...
    def getPeerPort(self) -> int: ...
    def getPacketBufferSize(self) -> int: ...
    def getApplicationBufferSize(self) -> int: ...
