from typing import Any, ClassVar, overload
from java.net.Socket import Socket
from java.security.Principal import Principal
from java.security.PrivateKey import PrivateKey
from java.security.cert.X509Certificate import X509Certificate

class X509KeyManager:
    def getClientAliases(self, arg0: str, arg1: list[Principal]) -> list[str]: ...
    def chooseClientAlias(self, arg0: list[str], arg1: list[Principal], arg2: Socket) -> str: ...
    def getServerAliases(self, arg0: str, arg1: list[Principal]) -> list[str]: ...
    def chooseServerAlias(self, arg0: str, arg1: list[Principal], arg2: Socket) -> str: ...
    def getCertificateChain(self, arg0: str) -> list[X509Certificate]: ...
    def getPrivateKey(self, arg0: str) -> PrivateKey: ...
