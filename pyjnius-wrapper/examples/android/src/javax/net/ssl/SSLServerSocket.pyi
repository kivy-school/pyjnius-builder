    def getWantClientAuth(self) -> bool: ...
    def setUseClientMode(self, arg0: bool) -> None: ...
    def getUseClientMode(self) -> bool: ...
    def setEnableSessionCreation(self, arg0: bool) -> None: ...
    def getEnableSessionCreation(self) -> bool: ...
