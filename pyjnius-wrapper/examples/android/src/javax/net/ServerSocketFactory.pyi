from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress
from java.net.ServerSocket import ServerSocket

class ServerSocketFactory:
    def __init__(self) -> None: ...
    @staticmethod
    def getDefault() -> "ServerSocketFactory": ...
    @overload
    def createServerSocket(self) -> ServerSocket: ...
    @overload
    def createServerSocket(self, arg0: int) -> ServerSocket: ...
    @overload
    def createServerSocket(self, arg0: int, arg1: int) -> ServerSocket: ...
    @overload
    def createServerSocket(self, arg0: int, arg1: int, arg2: InetAddress) -> ServerSocket: ...
