from typing import Any, ClassVar, overload
from java.sql.PreparedStatement import PreparedStatement
from java.sql.SQLException import SQLException
from javax.sql.PooledConnection import PooledConnection

class StatementEvent:
    @overload
    def __init__(self, arg0: PooledConnection, arg1: PreparedStatement) -> None: ...
    @overload
    def __init__(self, arg0: PooledConnection, arg1: PreparedStatement, arg2: SQLException) -> None: ...
    def getStatement(self) -> PreparedStatement: ...
    def getSQLException(self) -> SQLException: ...
