    def createLineBidi(self, arg0: int, arg1: int) -> "Bidi": ...
    def isMixed(self) -> bool: ...
    def isLeftToRight(self) -> bool: ...
    def isRightToLeft(self) -> bool: ...
    def getLength(self) -> int: ...
    def baseIsLeftToRight(self) -> bool: ...
    def getBaseLevel(self) -> int: ...
    def getLevelAt(self, arg0: int) -> int: ...
    def getRunCount(self) -> int: ...
    def getRunLevel(self, arg0: int) -> int: ...
    def getRunStart(self, arg0: int) -> int: ...
    def getRunLimit(self, arg0: int) -> int: ...
    @staticmethod
    def requiresBidi(arg0: list[str], arg1: int, arg2: int) -> bool: ...
    @staticmethod
    def reorderVisually(arg0: list[int], arg1: int, arg2: list, arg3: int, arg4: int) -> None: ...
    def toString(self) -> str: ...
