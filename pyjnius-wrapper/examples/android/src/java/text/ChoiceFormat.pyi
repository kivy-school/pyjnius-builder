from typing import Any, ClassVar, overload
from java.lang.StringBuffer import StringBuffer
from java.text.FieldPosition import FieldPosition
from java.text.ParsePosition import ParsePosition

class ChoiceFormat:
    @overload
    def __init__(self, arg0: str) -> None: ...
    @overload
    def __init__(self, arg0: list[float], arg1: list[str]) -> None: ...
    def applyPattern(self, arg0: str) -> None: ...
    def toPattern(self) -> str: ...
    def setChoices(self, arg0: list[float], arg1: list[str]) -> None: ...
    def getLimits(self) -> list[float]: ...
    def getFormats(self) -> list: ...
    @overload
    def format(self, arg0: int, arg1: StringBuffer, arg2: FieldPosition) -> StringBuffer: ...
    @overload
    def format(self, arg0: float, arg1: StringBuffer, arg2: FieldPosition) -> StringBuffer: ...
    def parse(self, arg0: str, arg1: ParsePosition) -> float: ...
    @overload
    @staticmethod
    def nextDouble(arg0: float) -> float: ...
    @overload
    @staticmethod
    def nextDouble(arg0: float, arg1: bool) -> float: ...
    @staticmethod
    def previousDouble(arg0: float) -> float: ...
    def clone(self) -> Any: ...
    def hashCode(self) -> int: ...
    def equals(self, arg0: Any) -> bool: ...
