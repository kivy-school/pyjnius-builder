from typing import Any, ClassVar, overload

class AttributedCharacterIterator:
    @overload
    def getRunStart(self) -> int: ...
    @overload
    def getRunStart(self, arg0: "Attribute") -> int: ...
    @overload
    def getRunStart(self, arg0: set) -> int: ...
    @overload
    def getRunLimit(self) -> int: ...
    @overload
    def getRunLimit(self, arg0: "Attribute") -> int: ...
    @overload
    def getRunLimit(self, arg0: set) -> int: ...
    def getAttributes(self) -> dict: ...
    def getAttribute(self, arg0: "Attribute") -> Any: ...
    def getAllAttributeKeys(self) -> set: ...

    class Attribute:
        INPUT_METHOD_SEGMENT: ClassVar["Attribute"]
        LANGUAGE: ClassVar["Attribute"]
        READING: ClassVar["Attribute"]
        def __init__(self, arg0: str) -> None: ...
        def equals(self, arg0: Any) -> bool: ...
        def hashCode(self) -> int: ...
        def toString(self) -> str: ...
        def getName(self) -> str: ...
        def readResolve(self) -> Any: ...
