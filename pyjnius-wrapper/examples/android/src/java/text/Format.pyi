from typing import Any, ClassVar, overload
from java.lang.StringBuffer import StringBuffer
from java.text.AttributedCharacterIterator import AttributedCharacterIterator
from java.text.FieldPosition import FieldPosition
from java.text.ParsePosition import ParsePosition

class Format:
    def __init__(self) -> None: ...
    @overload
    def format(self, arg0: Any) -> str: ...
    @overload
    def format(self, arg0: Any, arg1: StringBuffer, arg2: FieldPosition) -> StringBuffer: ...
    def formatToCharacterIterator(self, arg0: Any) -> AttributedCharacterIterator: ...
    @overload
    def parseObject(self, arg0: str, arg1: ParsePosition) -> Any: ...
    @overload
    def parseObject(self, arg0: str) -> Any: ...
    def clone(self) -> Any: ...

    class Field:
        def __init__(self, arg0: str) -> None: ...
