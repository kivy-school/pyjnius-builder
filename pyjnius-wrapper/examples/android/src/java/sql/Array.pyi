from typing import Any, ClassVar, overload
from java.sql.ResultSet import ResultSet

class Array:
    def getBaseTypeName(self) -> str: ...
    def getBaseType(self) -> int: ...
    @overload
    def getArray(self) -> Any: ...
    @overload
    def getArray(self, arg0: dict) -> Any: ...
    @overload
    def getArray(self, arg0: int, arg1: int) -> Any: ...
    @overload
    def getArray(self, arg0: int, arg1: int, arg2: dict) -> Any: ...
    @overload
    def getResultSet(self) -> ResultSet: ...
    @overload
    def getResultSet(self, arg0: dict) -> ResultSet: ...
    @overload
    def getResultSet(self, arg0: int, arg1: int) -> ResultSet: ...
    @overload
    def getResultSet(self, arg0: int, arg1: int, arg2: dict) -> ResultSet: ...
    def free(self) -> None: ...
