from typing import Any, ClassVar, overload
from java.sql.Connection import Connection
from java.sql.DriverPropertyInfo import DriverPropertyInfo
from java.util.Properties import Properties

class Driver:
    def connect(self, arg0: str, arg1: Properties) -> Connection: ...
    def acceptsURL(self, arg0: str) -> bool: ...
    def getPropertyInfo(self, arg0: str, arg1: Properties) -> list[DriverPropertyInfo]: ...
    def getMajorVersion(self) -> int: ...
    def getMinorVersion(self) -> int: ...
    def jdbcCompliant(self) -> bool: ...
