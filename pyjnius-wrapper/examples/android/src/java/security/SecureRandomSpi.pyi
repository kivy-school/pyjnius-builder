from typing import Any, ClassVar, overload
from java.security.SecureRandomParameters import SecureRandomParameters

class SecureRandomSpi:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: SecureRandomParameters) -> None: ...
    def engineSetSeed(self, arg0: list[int]) -> None: ...
    @overload
    def engineNextBytes(self, arg0: list[int]) -> None: ...
    @overload
    def engineNextBytes(self, arg0: list[int], arg1: SecureRandomParameters) -> None: ...
    def engineGenerateSeed(self, arg0: int) -> list[int]: ...
    def engineReseed(self, arg0: SecureRandomParameters) -> None: ...
    def engineGetParameters(self) -> SecureRandomParameters: ...
    def toString(self) -> str: ...
