from java.security.cert.Certificate import Certificate

class UnresolvedPermission:
    def __init__(self, arg0: str, arg1: str, arg2: str, arg3: list[Certificate]) -> None: ...
    def implies(self, arg0: Permission) -> bool: ...
    def getActions(self) -> str: ...
    def getUnresolvedType(self) -> str: ...
