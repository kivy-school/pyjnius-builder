from typing import Any, ClassVar, overload
from java.security.Certificate import Certificate
from java.security.IdentityScope import IdentityScope
from java.security.PublicKey import PublicKey

class Identity:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: IdentityScope) -> None: ...
    @overload
    def __init__(self, arg0: str) -> None: ...
    def getName(self) -> str: ...
    def getScope(self) -> IdentityScope: ...
    def getPublicKey(self) -> PublicKey: ...
    def setPublicKey(self, arg0: PublicKey) -> None: ...
    def setInfo(self, arg0: str) -> None: ...
    def getInfo(self) -> str: ...
    def addCertificate(self, arg0: Certificate) -> None: ...
    def removeCertificate(self, arg0: Certificate) -> None: ...
    def certificates(self) -> list[Certificate]: ...
    def equals(self, arg0: Any) -> bool: ...
    def identityEquals(self, arg0: "Identity") -> bool: ...
    @overload
    def toString(self) -> str: ...
    @overload
    def toString(self, arg0: bool) -> str: ...
    def hashCode(self) -> int: ...
