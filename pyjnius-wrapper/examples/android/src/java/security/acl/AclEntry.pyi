from typing import Any, ClassVar, overload
from java.security.Principal import Principal
from java.security.acl.Permission import Permission
from java.util.Enumeration import Enumeration

class AclEntry:
    def setPrincipal(self, arg0: Principal) -> bool: ...
    def getPrincipal(self) -> Principal: ...
    def setNegativePermissions(self) -> None: ...
    def isNegative(self) -> bool: ...
    def addPermission(self, arg0: Permission) -> bool: ...
    def removePermission(self, arg0: Permission) -> bool: ...
    def checkPermission(self, arg0: Permission) -> bool: ...
    def permissions(self) -> Enumeration: ...
    def toString(self) -> str: ...
    def clone(self) -> Any: ...
