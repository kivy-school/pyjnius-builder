from typing import Any, ClassVar, overload
from java.security.DomainCombiner import DomainCombiner
from java.security.Permission import Permission
from java.security.ProtectionDomain import ProtectionDomain

class AccessControlContext:
    @overload
    def __init__(self, arg0: list[ProtectionDomain]) -> None: ...
    @overload
    def __init__(self, arg0: "AccessControlContext", arg1: DomainCombiner) -> None: ...
    def getDomainCombiner(self) -> DomainCombiner: ...
    def checkPermission(self, arg0: Permission) -> None: ...
