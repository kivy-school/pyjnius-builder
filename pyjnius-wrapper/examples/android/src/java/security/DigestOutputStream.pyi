from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.security.MessageDigest import MessageDigest

class DigestOutputStream:
    digest: MessageDigest
    def __init__(self, arg0: OutputStream, arg1: MessageDigest) -> None: ...
    def getMessageDigest(self) -> MessageDigest: ...
    def setMessageDigest(self, arg0: MessageDigest) -> None: ...
    @overload
    def write(self, arg0: int) -> None: ...
    @overload
    def write(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    def on(self, arg0: bool) -> None: ...
    def toString(self) -> str: ...
