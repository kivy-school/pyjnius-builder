from typing import Any, ClassVar, overload
from java.security.IdentityScope import IdentityScope
from java.security.KeyPair import KeyPair
from java.security.PrivateKey import PrivateKey

class Signer:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: IdentityScope) -> None: ...
    def getPrivateKey(self) -> PrivateKey: ...
    def setKeyPair(self, arg0: KeyPair) -> None: ...
    def toString(self) -> str: ...
