from typing import Any, ClassVar, overload
from java.net.URL import URL
from java.security.CodeSigner import CodeSigner
from java.security.cert.Certificate import Certificate

class CodeSource:
    @overload
    def __init__(self, arg0: URL, arg1: list[Certificate]) -> None: ...
    @overload
    def __init__(self, arg0: URL, arg1: list[CodeSigner]) -> None: ...
    def getLocation(self) -> URL: ...
    def getCertificates(self) -> list[Certificate]: ...
    def getCodeSigners(self) -> list[CodeSigner]: ...
    def implies(self, arg0: "CodeSource") -> bool: ...
