from typing import Any, ClassVar, overload
from java.security.Identity import Identity
from java.security.Principal import Principal
from java.security.PublicKey import PublicKey
from java.util.Enumeration import Enumeration

class IdentityScope:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: "IdentityScope") -> None: ...
    @staticmethod
    def getSystemScope() -> "IdentityScope": ...
    @staticmethod
    def setSystemScope(arg0: "IdentityScope") -> None: ...
    def size(self) -> int: ...
    @overload
    def getIdentity(self, arg0: str) -> Identity: ...
    @overload
    def getIdentity(self, arg0: Principal) -> Identity: ...
    @overload
    def getIdentity(self, arg0: PublicKey) -> Identity: ...
    def addIdentity(self, arg0: Identity) -> None: ...
    def removeIdentity(self, arg0: Identity) -> None: ...
    def identities(self) -> Enumeration: ...
    def toString(self) -> str: ...
