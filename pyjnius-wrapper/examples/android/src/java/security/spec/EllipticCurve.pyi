from typing import Any, ClassVar, overload
from java.math.BigInteger import BigInteger
from java.security.spec.ECField import ECField

class EllipticCurve:
    @overload
    def __init__(self, arg0: ECField, arg1: BigInteger, arg2: BigInteger) -> None: ...
    @overload
    def __init__(self, arg0: ECField, arg1: BigInteger, arg2: BigInteger, arg3: list[int]) -> None: ...
    def getField(self) -> ECField: ...
    def getA(self) -> BigInteger: ...
    def getB(self) -> BigInteger: ...
    def getSeed(self) -> list[int]: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
