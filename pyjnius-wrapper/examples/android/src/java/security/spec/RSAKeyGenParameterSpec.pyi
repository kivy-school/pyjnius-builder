from typing import Any, ClassVar, overload
from java.math.BigInteger import BigInteger
from java.security.spec.AlgorithmParameterSpec import AlgorithmParameterSpec

class RSAKeyGenParameterSpec:
    F0: ClassVar[BigInteger]
    F4: ClassVar[BigInteger]
    @overload
    def __init__(self, arg0: int, arg1: BigInteger) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: BigInteger, arg2: AlgorithmParameterSpec) -> None: ...
    def getKeysize(self) -> int: ...
    def getPublicExponent(self) -> BigInteger: ...
    def getKeyParams(self) -> AlgorithmParameterSpec: ...
