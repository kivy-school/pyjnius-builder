from typing import Any, ClassVar, overload
from java.math.BigInteger import BigInteger

class ECFieldF2m:
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: BigInteger) -> None: ...
    @overload
    def __init__(self, arg0: int, arg1: list[int]) -> None: ...
    def getFieldSize(self) -> int: ...
    def getM(self) -> int: ...
    def getReductionPolynomial(self) -> BigInteger: ...
    def getMidTermsOfReductionPolynomial(self) -> list[int]: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
