from typing import Any, ClassVar, overload
from java.math.BigInteger import BigInteger
from java.security.cert.CRLReason import CRLReason
from java.util.Date import Date
from javax.security.auth.x500.X500Principal import X500Principal

class X509CRLEntry:
    def __init__(self) -> None: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def getEncoded(self) -> list[int]: ...
    def getSerialNumber(self) -> BigInteger: ...
    def getCertificateIssuer(self) -> X500Principal: ...
    def getRevocationDate(self) -> Date: ...
    def hasExtensions(self) -> bool: ...
    def toString(self) -> str: ...
    def getRevocationReason(self) -> CRLReason: ...
