from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.security.cert.CRL import CRL
from java.security.cert.CertPath import CertPath
from java.security.cert.Certificate import Certificate
from java.util.Iterator import Iterator

class CertificateFactorySpi:
    def __init__(self) -> None: ...
    def engineGenerateCertificate(self, arg0: InputStream) -> Certificate: ...
    @overload
    def engineGenerateCertPath(self, arg0: InputStream) -> CertPath: ...
    @overload
    def engineGenerateCertPath(self, arg0: InputStream, arg1: str) -> CertPath: ...
    @overload
    def engineGenerateCertPath(self, arg0: list) -> CertPath: ...
    def engineGetCertPathEncodings(self) -> Iterator: ...
    def engineGenerateCertificates(self, arg0: InputStream) -> list: ...
    def engineGenerateCRL(self, arg0: InputStream) -> CRL: ...
    def engineGenerateCRLs(self, arg0: InputStream) -> list: ...
