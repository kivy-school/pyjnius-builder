from typing import Any, ClassVar, overload
from java.security.cert.CRLReason import CRLReason
from java.util.Date import Date
from javax.security.auth.x500.X500Principal import X500Principal

class CertificateRevokedException:
    def __init__(self, arg0: Date, arg1: CRLReason, arg2: X500Principal, arg3: dict) -> None: ...
    def getRevocationDate(self) -> Date: ...
    def getRevocationReason(self) -> CRLReason: ...
    def getAuthorityName(self) -> X500Principal: ...
    def getInvalidityDate(self) -> Date: ...
    def getExtensions(self) -> dict: ...
    def getMessage(self) -> str: ...
