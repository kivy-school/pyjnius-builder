    def getHostName(self) -> str: ...
    def getHostString(self) -> str: ...
    def isUnresolved(self) -> bool: ...
    def toString(self) -> str: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
