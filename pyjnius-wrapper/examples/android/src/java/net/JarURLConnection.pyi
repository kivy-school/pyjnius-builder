from typing import Any, ClassVar, overload
from java.net.URL import URL
from java.net.URLConnection import URLConnection
from java.security.cert.Certificate import Certificate
from java.util.jar.Attributes import Attributes
from java.util.jar.JarEntry import JarEntry
from java.util.jar.JarFile import JarFile
from java.util.jar.Manifest import Manifest

class JarURLConnection:
    jarFileURLConnection: URLConnection
    def __init__(self, arg0: URL) -> None: ...
    def getJarFileURL(self) -> URL: ...
    def getEntryName(self) -> str: ...
    def getJarFile(self) -> JarFile: ...
    def getManifest(self) -> Manifest: ...
    def getJarEntry(self) -> JarEntry: ...
    def getAttributes(self) -> Attributes: ...
    def getMainAttributes(self) -> Attributes: ...
    def getCertificates(self) -> list[Certificate]: ...
