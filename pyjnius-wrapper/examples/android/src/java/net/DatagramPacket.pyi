from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress
from java.net.SocketAddress import SocketAddress

class DatagramPacket:
    @overload
    def __init__(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: list[int], arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: list[int], arg1: int, arg2: int, arg3: InetAddress, arg4: int) -> None: ...
    @overload
    def __init__(self, arg0: list[int], arg1: int, arg2: int, arg3: SocketAddress) -> None: ...
    @overload
    def __init__(self, arg0: list[int], arg1: int, arg2: InetAddress, arg3: int) -> None: ...
    @overload
    def __init__(self, arg0: list[int], arg1: int, arg2: SocketAddress) -> None: ...
    def getAddress(self) -> InetAddress: ...
    def getPort(self) -> int: ...
    def getData(self) -> list[int]: ...
    def getOffset(self) -> int: ...
    def getLength(self) -> int: ...
    @overload
    def setData(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    @overload
    def setData(self, arg0: list[int]) -> None: ...
    def setAddress(self, arg0: InetAddress) -> None: ...
    def setPort(self, arg0: int) -> None: ...
    def setSocketAddress(self, arg0: SocketAddress) -> None: ...
    def getSocketAddress(self) -> SocketAddress: ...
    def setLength(self, arg0: int) -> None: ...
