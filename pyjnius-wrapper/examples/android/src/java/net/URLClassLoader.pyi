    def findResource(self, arg0: str) -> URL: ...
    def findResources(self, arg0: str) -> Enumeration: ...
    def getPermissions(self, arg0: CodeSource) -> PermissionCollection: ...
    @overload
    @staticmethod
    def newInstance(arg0: list[URL], arg1: ClassLoader) -> "URLClassLoader": ...
    @overload
    @staticmethod
    def newInstance(arg0: list[URL]) -> "URLClassLoader": ...
