from typing import Any, ClassVar, overload
from java.io.PipedReader import PipedReader

class PipedWriter:
    @overload
    def __init__(self, arg0: PipedReader) -> None: ...
    @overload
    def __init__(self) -> None: ...
    def connect(self, arg0: PipedReader) -> None: ...
    @overload
    def write(self, arg0: int) -> None: ...
    @overload
    def write(self, arg0: list[str], arg1: int, arg2: int) -> None: ...
    def flush(self) -> None: ...
    def close(self) -> None: ...
