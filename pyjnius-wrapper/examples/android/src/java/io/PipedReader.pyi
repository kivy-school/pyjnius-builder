from typing import Any, ClassVar, overload
from java.io.PipedWriter import PipedWriter

class PipedReader:
    @overload
    def __init__(self, arg0: PipedWriter) -> None: ...
    @overload
    def __init__(self, arg0: PipedWriter, arg1: int) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: int) -> None: ...
    def connect(self, arg0: PipedWriter) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, arg0: list[str], arg1: int, arg2: int) -> int: ...
    def ready(self) -> bool: ...
    def close(self) -> None: ...
