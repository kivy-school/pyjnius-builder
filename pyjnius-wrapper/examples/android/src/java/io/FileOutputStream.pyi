from typing import Any, ClassVar, overload
from java.io.File import File
from java.io.FileDescriptor import FileDescriptor
from java.nio.channels.FileChannel import FileChannel

class FileOutputStream:
    @overload
    def __init__(self, arg0: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: bool) -> None: ...
    @overload
    def __init__(self, arg0: File) -> None: ...
    @overload
    def __init__(self, arg0: File, arg1: bool) -> None: ...
    @overload
    def __init__(self, arg0: FileDescriptor) -> None: ...
    @overload
    def write(self, arg0: int) -> None: ...
    @overload
    def write(self, arg0: list[int]) -> None: ...
    @overload
    def write(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    def close(self) -> None: ...
    def getFD(self) -> FileDescriptor: ...
    def getChannel(self) -> FileChannel: ...
    def finalize(self) -> None: ...
