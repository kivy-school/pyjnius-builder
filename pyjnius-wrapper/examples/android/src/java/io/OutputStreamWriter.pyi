from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.io.Writer import Writer
from java.nio.charset.Charset import Charset
from java.nio.charset.CharsetEncoder import CharsetEncoder

class OutputStreamWriter:
    @overload
    def __init__(self, arg0: OutputStream, arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: Charset) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: CharsetEncoder) -> None: ...
    def getEncoding(self) -> str: ...
    @overload
    def write(self, arg0: int) -> None: ...
    @overload
    def write(self, arg0: list[str], arg1: int, arg2: int) -> None: ...
    @overload
    def write(self, arg0: str, arg1: int, arg2: int) -> None: ...
    @overload
    def append(self, arg0: str, arg1: int, arg2: int) -> Writer: ...
    @overload
    def append(self, arg0: str) -> Writer: ...
    def flush(self) -> None: ...
    def close(self) -> None: ...
