from typing import Any, ClassVar, overload
from java.io.File import File
from java.io.OutputStream import OutputStream
from java.nio.charset.Charset import Charset
from java.util.Locale import Locale

class PrintStream:
    @overload
    def __init__(self, arg0: OutputStream) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: bool) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: bool, arg2: str) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: bool, arg2: Charset) -> None: ...
    @overload
    def __init__(self, arg0: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: Charset) -> None: ...
    @overload
    def __init__(self, arg0: File) -> None: ...
    @overload
    def __init__(self, arg0: File, arg1: str) -> None: ...
    @overload
    def __init__(self, arg0: File, arg1: Charset) -> None: ...
    def flush(self) -> None: ...
    def close(self) -> None: ...
    def checkError(self) -> bool: ...
    def setError(self) -> None: ...
    def clearError(self) -> None: ...
    @overload
    def write(self, arg0: int) -> None: ...
    @overload
    def write(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    @overload
    def write(self, arg0: list[int]) -> None: ...
    def writeBytes(self, arg0: list[int]) -> None: ...
    @overload
    def print(self, arg0: bool) -> None: ...
    @overload
    def print(self, arg0: str) -> None: ...
    @overload
    def print(self, arg0: int) -> None: ...
    @overload
    def print(self, arg0: int) -> None: ...
    @overload
    def print(self, arg0: float) -> None: ...
    @overload
    def print(self, arg0: float) -> None: ...
    @overload
    def print(self, arg0: list[str]) -> None: ...
    @overload
    def print(self, arg0: str) -> None: ...
    @overload
    def print(self, arg0: Any) -> None: ...
    @overload
    def println(self) -> None: ...
    @overload
    def println(self, arg0: bool) -> None: ...
    @overload
    def println(self, arg0: str) -> None: ...
    @overload
    def println(self, arg0: int) -> None: ...
    @overload
    def println(self, arg0: int) -> None: ...
    @overload
    def println(self, arg0: float) -> None: ...
    @overload
    def println(self, arg0: float) -> None: ...
    @overload
    def println(self, arg0: list[str]) -> None: ...
    @overload
    def println(self, arg0: str) -> None: ...
    @overload
    def println(self, arg0: Any) -> None: ...
    @overload
    def printf(self, arg0: str, *arg1: Any) -> "PrintStream": ...
    @overload
    def printf(self, arg0: Locale, arg1: str, *arg2: Any) -> "PrintStream": ...
    @overload
    def format(self, arg0: str, *arg1: Any) -> "PrintStream": ...
    @overload
    def format(self, arg0: Locale, arg1: str, *arg2: Any) -> "PrintStream": ...
    @overload
    def append(self, arg0: str) -> "PrintStream": ...
    @overload
    def append(self, arg0: str, arg1: int, arg2: int) -> "PrintStream": ...
    @overload
    def append(self, arg0: str) -> "PrintStream": ...
