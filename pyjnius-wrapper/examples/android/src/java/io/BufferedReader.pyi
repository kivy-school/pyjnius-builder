from typing import Any, ClassVar, overload
from java.io.Reader import Reader
from java.util.stream.Stream import Stream

class BufferedReader:
    @overload
    def __init__(self, arg0: Reader, arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: Reader) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, arg0: list[str], arg1: int, arg2: int) -> int: ...
    def readLine(self) -> str: ...
    def skip(self, arg0: int) -> int: ...
    def ready(self) -> bool: ...
    def markSupported(self) -> bool: ...
    def mark(self, arg0: int) -> None: ...
    def reset(self) -> None: ...
    def close(self) -> None: ...
    def lines(self) -> Stream: ...
