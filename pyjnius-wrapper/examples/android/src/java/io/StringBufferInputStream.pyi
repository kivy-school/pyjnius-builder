from typing import Any, ClassVar, overload

class StringBufferInputStream:
    buffer: str
    count: int
    pos: int
    def __init__(self, arg0: str) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, arg0: list[int], arg1: int, arg2: int) -> int: ...
    def skip(self, arg0: int) -> int: ...
    def available(self) -> int: ...
    def reset(self) -> None: ...
