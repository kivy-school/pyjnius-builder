from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.io.Reader import Reader

class StreamTokenizer:
    TT_EOF: ClassVar[int]
    TT_EOL: ClassVar[int]
    TT_NUMBER: ClassVar[int]
    TT_WORD: ClassVar[int]
    nval: float
    sval: str
    ttype: int
    @overload
    def __init__(self, arg0: InputStream) -> None: ...
    @overload
    def __init__(self, arg0: Reader) -> None: ...
    def resetSyntax(self) -> None: ...
    def wordChars(self, arg0: int, arg1: int) -> None: ...
    def whitespaceChars(self, arg0: int, arg1: int) -> None: ...
    def ordinaryChars(self, arg0: int, arg1: int) -> None: ...
    def ordinaryChar(self, arg0: int) -> None: ...
    def commentChar(self, arg0: int) -> None: ...
    def quoteChar(self, arg0: int) -> None: ...
    def parseNumbers(self) -> None: ...
    def eolIsSignificant(self, arg0: bool) -> None: ...
    def slashStarComments(self, arg0: bool) -> None: ...
    def slashSlashComments(self, arg0: bool) -> None: ...
    def lowerCaseMode(self, arg0: bool) -> None: ...
    def nextToken(self) -> int: ...
    def pushBack(self) -> None: ...
    def lineno(self) -> int: ...
    def toString(self) -> str: ...
