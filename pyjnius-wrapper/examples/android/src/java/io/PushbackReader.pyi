from typing import Any, ClassVar, overload
from java.io.Reader import Reader

class PushbackReader:
    @overload
    def __init__(self, arg0: Reader, arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: Reader) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, arg0: list[str], arg1: int, arg2: int) -> int: ...
    @overload
    def unread(self, arg0: int) -> None: ...
    @overload
    def unread(self, arg0: list[str], arg1: int, arg2: int) -> None: ...
    @overload
    def unread(self, arg0: list[str]) -> None: ...
    def ready(self) -> bool: ...
    def mark(self, arg0: int) -> None: ...
    def reset(self) -> None: ...
    def markSupported(self) -> bool: ...
    def close(self) -> None: ...
    def skip(self, arg0: int) -> int: ...
