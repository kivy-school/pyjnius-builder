from typing import Any, ClassVar, overload
from java.io.PipedOutputStream import PipedOutputStream

class PipedInputStream:
    PIPE_SIZE: ClassVar[int]
    buffer: list[int]
    in_: int
    out: int
    @overload
    def __init__(self, arg0: PipedOutputStream) -> None: ...
    @overload
    def __init__(self, arg0: PipedOutputStream, arg1: int) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: int) -> None: ...
    def connect(self, arg0: PipedOutputStream) -> None: ...
    def receive(self, arg0: int) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, arg0: list[int], arg1: int, arg2: int) -> int: ...
    def available(self) -> int: ...
    def close(self) -> None: ...
