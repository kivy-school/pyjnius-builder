from typing import Any, ClassVar, overload
from java.io.PrintWriter import PrintWriter
from java.io.Reader import Reader
from java.nio.charset.Charset import Charset

class Console:
    def writer(self) -> PrintWriter: ...
    def reader(self) -> Reader: ...
    def format(self, arg0: str, *arg1: Any) -> "Console": ...
    def printf(self, arg0: str, *arg1: Any) -> "Console": ...
    @overload
    def readLine(self, arg0: str, *arg1: Any) -> str: ...
    @overload
    def readLine(self) -> str: ...
    @overload
    def readPassword(self, arg0: str, *arg1: Any) -> list[str]: ...
    @overload
    def readPassword(self) -> list[str]: ...
    def flush(self) -> None: ...
    def charset(self) -> Charset: ...
