from typing import Any, ClassVar, overload
from java.util.SequencedSet import SequencedSet
from java.util.Spliterator import Spliterator

class LinkedHashSet:
    @overload
    def __init__(self, arg0: int, arg1: float) -> None: ...
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: list) -> None: ...
    def spliterator(self) -> Spliterator: ...
    @staticmethod
    def newLinkedHashSet(arg0: int) -> set: ...
    def addFirst(self, arg0: Any) -> None: ...
    def addLast(self, arg0: Any) -> None: ...
    def getFirst(self) -> Any: ...
    def getLast(self) -> Any: ...
    def removeFirst(self) -> Any: ...
    def removeLast(self) -> Any: ...
    def reversed(self) -> SequencedSet: ...
