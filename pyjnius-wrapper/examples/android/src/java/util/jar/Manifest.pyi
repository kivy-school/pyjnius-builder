from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.io.OutputStream import OutputStream
from java.util.jar.Attributes import Attributes

class Manifest:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: InputStream) -> None: ...
    @overload
    def __init__(self, arg0: "Manifest") -> None: ...
    def getMainAttributes(self) -> Attributes: ...
    def getEntries(self) -> dict: ...
    def getAttributes(self, arg0: str) -> Attributes: ...
    def clear(self) -> None: ...
    def write(self, arg0: OutputStream) -> None: ...
    def read(self, arg0: InputStream) -> None: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def clone(self) -> Any: ...
