from typing import Any, ClassVar, overload
from java.util.Iterator import Iterator

class Deque:
    def addFirst(self, arg0: Any) -> None: ...
    def addLast(self, arg0: Any) -> None: ...
    def offerFirst(self, arg0: Any) -> bool: ...
    def offerLast(self, arg0: Any) -> bool: ...
    def removeFirst(self) -> Any: ...
    def removeLast(self) -> Any: ...
    def pollFirst(self) -> Any: ...
    def pollLast(self) -> Any: ...
    def getFirst(self) -> Any: ...
    def getLast(self) -> Any: ...
    def peekFirst(self) -> Any: ...
    def peekLast(self) -> Any: ...
    def removeFirstOccurrence(self, arg0: Any) -> bool: ...
    def removeLastOccurrence(self, arg0: Any) -> bool: ...
    def add(self, arg0: Any) -> bool: ...
    def offer(self, arg0: Any) -> bool: ...
    @overload
    def remove(self) -> Any: ...
    @overload
    def remove(self, arg0: Any) -> bool: ...
    def poll(self) -> Any: ...
    def element(self) -> Any: ...
    def peek(self) -> Any: ...
    def addAll(self, arg0: list) -> bool: ...
    def push(self, arg0: Any) -> None: ...
    def pop(self) -> Any: ...
    def contains(self, arg0: Any) -> bool: ...
    def size(self) -> int: ...
    def iterator(self) -> Iterator: ...
    def descendingIterator(self) -> Iterator: ...
    def reversed(self) -> "Deque": ...
