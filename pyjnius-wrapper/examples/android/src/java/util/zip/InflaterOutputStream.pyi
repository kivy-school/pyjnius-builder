from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.util.zip.Inflater import Inflater

class InflaterOutputStream:
    buf: list[int]
    inf: Inflater
    @overload
    def __init__(self, arg0: OutputStream) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: Inflater) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: Inflater, arg2: int) -> None: ...
    def close(self) -> None: ...
    def flush(self) -> None: ...
    def finish(self) -> None: ...
    @overload
    def write(self, arg0: int) -> None: ...
    @overload
    def write(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
