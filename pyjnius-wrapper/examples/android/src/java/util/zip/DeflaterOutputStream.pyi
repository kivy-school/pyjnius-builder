from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.util.zip.Deflater import Deflater

class DeflaterOutputStream:
    buf: list[int]
    def_: Deflater
    @overload
    def __init__(self, arg0: OutputStream, arg1: Deflater, arg2: int, arg3: bool) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: Deflater, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: Deflater, arg2: bool) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: Deflater) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: bool) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream) -> None: ...
    @overload
    def write(self, arg0: int) -> None: ...
    @overload
    def write(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    def finish(self) -> None: ...
    def close(self) -> None: ...
    def deflate(self) -> None: ...
    def flush(self) -> None: ...
