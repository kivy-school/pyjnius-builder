from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.util.zip.Inflater import Inflater

class InflaterInputStream:
    buf: list[int]
    closed: bool
    inf: Inflater
    len: int
    @overload
    def __init__(self, arg0: InputStream, arg1: Inflater, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: InputStream, arg1: Inflater) -> None: ...
    @overload
    def __init__(self, arg0: InputStream) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, arg0: list[int], arg1: int, arg2: int) -> int: ...
    def available(self) -> int: ...
    def skip(self, arg0: int) -> int: ...
    def close(self) -> None: ...
    def fill(self) -> None: ...
    def markSupported(self) -> bool: ...
    def mark(self, arg0: int) -> None: ...
    def reset(self) -> None: ...
