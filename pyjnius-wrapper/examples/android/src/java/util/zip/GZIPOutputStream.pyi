from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.util.zip.CRC32 import CRC32

class GZIPOutputStream:
    crc: CRC32
    @overload
    def __init__(self, arg0: OutputStream, arg1: int) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: int, arg2: bool) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream) -> None: ...
    @overload
    def __init__(self, arg0: OutputStream, arg1: bool) -> None: ...
    def write(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    def finish(self) -> None: ...
