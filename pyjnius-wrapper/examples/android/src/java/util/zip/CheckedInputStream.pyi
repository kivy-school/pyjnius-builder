from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.util.zip.Checksum import Checksum

class CheckedInputStream:
    def __init__(self, arg0: InputStream, arg1: Checksum) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, arg0: list[int], arg1: int, arg2: int) -> int: ...
    def skip(self, arg0: int) -> int: ...
    def getChecksum(self) -> Checksum: ...
