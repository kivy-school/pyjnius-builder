from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.util.zip.Checksum import Checksum

class CheckedOutputStream:
    def __init__(self, arg0: OutputStream, arg1: Checksum) -> None: ...
    @overload
    def write(self, arg0: int) -> None: ...
    @overload
    def write(self, arg0: list[int], arg1: int, arg2: int) -> None: ...
    def getChecksum(self) -> Checksum: ...
