from typing import Any, ClassVar, overload
from java.util.logging.Handler import Handler
from java.util.logging.Level import Level
from java.util.logging.LogRecord import LogRecord

class MemoryHandler:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: Handler, arg1: int, arg2: Level) -> None: ...
    def publish(self, arg0: LogRecord) -> None: ...
    def push(self) -> None: ...
    def flush(self) -> None: ...
    def close(self) -> None: ...
    def setPushLevel(self, arg0: Level) -> None: ...
    def getPushLevel(self) -> Level: ...
    def isLoggable(self, arg0: LogRecord) -> bool: ...
