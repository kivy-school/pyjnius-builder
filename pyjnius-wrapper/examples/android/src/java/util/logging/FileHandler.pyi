from typing import Any, ClassVar, overload
from java.util.logging.LogRecord import LogRecord

class FileHandler:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: str) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: bool) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: int, arg2: int) -> None: ...
    @overload
    def __init__(self, arg0: str, arg1: int, arg2: int, arg3: bool) -> None: ...
    def publish(self, arg0: LogRecord) -> None: ...
    def close(self) -> None: ...
