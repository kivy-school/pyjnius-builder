from typing import Any, ClassVar, overload
from java.lang.Exception import Exception
from java.util.logging.ErrorManager import ErrorManager
from java.util.logging.Filter import Filter
from java.util.logging.Formatter import Formatter
from java.util.logging.Level import Level
from java.util.logging.LogRecord import LogRecord

class Handler:
    def __init__(self) -> None: ...
    def publish(self, arg0: LogRecord) -> None: ...
    def flush(self) -> None: ...
    def close(self) -> None: ...
    def setFormatter(self, arg0: Formatter) -> None: ...
    def getFormatter(self) -> Formatter: ...
    def setEncoding(self, arg0: str) -> None: ...
    def getEncoding(self) -> str: ...
    def setFilter(self, arg0: Filter) -> None: ...
    def getFilter(self) -> Filter: ...
    def setErrorManager(self, arg0: ErrorManager) -> None: ...
    def getErrorManager(self) -> ErrorManager: ...
    def reportError(self, arg0: str, arg1: Exception, arg2: int) -> None: ...
    def setLevel(self, arg0: Level) -> None: ...
    def getLevel(self) -> Level: ...
    def isLoggable(self, arg0: LogRecord) -> bool: ...
