from typing import Any, ClassVar, overload
from java.util.function.Predicate import Predicate
from java.util.regex.Matcher import Matcher
from java.util.stream.Stream import Stream

class Pattern:
    CANON_EQ: ClassVar[int]
    CASE_INSENSITIVE: ClassVar[int]
    COMMENTS: ClassVar[int]
    DOTALL: ClassVar[int]
    LITERAL: ClassVar[int]
    MULTILINE: ClassVar[int]
    UNICODE_CASE: ClassVar[int]
    UNICODE_CHARACTER_CLASS: ClassVar[int]
    UNIX_LINES: ClassVar[int]
    @overload
    @staticmethod
    def compile(arg0: str) -> "Pattern": ...
    @overload
    @staticmethod
    def compile(arg0: str, arg1: int) -> "Pattern": ...
    def pattern(self) -> str: ...
    def toString(self) -> str: ...
    def matcher(self, arg0: str) -> Matcher: ...
    def flags(self) -> int: ...
    @staticmethod
    def matches(arg0: str, arg1: str) -> bool: ...
    @overload
    def split(self, arg0: str, arg1: int) -> list[str]: ...
    @overload
    def split(self, arg0: str) -> list[str]: ...
    @staticmethod
    def quote(arg0: str) -> str: ...
    def asPredicate(self) -> Predicate: ...
    def asMatchPredicate(self) -> Predicate: ...
    def splitAsStream(self, arg0: str) -> Stream: ...
