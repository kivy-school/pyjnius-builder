from typing import Any, ClassVar, overload

class MatchResult:
    @overload
    def start(self) -> int: ...
    @overload
    def start(self, arg0: int) -> int: ...
    @overload
    def end(self) -> int: ...
    @overload
    def end(self, arg0: int) -> int: ...
    @overload
    def group(self) -> str: ...
    @overload
    def group(self, arg0: int) -> str: ...
    def groupCount(self) -> int: ...
