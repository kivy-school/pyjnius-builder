from typing import Any, ClassVar, overload
from java.util.Iterator import Iterator
from java.util.ListIterator import ListIterator

class AbstractList:
    modCount: int
    def __init__(self) -> None: ...
    @overload
    def add(self, arg0: Any) -> bool: ...
    @overload
    def add(self, arg0: int, arg1: Any) -> None: ...
    def get(self, arg0: int) -> Any: ...
    def set(self, arg0: int, arg1: Any) -> Any: ...
    def remove(self, arg0: int) -> Any: ...
    def indexOf(self, arg0: Any) -> int: ...
    def lastIndexOf(self, arg0: Any) -> int: ...
    def clear(self) -> None: ...
    def addAll(self, arg0: int, arg1: list) -> bool: ...
    def iterator(self) -> Iterator: ...
    @overload
    def listIterator(self) -> ListIterator: ...
    @overload
    def listIterator(self, arg0: int) -> ListIterator: ...
    def subList(self, arg0: int, arg1: int) -> list: ...
    def equals(self, arg0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def removeRange(self, arg0: int, arg1: int) -> None: ...
