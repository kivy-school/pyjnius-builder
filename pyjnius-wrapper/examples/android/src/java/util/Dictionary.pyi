from typing import Any, ClassVar, overload
from java.util.Enumeration import Enumeration

class Dictionary:
    def __init__(self) -> None: ...
    def size(self) -> int: ...
    def isEmpty(self) -> bool: ...
    def keys(self) -> Enumeration: ...
    def elements(self) -> Enumeration: ...
    def get(self, arg0: Any) -> Any: ...
    def put(self, arg0: Any, arg1: Any) -> Any: ...
    def remove(self, arg0: Any) -> Any: ...
