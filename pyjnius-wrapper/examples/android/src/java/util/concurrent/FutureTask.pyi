from typing import Any, ClassVar, overload
from java.lang.Runnable import Runnable
from java.lang.Throwable import Throwable
from java.util.concurrent.Callable import Callable
from java.util.concurrent.TimeUnit import TimeUnit

class FutureTask:
    @overload
    def __init__(self, arg0: Callable) -> None: ...
    @overload
    def __init__(self, arg0: Runnable, arg1: Any) -> None: ...
    def isCancelled(self) -> bool: ...
    def isDone(self) -> bool: ...
    def cancel(self, arg0: bool) -> bool: ...
    @overload
    def get(self) -> Any: ...
    @overload
    def get(self, arg0: int, arg1: TimeUnit) -> Any: ...
    def done(self) -> None: ...
    def set(self, arg0: Any) -> None: ...
    def setException(self, arg0: Throwable) -> None: ...
    def run(self) -> None: ...
    def runAndReset(self) -> bool: ...
    def toString(self) -> str: ...
