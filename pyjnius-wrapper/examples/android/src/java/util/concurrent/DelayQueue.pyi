from typing import Any, ClassVar, overload
from java.util.Iterator import Iterator
from java.util.concurrent.Delayed import Delayed
from java.util.concurrent.TimeUnit import TimeUnit

class DelayQueue:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: list) -> None: ...
    def add(self, arg0: Delayed) -> bool: ...
    @overload
    def offer(self, arg0: Delayed) -> bool: ...
    @overload
    def offer(self, arg0: Delayed, arg1: int, arg2: TimeUnit) -> bool: ...
    def put(self, arg0: Delayed) -> None: ...
    @overload
    def poll(self) -> Delayed: ...
    @overload
    def poll(self, arg0: int, arg1: TimeUnit) -> Delayed: ...
    def take(self) -> Delayed: ...
    def peek(self) -> Delayed: ...
    def size(self) -> int: ...
    @overload
    def drainTo(self, arg0: list) -> int: ...
    @overload
    def drainTo(self, arg0: list, arg1: int) -> int: ...
    def clear(self) -> None: ...
    def remainingCapacity(self) -> int: ...
    @overload
    def toArray(self) -> list: ...
    @overload
    def toArray(self, arg0: list) -> list: ...
    def remove(self, arg0: Any) -> bool: ...
    def iterator(self) -> Iterator: ...
