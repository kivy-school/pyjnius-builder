from typing import Any, ClassVar, overload
from java.util.concurrent.TimeUnit import TimeUnit

class TransferQueue:
    @overload
    def tryTransfer(self, arg0: Any) -> bool: ...
    @overload
    def tryTransfer(self, arg0: Any, arg1: int, arg2: TimeUnit) -> bool: ...
    def transfer(self, arg0: Any) -> None: ...
    def hasWaitingConsumer(self) -> bool: ...
    def getWaitingConsumerCount(self) -> int: ...
