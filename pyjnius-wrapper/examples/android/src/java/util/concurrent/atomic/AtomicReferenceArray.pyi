from typing import Any, ClassVar, overload
from java.util.function.BinaryOperator import BinaryOperator
from java.util.function.UnaryOperator import UnaryOperator

class AtomicReferenceArray:
    @overload
    def __init__(self, arg0: int) -> None: ...
    @overload
    def __init__(self, arg0: list) -> None: ...
    def length(self) -> int: ...
    def get(self, arg0: int) -> Any: ...
    def set(self, arg0: int, arg1: Any) -> None: ...
    def lazySet(self, arg0: int, arg1: Any) -> None: ...
    def getAndSet(self, arg0: int, arg1: Any) -> Any: ...
    def compareAndSet(self, arg0: int, arg1: Any, arg2: Any) -> bool: ...
    def weakCompareAndSet(self, arg0: int, arg1: Any, arg2: Any) -> bool: ...
    def weakCompareAndSetPlain(self, arg0: int, arg1: Any, arg2: Any) -> bool: ...
    def getAndUpdate(self, arg0: int, arg1: UnaryOperator) -> Any: ...
    def updateAndGet(self, arg0: int, arg1: UnaryOperator) -> Any: ...
    def getAndAccumulate(self, arg0: int, arg1: Any, arg2: BinaryOperator) -> Any: ...
    def accumulateAndGet(self, arg0: int, arg1: Any, arg2: BinaryOperator) -> Any: ...
    def toString(self) -> str: ...
    def getPlain(self, arg0: int) -> Any: ...
    def setPlain(self, arg0: int, arg1: Any) -> None: ...
    def getOpaque(self, arg0: int) -> Any: ...
    def setOpaque(self, arg0: int, arg1: Any) -> None: ...
    def getAcquire(self, arg0: int) -> Any: ...
    def setRelease(self, arg0: int, arg1: Any) -> None: ...
    def compareAndExchange(self, arg0: int, arg1: Any, arg2: Any) -> Any: ...
    def compareAndExchangeAcquire(self, arg0: int, arg1: Any, arg2: Any) -> Any: ...
    def compareAndExchangeRelease(self, arg0: int, arg1: Any, arg2: Any) -> Any: ...
    def weakCompareAndSetVolatile(self, arg0: int, arg1: Any, arg2: Any) -> bool: ...
    def weakCompareAndSetAcquire(self, arg0: int, arg1: Any, arg2: Any) -> bool: ...
    def weakCompareAndSetRelease(self, arg0: int, arg1: Any, arg2: Any) -> bool: ...
