    def __init__(self, arg0: Any, arg1: bool) -> None: ...
    def getReference(self) -> Any: ...
    def isMarked(self) -> bool: ...
    def get(self, arg0: list[bool]) -> Any: ...
    def weakCompareAndSet(self, arg0: Any, arg1: Any, arg2: bool, arg3: bool) -> bool: ...
    def compareAndSet(self, arg0: Any, arg1: Any, arg2: bool, arg3: bool) -> bool: ...
    def set(self, arg0: Any, arg1: bool) -> None: ...
    def attemptMark(self, arg0: Any, arg1: bool) -> bool: ...
