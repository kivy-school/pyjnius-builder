from typing import Any, ClassVar, overload
from java.lang.Runnable import Runnable
from java.util.concurrent.Callable import Callable
from java.util.concurrent.Future import Future
from java.util.concurrent.RunnableFuture import RunnableFuture
from java.util.concurrent.TimeUnit import TimeUnit

class AbstractExecutorService:
    def __init__(self) -> None: ...
    @overload
    def newTaskFor(self, arg0: Runnable, arg1: Any) -> RunnableFuture: ...
    @overload
    def newTaskFor(self, arg0: Callable) -> RunnableFuture: ...
    @overload
    def submit(self, arg0: Runnable) -> Future: ...
    @overload
    def submit(self, arg0: Runnable, arg1: Any) -> Future: ...
    @overload
    def submit(self, arg0: Callable) -> Future: ...
    @overload
    def invokeAny(self, arg0: list) -> Any: ...
    @overload
    def invokeAny(self, arg0: list, arg1: int, arg2: TimeUnit) -> Any: ...
    @overload
    def invokeAll(self, arg0: list) -> list: ...
    @overload
    def invokeAll(self, arg0: list, arg1: int, arg2: TimeUnit) -> list: ...
