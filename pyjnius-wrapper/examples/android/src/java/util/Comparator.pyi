from typing import Any, ClassVar, overload
from java.util.function.Function import Function
from java.util.function.ToDoubleFunction import ToDoubleFunction
from java.util.function.ToIntFunction import ToIntFunction
from java.util.function.ToLongFunction import ToLongFunction

class Comparator:
    def compare(self, arg0: Any, arg1: Any) -> int: ...
    def equals(self, arg0: Any) -> bool: ...
    def reversed(self) -> "Comparator": ...
    @overload
    def thenComparing(self, arg0: "Comparator") -> "Comparator": ...
    @overload
    def thenComparing(self, arg0: Function, arg1: "Comparator") -> "Comparator": ...
    @overload
    def thenComparing(self, arg0: Function) -> "Comparator": ...
    def thenComparingInt(self, arg0: ToIntFunction) -> "Comparator": ...
    def thenComparingLong(self, arg0: ToLongFunction) -> "Comparator": ...
    def thenComparingDouble(self, arg0: ToDoubleFunction) -> "Comparator": ...
    @staticmethod
    def reverseOrder() -> "Comparator": ...
    @staticmethod
    def naturalOrder() -> "Comparator": ...
    @staticmethod
    def nullsFirst(arg0: "Comparator") -> "Comparator": ...
    @staticmethod
    def nullsLast(arg0: "Comparator") -> "Comparator": ...
    @overload
    @staticmethod
    def comparing(arg0: Function, arg1: "Comparator") -> "Comparator": ...
    @overload
    @staticmethod
    def comparing(arg0: Function) -> "Comparator": ...
    @staticmethod
    def comparingInt(arg0: ToIntFunction) -> "Comparator": ...
    @staticmethod
    def comparingLong(arg0: ToLongFunction) -> "Comparator": ...
    @staticmethod
    def comparingDouble(arg0: ToDoubleFunction) -> "Comparator": ...
