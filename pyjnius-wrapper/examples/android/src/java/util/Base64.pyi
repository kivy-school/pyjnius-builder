from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.io.OutputStream import OutputStream
from java.nio.ByteBuffer import ByteBuffer

class Base64:
    @staticmethod
    def getEncoder() -> "Encoder": ...
    @staticmethod
    def getUrlEncoder() -> "Encoder": ...
    @overload
    @staticmethod
    def getMimeEncoder() -> "Encoder": ...
    @overload
    @staticmethod
    def getMimeEncoder(arg0: int, arg1: list[int]) -> "Encoder": ...
    @staticmethod
    def getDecoder() -> "Decoder": ...
    @staticmethod
    def getUrlDecoder() -> "Decoder": ...
    @staticmethod
    def getMimeDecoder() -> "Decoder": ...

    class Decoder:
        @overload
        def decode(self, arg0: list[int]) -> list[int]: ...
        @overload
        def decode(self, arg0: str) -> list[int]: ...
        @overload
        def decode(self, arg0: list[int], arg1: list[int]) -> int: ...
        @overload
        def decode(self, arg0: ByteBuffer) -> ByteBuffer: ...
        def wrap(self, arg0: InputStream) -> InputStream: ...

    class Encoder:
        @overload
        def encode(self, arg0: list[int]) -> list[int]: ...
        @overload
        def encode(self, arg0: list[int], arg1: list[int]) -> int: ...
        @overload
        def encode(self, arg0: ByteBuffer) -> ByteBuffer: ...
        def encodeToString(self, arg0: list[int]) -> str: ...
        def wrap(self, arg0: OutputStream) -> OutputStream: ...
        def withoutPadding(self) -> "Encoder": ...
