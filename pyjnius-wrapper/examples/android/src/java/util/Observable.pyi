from typing import Any, ClassVar, overload
from java.util.Observer import Observer

class Observable:
    def __init__(self) -> None: ...
    def addObserver(self, arg0: Observer) -> None: ...
    def deleteObserver(self, arg0: Observer) -> None: ...
    @overload
    def notifyObservers(self) -> None: ...
    @overload
    def notifyObservers(self, arg0: Any) -> None: ...
    def deleteObservers(self) -> None: ...
    def setChanged(self) -> None: ...
    def clearChanged(self) -> None: ...
    def hasChanged(self) -> bool: ...
    def countObservers(self) -> int: ...
