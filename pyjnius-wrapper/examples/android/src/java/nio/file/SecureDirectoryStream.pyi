from typing import Any, ClassVar, overload
from java.nio.channels.SeekableByteChannel import SeekableByteChannel
from java.nio.file.LinkOption import LinkOption
from java.nio.file.attribute.FileAttribute import FileAttribute
from java.nio.file.attribute.FileAttributeView import FileAttributeView

class SecureDirectoryStream:
    def newDirectoryStream(self, arg0: Any, *arg1: LinkOption) -> "SecureDirectoryStream": ...
    def newByteChannel(self, arg0: Any, arg1: set, *arg2: FileAttribute) -> SeekableByteChannel: ...
    def deleteFile(self, arg0: Any) -> None: ...
    def deleteDirectory(self, arg0: Any) -> None: ...
    def move(self, arg0: Any, arg1: "SecureDirectoryStream", arg2: Any) -> None: ...
    @overload
    def getFileAttributeView(self, arg0: type) -> FileAttributeView: ...
    @overload
    def getFileAttributeView(self, arg0: Any, arg1: type, *arg2: LinkOption) -> FileAttributeView: ...
