from typing import Any, ClassVar, overload
from java.io.IOException import IOException
from java.nio.file.FileVisitResult import FileVisitResult
from java.nio.file.attribute.BasicFileAttributes import BasicFileAttributes

class FileVisitor:
    def preVisitDirectory(self, arg0: Any, arg1: BasicFileAttributes) -> FileVisitResult: ...
    def visitFile(self, arg0: Any, arg1: BasicFileAttributes) -> FileVisitResult: ...
    def visitFileFailed(self, arg0: Any, arg1: IOException) -> FileVisitResult: ...
    def postVisitDirectory(self, arg0: Any, arg1: IOException) -> FileVisitResult: ...
