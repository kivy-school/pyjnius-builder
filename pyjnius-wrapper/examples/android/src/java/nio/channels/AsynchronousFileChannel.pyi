    def lock(self, arg0: int, arg1: int, arg2: bool) -> Future: ...
    @overload
    def lock(self) -> Future: ...
    @overload
    def tryLock(self, arg0: int, arg1: int, arg2: bool) -> FileLock: ...
    @overload
    def tryLock(self) -> FileLock: ...
