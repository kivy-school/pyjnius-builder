    def __init__(self) -> None: ...
    @overload
    @staticmethod
    def open(arg0: Path, arg1: set, arg2: ExecutorService, *arg3: FileAttribute) -> "AsynchronousFileChannel": ...
    @overload
    @staticmethod
    def open(arg0: Path, *arg1: OpenOption) -> "AsynchronousFileChannel": ...
    def size(self) -> int: ...
    def truncate(self, arg0: int) -> "AsynchronousFileChannel": ...
    def force(self, arg0: bool) -> None: ...
