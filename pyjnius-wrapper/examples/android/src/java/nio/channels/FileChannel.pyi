from typing import Any, ClassVar, overload
from java.nio.ByteBuffer import ByteBuffer
from java.nio.MappedByteBuffer import MappedByteBuffer
from java.nio.channels.FileLock import FileLock
from java.nio.channels.ReadableByteChannel import ReadableByteChannel
from java.nio.channels.WritableByteChannel import WritableByteChannel
from java.nio.file.OpenOption import OpenOption
from java.nio.file.Path import Path
from java.nio.file.attribute.FileAttribute import FileAttribute

class FileChannel:
    def __init__(self) -> None: ...
    @overload
    @staticmethod
    def open(arg0: Path, arg1: set, *arg2: FileAttribute) -> "FileChannel": ...
    @overload
    @staticmethod
    def open(arg0: Path, *arg1: OpenOption) -> "FileChannel": ...
    @overload
    def read(self, arg0: ByteBuffer) -> int: ...
    @overload
    def read(self, arg0: list[ByteBuffer], arg1: int, arg2: int) -> int: ...
    @overload
    def read(self, arg0: list[ByteBuffer]) -> int: ...
    @overload
    def read(self, arg0: ByteBuffer, arg1: int) -> int: ...
    @overload
    def write(self, arg0: ByteBuffer) -> int: ...
    @overload
    def write(self, arg0: list[ByteBuffer], arg1: int, arg2: int) -> int: ...
    @overload
    def write(self, arg0: list[ByteBuffer]) -> int: ...
    @overload
    def write(self, arg0: ByteBuffer, arg1: int) -> int: ...
    @overload
    def position(self) -> int: ...
    @overload
    def position(self, arg0: int) -> "FileChannel": ...
    def size(self) -> int: ...
    def truncate(self, arg0: int) -> "FileChannel": ...
    def force(self, arg0: bool) -> None: ...
    def transferTo(self, arg0: int, arg1: int, arg2: WritableByteChannel) -> int: ...
    def transferFrom(self, arg0: ReadableByteChannel, arg1: int, arg2: int) -> int: ...
    def map(self, arg0: "MapMode", arg1: int, arg2: int) -> MappedByteBuffer: ...
    @overload
    def lock(self, arg0: int, arg1: int, arg2: bool) -> FileLock: ...
    @overload
    def lock(self) -> FileLock: ...
    @overload
    def tryLock(self, arg0: int, arg1: int, arg2: bool) -> FileLock: ...
    @overload
    def tryLock(self) -> FileLock: ...

    class MapMode:
        PRIVATE: ClassVar["MapMode"]
        READ_ONLY: ClassVar["MapMode"]
        READ_WRITE: ClassVar["MapMode"]
        def toString(self) -> str: ...
