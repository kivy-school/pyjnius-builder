from typing import Any, ClassVar, overload
from java.nio.channels.AsynchronousFileChannel import AsynchronousFileChannel
from java.nio.channels.Channel import Channel
from java.nio.channels.FileChannel import FileChannel

class FileLock:
    @overload
    def __init__(self, arg0: FileChannel, arg1: int, arg2: int, arg3: bool) -> None: ...
    @overload
    def __init__(self, arg0: AsynchronousFileChannel, arg1: int, arg2: int, arg3: bool) -> None: ...
    def channel(self) -> FileChannel: ...
    def acquiredBy(self) -> Channel: ...
    def position(self) -> int: ...
    def size(self) -> int: ...
    def isShared(self) -> bool: ...
    def overlaps(self, arg0: int, arg1: int) -> bool: ...
    def isValid(self) -> bool: ...
    def release(self) -> None: ...
    def close(self) -> None: ...
    def toString(self) -> str: ...
