from typing import Any, ClassVar, overload
from java.util.Locale import Locale
from org.xml.sax.DTDHandler import DTDHandler
from org.xml.sax.DocumentHandler import DocumentHandler
from org.xml.sax.EntityResolver import EntityResolver
from org.xml.sax.ErrorHandler import ErrorHandler
from org.xml.sax.InputSource import InputSource

class Parser:
    def setLocale(self, arg0: Locale) -> None: ...
    def setEntityResolver(self, arg0: EntityResolver) -> None: ...
    def setDTDHandler(self, arg0: DTDHandler) -> None: ...
    def setDocumentHandler(self, arg0: DocumentHandler) -> None: ...
    def setErrorHandler(self, arg0: ErrorHandler) -> None: ...
    @overload
    def parse(self, arg0: InputSource) -> None: ...
    @overload
    def parse(self, arg0: str) -> None: ...
