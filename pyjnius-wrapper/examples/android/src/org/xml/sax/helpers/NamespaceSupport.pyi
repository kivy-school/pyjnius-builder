from typing import Any, ClassVar, overload
from java.util.Enumeration import Enumeration

class NamespaceSupport:
    NSDECL: ClassVar[str]
    XMLNS: ClassVar[str]
    def __init__(self) -> None: ...
    def reset(self) -> None: ...
    def pushContext(self) -> None: ...
    def popContext(self) -> None: ...
    def declarePrefix(self, arg0: str, arg1: str) -> bool: ...
    def processName(self, arg0: str, arg1: list[str], arg2: bool) -> list[str]: ...
    def getURI(self, arg0: str) -> str: ...
    @overload
    def getPrefixes(self) -> Enumeration: ...
    @overload
    def getPrefixes(self, arg0: str) -> Enumeration: ...
    def getPrefix(self, arg0: str) -> str: ...
    def getDeclaredPrefixes(self) -> Enumeration: ...
    def setNamespaceDeclUris(self, arg0: bool) -> None: ...
    def isNamespaceDeclUris(self) -> bool: ...
