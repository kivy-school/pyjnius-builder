from typing import Any, ClassVar, overload
from java.security.cert.X509Certificate import X509Certificate
from javax.net.ssl.SSLSession import SSLSession
from javax.net.ssl.SSLSocket import SSLSocket

class AbstractVerifier:
    def __init__(self) -> None: ...
    @overload
    def verify(self, arg0: str, arg1: SSLSocket) -> None: ...
    @overload
    def verify(self, arg0: str, arg1: SSLSession) -> bool: ...
    @overload
    def verify(self, arg0: str, arg1: X509Certificate) -> None: ...
    @overload
    def verify(self, arg0: str, arg1: list[str], arg2: list[str], arg3: bool) -> None: ...
    @staticmethod
    def acceptableCountryWildcard(arg0: str) -> bool: ...
    @staticmethod
    def getCNs(arg0: X509Certificate) -> list[str]: ...
    @staticmethod
    def getDNSSubjectAlts(arg0: X509Certificate) -> list[str]: ...
    @staticmethod
    def countDots(arg0: str) -> int: ...
