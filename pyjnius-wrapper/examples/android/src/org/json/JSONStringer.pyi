from typing import Any, ClassVar, overload

class JSONStringer:
    def __init__(self) -> None: ...
    def array(self) -> "JSONStringer": ...
    def endArray(self) -> "JSONStringer": ...
    def object(self) -> "JSONStringer": ...
    def endObject(self) -> "JSONStringer": ...
    @overload
    def value(self, arg0: Any) -> "JSONStringer": ...
    @overload
    def value(self, arg0: bool) -> "JSONStringer": ...
    @overload
    def value(self, arg0: float) -> "JSONStringer": ...
    @overload
    def value(self, arg0: int) -> "JSONStringer": ...
    def key(self, arg0: str) -> "JSONStringer": ...
    def toString(self) -> str: ...
