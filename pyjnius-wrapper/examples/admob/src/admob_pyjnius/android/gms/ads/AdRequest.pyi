from typing import Any, ClassVar, overload
from android.gms.ads.AbstractAdRequestBuilder import AbstractAdRequestBuilder
from android.gms.ads.internal.client.zzeh import zzeh

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class Bundle: ...  # android.os.Bundle
class Context: ...  # android.content.Context

class AdRequest:
    ERROR_CODE_INTERNAL_ERROR: ClassVar[int]
    ERROR_CODE_INVALID_REQUEST: ClassVar[int]
    ERROR_CODE_NETWORK_ERROR: ClassVar[int]
    ERROR_CODE_NO_FILL: ClassVar[int]
    ERROR_CODE_APP_ID_MISSING: ClassVar[int]
    ERROR_CODE_REQUEST_ID_MISMATCH: ClassVar[int]
    ERROR_CODE_INVALID_AD_STRING: ClassVar[int]
    ERROR_CODE_MEDIATION_NO_FILL: ClassVar[int]
    MAX_CONTENT_URL_LENGTH: ClassVar[int]
    DEVICE_ID_EMULATOR: ClassVar[str]
    zza: zzeh
    def __init__(self, arg0: AbstractAdRequestBuilder) -> None: ...
    def getContentUrl(self) -> str: ...
    def getNeighboringContentUrls(self) -> list: ...
    def getKeywords(self) -> set: ...
    def getNetworkExtrasBundle(self, arg0: type) -> Bundle: ...
    def getCustomEventExtrasBundle(self, arg0: type) -> Bundle: ...
    def isTestDevice(self, arg0: Context) -> bool: ...
    def getCustomTargeting(self) -> Bundle: ...
    def getRequestAgent(self) -> str: ...
    def getAdString(self) -> str: ...
    def getPlacementId(self) -> int: ...
    def zza(self) -> zzeh: ...

    class Builder:
        def __init__(self) -> None: ...
        def build(self) -> "AdRequest": ...
        def self(self) -> "Builder": ...
