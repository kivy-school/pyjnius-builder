from typing import Any, ClassVar, overload
from android.gms.ads.AdError import AdError

class FullScreenContentCallback:
    ERROR_CODE_INTERNAL_ERROR: ClassVar[int]
    ERROR_CODE_AD_REUSED: ClassVar[int]
    ERROR_CODE_NOT_READY: ClassVar[int]
    ERROR_CODE_APP_NOT_FOREGROUND: ClassVar[int]
    ERROR_CODE_MEDIATION_SHOW_ERROR: ClassVar[int]
    def __init__(self) -> None: ...
    def onAdFailedToShowFullScreenContent(self, arg0: AdError) -> None: ...
    def onAdShowedFullScreenContent(self) -> None: ...
    def onAdDismissedFullScreenContent(self) -> None: ...
    def onAdImpression(self) -> None: ...
    def onAdClicked(self) -> None: ...
