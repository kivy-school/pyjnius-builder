from typing import Any, ClassVar, overload
from android.gms.ads.AdError import AdError
from android.gms.ads.rewarded.RewardItem import RewardItem

class MediationRewardedAdCallback:
    @overload
    def onUserEarnedReward(self, arg0: RewardItem) -> None: ...
    @overload
    def onUserEarnedReward(self) -> None: ...
    def onVideoStart(self) -> None: ...
    def onVideoComplete(self) -> None: ...
    def onAdFailedToShow(self, arg0: AdError) -> None: ...
