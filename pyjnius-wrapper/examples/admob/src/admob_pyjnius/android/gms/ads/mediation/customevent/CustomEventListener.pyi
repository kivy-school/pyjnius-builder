from typing import Any, ClassVar, overload

class CustomEventListener:
    @overload
    def onAdFailedToLoad(self, arg0: int) -> None: ...
    @overload
    def onAdFailedToLoad(self, arg0: "AdError") -> None: ...
    def onAdOpened(self) -> None: ...
    def onAdClicked(self) -> None: ...
    def onAdClosed(self) -> None: ...
    def onAdLeftApplication(self) -> None: ...
