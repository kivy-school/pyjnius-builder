from typing import Any, ClassVar, overload
from android.gms.ads.internal.client.zzea import zzea

class VideoController:
    PLAYBACK_STATE_UNKNOWN: ClassVar[int]
    PLAYBACK_STATE_PLAYING: ClassVar[int]
    PLAYBACK_STATE_PAUSED: ClassVar[int]
    PLAYBACK_STATE_ENDED: ClassVar[int]
    PLAYBACK_STATE_READY: ClassVar[int]
    def __init__(self) -> None: ...
    def play(self) -> None: ...
    def pause(self) -> None: ...
    def stop(self) -> None: ...
    def mute(self, arg0: bool) -> None: ...
    def isMuted(self) -> bool: ...
    def getPlaybackState(self) -> int: ...
    def isCustomControlsEnabled(self) -> bool: ...
    def isClickToExpandEnabled(self) -> bool: ...
    def setVideoLifecycleCallbacks(self, arg0: "VideoLifecycleCallbacks") -> None: ...
    def getVideoLifecycleCallbacks(self) -> "VideoLifecycleCallbacks": ...
    def hasVideoContent(self) -> bool: ...
    def zza(self, arg0: zzea) -> None: ...
    def zzb(self) -> zzea: ...

    class VideoLifecycleCallbacks:
        def __init__(self) -> None: ...
        def onVideoStart(self) -> None: ...
        def onVideoPlay(self) -> None: ...
        def onVideoPause(self) -> None: ...
        def onVideoEnd(self) -> None: ...
        def onVideoMute(self, arg0: bool) -> None: ...
